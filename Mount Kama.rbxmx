			<Item class="LocalScript" referent="RBXECCD81A2E23E46C1973A048EFBF083C8">
				<Properties>
					<ProtectedString name="Source"><![CDATA[-- SERVICES
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

-- PLAYER
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- TOUCH GUI (ROBLOX DEFAULT)
local touchGui = playerGui:FindFirstChild("TouchGui")
local controlFrame = touchGui:WaitForChild("TouchControlFrame")
local jumpButton = controlFrame:WaitForChild("JumpButton")

-- SETTINGS UI
local screenGui = playerGui:WaitForChild("ScreenGui")
local frame = screenGui:WaitForChild("JumpButtonFrame")
local editButton = frame:WaitForChild("EditButton")

-- STATE
local editMode = false
local dragging = false
local dragStartPos
local buttonStartPos

------------------------------------------------
-- EDIT BUTTON LOGIC
------------------------------------------------

local function updateEditVisual()
	local stroke = jumpButton:FindFirstChild("EditStroke")

	if editMode then
		if not stroke then
			stroke = Instance.new("UIStroke")
			stroke.Name = "EditStroke"
			stroke.Thickness = 2
			stroke.Color = Color3.fromRGB(255, 12, 129)
			stroke.Transparency = 0.3
			stroke.Parent = jumpButton
		end
	else
		if stroke then
			stroke:Destroy()
		end
	end
end

local function updateEditButton()
	if editMode then
		editButton.Text = "SELESAI"
	else
		editButton.Text = "UBAH POSISI"
	end

	updateEditVisual()
end

updateEditButton()

editButton.MouseButton1Click:Connect(function()
	editMode = not editMode
	updateEditButton()
end)

------------------------------------------------
-- DRAG JUMP BUTTON (EDIT MODE ONLY)
------------------------------------------------

-- mulai drag
jumpButton.InputBegan:Connect(function(input)
	if not editMode then return end
	if input.UserInputType ~= Enum.UserInputType.Touch then return end

	dragging = true
	dragStartPos = input.Position

	-- 🔧 FIX BUG PERTAMA KALI
	buttonStartPos = UDim2.fromOffset(
		jumpButton.AbsolutePosition.X,
		jumpButton.AbsolutePosition.Y
	)

	input:CaptureController()
end)


-- drag bergerak
UIS.InputChanged:Connect(function(input)
	if not dragging then return end
	if input.UserInputType ~= Enum.UserInputType.Touch then return end

	local delta = input.Position - dragStartPos

	local newX = buttonStartPos.X.Offset + delta.X
	local newY = buttonStartPos.Y.Offset + delta.Y

	-- clamp ke layar
	local viewport = workspace.CurrentCamera.ViewportSize
	local size = jumpButton.AbsoluteSize

	newX = math.clamp(newX, 0, viewport.X - size.X)
	newY = math.clamp(newY, 0, viewport.Y - size.Y)

	jumpButton.Position = UDim2.fromOffset(newX, newY)
end)

-- lepas drag
UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)
]]></ProtectedString>
