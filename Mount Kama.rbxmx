		<Item class="LocalScript" referent="RBX6FB7F2FE9CCA431FB64ED4AE272E2B36">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local shutdownEvent = ReplicatedStorage:WaitForChild("ServerShutdownEvent")

shutdownEvent.OnClientEvent:Connect(function(seconds)
	-- ScreenGui
	local gui = Instance.new("ScreenGui")
	gui.Name = "ShutdownGui"
	gui.ResetOnSpawn = false
	gui.Parent = player:WaitForChild("PlayerGui")

	-- TextLabel
	local text = Instance.new("TextLabel")
	text.Size = UDim2.fromScale(1, 0.15)
	text.Position = UDim2.fromScale(0, 0.4)
	text.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	text.BackgroundTransparency = 0.2
	text.TextScaled = true
	text.Font = Enum.Font.GothamBold
	text.TextColor3 = Color3.fromRGB(255, 80, 80)
	text.TextStrokeTransparency = 0.3
	text.Parent = gui

	-- Countdown
	for i = seconds, 1, -1 do
		text.Text = "⚠ SERVER AKAN RESTART DALAM " .. i .. " DETIK"
		task.wait(1)
	end

	text.Text = "🔄 SERVER RESTART..."
end)
]]></ProtectedString>
