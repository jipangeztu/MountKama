				<Properties>
					<ProtectedString name="Source"><![CDATA[local button = script.Parent
local on = false
local soundOn  = button:WaitForChild("SoundOn")
local soundOff = button:WaitForChild("SoundOff")

button.MouseButton1Click:Connect(function()
	on = not on
	

	if on then
		soundOn:Play()
	else
		soundOff:Play()
	end
end)

