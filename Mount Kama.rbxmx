	<Item class="Script" referent="RBX4B1032E422704C9EBFC687C01B5376C6">
		<Properties>
			<ProtectedString name="Source"><![CDATA[-- SERVICES
local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")
local ServerStorage = game:GetService("ServerStorage")

-- CONFIG
local VIP_GAMEPASS_ID = 1684320630
local VIP_TOOLS_FOLDER = ServerStorage:WaitForChild("VIPTools")

-- GIVE TOOLS
local function giveVIPTools(player)
	if player:GetAttribute("VIP") ~= true then
		return
	end

	local backpack = player:WaitForChild("Backpack", 5)
	if not backpack then
		warn("Backpack tidak ditemukan:", player.Name)
		return
	end

	for _, tool in ipairs(VIP_TOOLS_FOLDER:GetChildren()) do
		if tool:IsA("Tool") then
			if not backpack:FindFirstChild(tool.Name) then
				local clone = tool:Clone()
				clone.Parent = backpack
				print("VIP Tool diberikan:", tool.Name, "ke", player.Name)
			end
		end
	end
end

-- CHECK VIP
local function checkVIP(player)
	local success, hasPass = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, VIP_GAMEPASS_ID)
	end)

	player:SetAttribute("VIP", success and hasPass == true)
end

-- PLAYER JOIN
Players.PlayerAdded:Connect(function(player)
	player:SetAttribute("VIP", false)

	checkVIP(player)

	player.CharacterAdded:Connect(function()
		-- tunggu Backpack benar-benar siap
		task.wait(1)
		giveVIPTools(player)
	end)
end)

-- BUY VIP MID GAME
MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, passId, purchased)
	if passId ~= VIP_GAMEPASS_ID then return end
	if not purchased then return end

	player:SetAttribute("VIP", true)

	-- kasih tool langsung
	task.wait(0.5)
	giveVIPTools(player)
end)
]]></ProtectedString>
