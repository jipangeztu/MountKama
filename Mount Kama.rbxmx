			<Item class="LocalScript" referent="RBX2F7DECD147FD40C58D3F13E6C651DEB5">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--================================
-- SERVICES
--================================
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local RS = game:GetService("ReplicatedStorage")
local TeleportEvent = RS:WaitForChild("AdminTeleport")


--================================
-- UI REFERENCES
--================================
local panel = script.Parent
local list = panel:WaitForChild("PlayerList")
local template = panel:WaitForChild("PlayerButtonTemplate")

local searchBox = panel:WaitForChild("SearchBox")
local sortButton = panel:WaitForChild("SortButton")

local actionMenu = panel:WaitForChild("ActionMenu")
local teleButton = actionMenu:WaitForChild("TeleButton")
local bringButton = actionMenu:WaitForChild("BringButton")

--================================
-- STATE
--================================
local sortAscending = true
local currentSearch = ""
local selectedPlayer = nil

actionMenu.Visible = false

--================================
-- AVATAR FUNCTION
--================================
local function getAvatar(userId)
	local content = Players:GetUserThumbnailAsync(
		userId,
		Enum.ThumbnailType.HeadShot,
		Enum.ThumbnailSize.Size100x100
	)
	return content
end

--================================
-- CLEAR PLAYER LIST
--================================
local function clearList()
	for _, child in ipairs(list:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end
end

--================================
-- SORT
--================================
local function sortPlayers(players)
	table.sort(players, function(a, b)
		if sortAscending then
			return a.Name:lower() < b.Name:lower()
		else
			return a.Name:lower() > b.Name:lower()
		end
	end)
end

--================================
-- REFRESH LIST
--================================
local function refreshList()
	clearList()

	local players = Players:GetPlayers()

	-- SEARCH FILTER
	if currentSearch ~= "" then
		local filtered = {}
		for _, plr in ipairs(players) do
			if plr.Name:lower():find(currentSearch, 1, true) then
				table.insert(filtered, plr)
			end
		end
		players = filtered
	end

	sortPlayers(players)

	for _, plr in ipairs(players) do
		local button = template:Clone()
		button.Visible = true
		button.Parent = list
		button.Name = plr.Name

		local avatar = button:WaitForChild("Avatar")
		local nameLabel = button:WaitForChild("NameLabel")

		nameLabel.Text = plr.Name
		avatar.Image = getAvatar(plr.UserId)

		-- CLICK PLAYER
		button.MouseButton1Click:Connect(function()
			selectedPlayer = plr

			actionMenu.Visible = true
			local panelPos = panel.AbsolutePosition
			local btnPos = button.AbsolutePosition

			local x = (btnPos.X - panelPos.X) + button.AbsoluteSize.X + 6
			local y = (btnPos.Y - panelPos.Y)

			actionMenu.Position = UDim2.fromOffset(x, y)


			print("Selected:", plr.Name)
		end)
	end
end

--================================
-- SEARCH
--================================
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	currentSearch = searchBox.Text:lower()
	refreshList()
end)

--================================
-- SORT BUTTON
--================================
sortButton.MouseButton1Click:Connect(function()
	sortAscending = not sortAscending
	sortButton.Text = sortAscending and "A → Z" or "Z → A"
	refreshList()
end)

--================================
-- ACTION MENU BUTTONS
--================================
teleButton.MouseButton1Click:Connect(function()
	if not selectedPlayer then return end
	TeleportEvent:FireServer("tele", selectedPlayer.Name)
	actionMenu.Visible = false
end)

bringButton.MouseButton1Click:Connect(function()
	if not selectedPlayer then return end
	TeleportEvent:FireServer("bring", selectedPlayer.Name)
	actionMenu.Visible = false
end)


--================================
-- CLICK OUTSIDE = CLOSE MENU
--================================
panel.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		actionMenu.Visible = false
	end
end)

--================================
-- PLAYER JOIN / LEAVE
--================================
Players.PlayerAdded:Connect(refreshList)
Players.PlayerRemoving:Connect(refreshList)

-- INIT
refreshList()
]]></ProtectedString>
