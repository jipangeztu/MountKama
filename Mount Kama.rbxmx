	<Item class="Script" referent="RBXE4884D0C16AD443796BF6D5B3C022658">
		<Properties>
			<ProtectedString name="Source"><![CDATA[game.Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(char)
		task.wait(0.1)

		-- 🚫 SKIP kalau sedang ChangeAva
		if char:GetAttribute("IgnoreCheckpointTeleport") then
			return
		end

		local cpId = player:GetAttribute("Checkpoint") or 0
		local target

		if cpId == 0 then
			target = workspace.Start
		else
			target = workspace.cp:FindFirstChild(tostring(cpId))
		end

		if target then
			char:MoveTo(target.Position + Vector3.new(0,3,0))
		end
	end)
end)
]]></ProtectedString>
