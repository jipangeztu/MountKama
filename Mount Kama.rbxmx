	<Item class="Script" referent="RBX371246B31D4E4627907AA9E835C9076A">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local SummitStore = DataStoreService:GetDataStore("SummitDataV1")

-- simpan status summit aktif per player
local SummitActive = {}

-- LOAD DATA
Players.PlayerAdded:Connect(function(player)
	local data
	pcall(function()
		data = SummitStore:GetAsync(player.UserId)
	end)

	local stats = player:WaitForChild("leaderstats")
	local summit = stats:WaitForChild("Summit")

	if data then
		summit.Value = data.Summit or 0
		SummitActive[player] = data.SummitActive ~= false
	else
		SummitActive[player] = true
	end
end)

-- SAVE DATA
Players.PlayerRemoving:Connect(function(player)
	local stats = player:FindFirstChild("leaderstats")
	if not stats then return end

	local summit = stats:FindFirstChild("Summit")
	if not summit then return end

	pcall(function()
		SummitStore:SetAsync(player.UserId, {
			Summit = summit.Value,
			SummitActive = SummitActive[player]
		})
	end)

	SummitActive[player] = nil
end)

-- fungsi reset summit (dipanggil dari Start / CP1)
_G.ResetSummit = function(player)
	SummitActive[player] = true
end

-- fungsi saat summit disentuh
_G.TakeSummit = function(player)
	SummitActive[player] = false
end

_G.IsSummitActive = function(player)
	return SummitActive[player] == true
end
]]></ProtectedString>
