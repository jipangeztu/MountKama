	<Item class="Script" referent="RBX2B1E8F73645D4E7DAF3C1ACF930ECF0A">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")

local function createSummitGui(character, summitValue)
	local head = character:FindFirstChild("Head")
	if not head then return end

	local gui = character:FindFirstChild("SummitGui")
	if not gui then
		gui = Instance.new("BillboardGui")
		gui.Name = "SummitGui"
		gui.Size = UDim2.fromScale(3, 1)
		gui.StudsOffset = Vector3.new(0, 2.8, 0)
		gui.AlwaysOnTop = true
		gui.Parent = character

		local text = Instance.new("TextLabel")
		text.Name = "Text"
		text.Size = UDim2.fromScale(1, 1)
		text.BackgroundTransparency = 1
		text.TextScaled = true
		text.Font = Enum.Font.GothamBold
		text.TextColor3 = Color3.fromRGB(82, 255, 243)
		text.TextStrokeTransparency = 0.3
		text.Parent = gui

		summitValue.Changed:Connect(function()
			text.Text = "Summit: " .. summitValue.Value
		end)
	end

	gui.Adornee = head
	gui.Text.Text = "Summit: " .. summitValue.Value
end

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(character)
		local leaderstats = player:WaitForChild("leaderstats")
		local summitValue = leaderstats:WaitForChild("Summit")

		createSummitGui(character, summitValue)

		-- 🔥 INI YANG PALING AMAN
		character.DescendantAdded:Connect(function(obj)
			if obj.Name == "Head" then
				task.wait()
				createSummitGui(character, summitValue)
			end
		end)
	end)
end)
]]></ProtectedString>
