				<ProtectedString name="Source"><![CDATA[--!strict

--[[
	TryOn - This script handles the main Try On UI, creating buttons to represent each of
	the items the player is currently trying on.
--]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local remotes = ReplicatedStorage.Remotes
local tryOnSyncRemote = remotes.TryOnSync
local TryOnRemote = remotes.TryOn

local TryOn = require(ReplicatedStorage.Libraries.TryOn)
local ItemContainer = require(ReplicatedStorage.Utility.ItemContainer)

local TryOnButton = require(ReplicatedStorage.UI.Components.TryOnButton)

local player = Players.LocalPlayer :: Player
local playerGui = player.PlayerGui
local shoppingGui = playerGui:WaitForChild("ShoppingGui")
local tryOnFrame = shoppingGui:WaitForChild("TryOnFrame")

local tryOnButtons: { [string]: ImageButton } = {}



local function onItemAdded(item: ItemContainer.ContainedItem)
	-- kalau kategori sama, hancurkan yang lama
	if tryOnButtons[item.key] then
		tryOnButtons[item.key]:Destroy()
		tryOnButtons[item.key] = nil
	end

	local tryOnButton = TryOnButton(item.id, item.type)
	tryOnButton.Parent = tryOnFrame
	tryOnButtons[item.key] = tryOnButton
end


local function onItemRemoved(item: ItemContainer.ContainedItem)
	if tryOnButtons[item.key] then
		tryOnButtons[item.key]:Destroy()
		tryOnButtons[item.key] = nil
	end
end

local function rebuildUI()
	-- Hapus semua tombol lama
	
	for _, button in tryOnButtons do
		button:Destroy()
	end
	table.clear(tryOnButtons)

	-- Bangun ulang dari state TryOn SEKARANG
	for _, item in TryOn.getItems() do
		onItemAdded(item)
	end
	
end

local shopFrame = shoppingGui:WaitForChild("ShopFrame") -- sesuaikan nama kalau beda
local inspectFrame = shoppingGui:WaitForChild("InspectFrame") 

-- sync awal
tryOnFrame.Visible = shopFrame.Visible
tryOnFrame.Visible = inspectFrame.Visible

-- setiap ShopFrame berubah
shopFrame:GetPropertyChangedSignal("Visible"):Connect(function()
	tryOnFrame.Visible = shopFrame.Visible
end)

inspectFrame:GetPropertyChangedSignal("Visible"):Connect(function()
	tryOnFrame.Visible = inspectFrame.Visible
end)


local function initialize()
	-- listen perubahan TryOn SEKALI
	TryOn.itemAdded:Connect(onItemAdded)
	TryOn.itemRemoved:Connect(onItemRemoved)

	-- listen sync dari server
	tryOnSyncRemote.OnClientEvent:Connect(function(assets, bundles)
		local items = {}

		for _, id in assets do
			table.insert(items, {
				id = id,
				type = Enum.MarketplaceProductType.AvatarAsset,
			})
		end

		for _, id in bundles do
			table.insert(items, {
				id = id,
				type = Enum.MarketplaceProductType.AvatarBundle,
			})
		end

		TryOn.setItemsAsync(items)
		rebuildUI()
	end)
	
	task.defer(function()
		rebuildUI()
	end)

end



initialize()
]]></ProtectedString>
