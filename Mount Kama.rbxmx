		<Properties>
			<ProtectedString name="Source"><![CDATA[-- SERVICES
local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")

-- CONFIG
local VIP_GAMEPASS_ID = 1684320630

-- FUNCTION: cek kepemilikan VIP
local function checkVIP(player)
	local success, hasPass = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, VIP_GAMEPASS_ID)
	end)

	if success and hasPass then
		player:SetAttribute("VIP", true)
		print(player.Name .. " adalah VIP")
	else
		player:SetAttribute("VIP", false)
	end
end

-- PLAYER JOIN
Players.PlayerAdded:Connect(function(player)
	-- default (biar LocalScript nggak keburu baca nil)
	player:SetAttribute("VIP", false)

	checkVIP(player)
end)

-- PLAYER BUY VIP SAAT GAME JALAN
MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, passId, purchased)
	if passId ~= VIP_GAMEPASS_ID then return end
	if not purchased then return end

	player:SetAttribute("VIP", true)
	print(player.Name .. " baru beli VIP!")
end)
]]></ProtectedString>
