			<Properties>
				<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- TouchGui (Jump Button bawaan Roblox)
local touchGui = playerGui:WaitForChild("TouchGui")
local controlFrame = touchGui:WaitForChild("TouchControlFrame")
local jumpButton = controlFrame:WaitForChild("JumpButton")

-- UI Setting kamu
local settingsGui = playerGui:WaitForChild("ScreenGui")
local frame = settingsGui:WaitForChild("JumpButtonFrame")
local slider = frame:WaitForChild("SliderBar")
local knob = slider:WaitForChild("Knob")
local valueLabel = frame:WaitForChild("ValueLabel")

-- Pastikan knob aman
knob.AnchorPoint = Vector2.new(0.5, 0.5)
knob.Active = true
slider.Active = true

-- Range ukuran
local MIN = 0.10
local MAX = 0.30

local dragging = false

--------------------------------------------------
-- UIScale (dibuat sekali)
--------------------------------------------------
local uiScale = jumpButton:FindFirstChild("UIScale")
if not uiScale then
	uiScale = Instance.new("UIScale")
	uiScale.Parent = jumpButton
end

-- Base size JANGAN diubah
jumpButton.Size = UDim2.fromScale(0.09, 0.18)

--------------------------------------------------
-- HITUNG SCALE DARI POSISI X SLIDER
--------------------------------------------------
local function getScaleFromX(x)
	-- clamp X ke area slider
	x = math.clamp(
		x,
		slider.AbsolutePosition.X,
		slider.AbsolutePosition.X + slider.AbsoluteSize.X
	)

	local relative = (x - slider.AbsolutePosition.X) / slider.AbsoluteSize.X
	-- kiri kecil, kanan besar (natural)
	return MIN + (MAX - MIN) * relative
end

--------------------------------------------------
-- SET POSISI KNOB DENGAN KOMPENSASI LEBAR
--------------------------------------------------
local function setKnobFromScale(scale)
	local t = (scale - MIN) / (MAX - MIN) -- 0..1

	-- kompensasi lebar knob
	local knobHalf = (knob.AbsoluteSize.X / slider.AbsoluteSize.X) / 2
	t = math.clamp(t, knobHalf, 1 - knobHalf)

	knob.Position = UDim2.fromScale(t, 0.5)
end

--------------------------------------------------
-- APPLY KE JUMP BUTTON + UI
--------------------------------------------------
local function applyFromX(x)
	local scale = getScaleFromX(x)

	-- scale visual jump button
	uiScale.Scale = math.clamp(scale / 0.15, 0.8, 1.8)

	-- update knob
	setKnobFromScale(scale)

	-- label
	valueLabel.Text = string.format("%.2f", scale)
end

--------------------------------------------------
-- INPUT HANDLING
--------------------------------------------------
knob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.Touch then
		applyFromX(input.Position.X)
	end
end)

--------------------------------------------------
-- DEFAULT (TENGAH)
--------------------------------------------------
task.wait(0.5)

applyFromX(
	slider.AbsolutePosition.X + slider.AbsoluteSize.X * 0.5
)
]]></ProtectedString>
