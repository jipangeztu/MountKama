		<Item class="LocalScript" referent="RBX9BF06387E0384FE7A69DE17B27D9D675">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--[[
	MASTER CLIENT SCRIPT (LocalScript)
	Ditingkatkan: Menggunakan Server-Replicated Sync, Kompensasi Latensi, dan Global Listener (Fail-Safe)
]]

-- ============================================
-- 1. SERVICES & INITIALIZATION
-- ============================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer

-- Import shared module (Pastikan SyncModule ada di ReplicatedStorage.Modules)
local SyncModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("SyncModule", 10))

-- Fungsi utilitas untuk notifikasi
local function showNotification(title, text, duration)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = title,
			Text = text,
			Duration = duration or 3
		})
	end)
end

-- Ambil RemoteEvents dan Modules
repeat task.wait() until player.Character
task.wait(1)

local remoteFolder = ReplicatedStorage:WaitForChild("Remotes", 10)
local syncFolder = remoteFolder and remoteFolder:WaitForChild("Sync", 10)
local carryRemote = ReplicatedStorage:WaitForChild("CarryRemote", 10) -- Carry Remote

local syncRemote
local unsyncRemote
local globalSyncEvent = remoteFolder:WaitForChild("GlobalSyncEvent", 10) -- Remote Event Baru
local emotesFolder

if syncFolder then
	syncRemote = syncFolder:WaitForChild("SyncRemote", 10)
	unsyncRemote = syncFolder:WaitForChild("UnsyncRemote", 10)
end
emotesFolder = ReplicatedStorage:WaitForChild("Emotes", 10)

if not syncRemote or not unsyncRemote or not emotesFolder or not carryRemote or not syncFolder or not globalSyncEvent then
	warn("[MASTER CLIENT] ERROR: Missing required dependencies (Remotes/Modules/GlobalEvent). Features disabled.")
	showNotification("Initialization Error", "Game assets not ready. Some features disabled.", 5)
	return
end

SyncModule.debugPrint("MASTER CLIENT", "All dependencies loaded")

-- ============================================
-- 2. STATE MANAGEMENT & UTILITIES
-- ============================================
local currentSyncTarget = nil
local currentSyncTrack = nil 
local predictedAnimations = {}
local connections = {}

local function trackConnection(conn)
	table.insert(connections, conn)
	return conn
end

-- ============================================
-- 3. CLIENT-SIDE PREDICTION LOGIC
-- ============================================
local function predictLeaderAnimations(leaderPlayer)
	-- ... (Logika Prediksi tetap sama) ...
	local leaderAnimator = leaderPlayer.Character:FindFirstChild("Humanoid")
		and leaderPlayer.Character.Humanoid:FindFirstChild("Animator")
	local myAnimator = player.Character
		and player.Character:FindFirstChild("Humanoid")
		and player.Character.Humanoid:FindFirstChild("Animator")

	if not leaderAnimator or not myAnimator then return end

	for _, track in pairs(predictedAnimations) do
		if track and track.IsPlaying then track:Stop(0) end
	end
	predictedAnimations = {}

	for _, leaderTrack in ipairs(leaderAnimator:GetPlayingAnimationTracks()) do
		if SyncModule.isEmoteAnimation(leaderTrack.Animation, emotesFolder) then
			local success, track = pcall(function()
				local newTrack = myAnimator:LoadAnimation(leaderTrack.Animation)
				newTrack:Play(0, 1, 1)
				newTrack.TimePosition = leaderTrack.TimePosition
				newTrack:AdjustSpeed(leaderTrack.Speed)
				if leaderTrack.WeightCurrent and leaderTrack.WeightCurrent > 0 then
					newTrack:AdjustWeight(leaderTrack.WeightCurrent)
				end
				return newTrack
			end)

			if success and track then
				table.insert(predictedAnimations, track)
			end
		end
	end
end

local function clearPredictedAnimations(waitForServer)
	-- Hentikan track yang disinkronkan oleh Server
	if currentSyncTrack and currentSyncTrack.IsPlaying then
		currentSyncTrack:Stop(0)
	end
	if currentSyncTrack then currentSyncTrack:Destroy() end
	currentSyncTrack = nil

	-- Hentikan animasi prediksi Klien
	for _, track in pairs(predictedAnimations) do
		if track then
			if track.IsPlaying then track:Stop(0) end
			task.spawn(function() task.wait(0.1) if track then track:Destroy() end end)
		end
	end
	predictedAnimations = {}
end

-- ============================================
-- 4. FEATURE LOGIC: SYNC & UNSYNC
-- ============================================
local function sync(targetPlayer)
	if not targetPlayer or targetPlayer == player then
		showNotification("Sync Error", "Target tidak valid.", 3)
		return
	end

	currentSyncTarget = targetPlayer
	predictLeaderAnimations(targetPlayer) 
	syncRemote:FireServer(targetPlayer)

	showNotification("Syncing...", "Mencoba Sync Dance dengan " .. targetPlayer.DisplayName, 2)
end

local function unsync()
	currentSyncTarget = nil
	clearPredictedAnimations(false)

	if unsyncRemote then
		unsyncRemote:FireServer()
	end

	showNotification("Unsynced", "Sinkronisasi Dance telah dihentikan.", 2)
end

-- ... (Carry & Stop Carry Logic sama) ...
-- ============================================
-- CARRY (CLIENT SIDE - DIFFICULTY CHECK)
-- ============================================

local function carry(targetPlayer)
	if not targetPlayer or not targetPlayer:IsA("Player") then
		warn("[Carry] TargetPlayer tidak valid.")
		return
	end

	local myDifficulty = player:GetAttribute("Difficulty")
	local targetDifficulty = targetPlayer:GetAttribute("Difficulty")

	-- Salah satu belum pilih difficulty
	if not myDifficulty or not targetDifficulty then
		showNotification(
			"Carry Ditolak",
			"Salah satu pemain belum memilih difficulty.",
			3
		)
		return
	end

	-- Difficulty beda
	if myDifficulty ~= targetDifficulty then
		showNotification(
			"Carry Ditolak",
			"Difficulty harus sama.\n(" ..
				myDifficulty .. " ≠ " .. targetDifficulty .. ")",
			4
		)
		return
	end

	-- LULUS → kirim ke server
	carryRemote:FireServer("Request", {
		targetId = targetPlayer.UserId
	})

	showNotification(
		"Permintaan Carry",
		"Mengirim permintaan ke " .. targetPlayer.DisplayName,
		3
	)
end


local function stopCarry()
	carryRemote:FireServer("Stop")
	showNotification("Carry Dihentikan", "Anda telah menghentikan aksi carrying.", 2)
end


-- ============================================
-- 6. REMOTE EVENT HANDLERS (PERBAIKAN REPLIKASI)
-- ============================================
trackConnection(syncRemote.OnClientEvent:Connect(function(data)
	if not data or type(data) ~= "table" then return end

	if data.cmd == "InitialSync" then
		-- 1. Hentikan prediksi lokal
		clearPredictedAnimations(false) 

		if data.animationId and player.Character then
			local myAnimator = player.Character:FindFirstChild("Humanoid")
				and player.Character.Humanoid:FindFirstChild("Animator")

			if myAnimator then
				-- 2. Beri waktu Server mereplikasi animasi ke klien ini
				task.wait(0.1) 

				local foundTrack = nil

				-- Cari AnimationTrack yang sudah dimuat oleh Server (melalui replikasi)
				for _, track in ipairs(myAnimator:GetPlayingAnimationTracks()) do
					if track.Animation and track.Animation.AnimationId == data.animationId then
						foundTrack = track
						break
					end
				end

				if foundTrack then
					-- 3. Terapkan Kompensasi Latensi (untuk klien Pengikut ini saja)
					foundTrack.TimePosition = data.timePosition or 0
					currentSyncTrack = foundTrack
				end
			end
		end

		showNotification(
			"✓ Sync Success",
			"Synced with " .. (currentSyncTarget and currentSyncTarget.Name or "player"),
			3
		)

	elseif data.cmd == "SyncFailed" then
		clearPredictedAnimations(false)
		currentSyncTarget = nil
		showNotification(
			"✗ Sync Failed",
			data.reason or "Unable to sync",
			4
		)
	end
end))

trackConnection(unsyncRemote.OnClientEvent:Connect(function(data)
	if not data or type(data) ~= "table" then return end

	if data.cmd == "UnsyncCompleted" or data.cmd == "LeaderStopped" then
		currentSyncTarget = nil
		clearPredictedAnimations(false)

	elseif data.cmd == "LeaderLeft" then
		if currentSyncTarget and data.leaderUserId and
			currentSyncTarget.UserId == data.leaderUserId then
			currentSyncTarget = nil
			clearPredictedAnimations(false)
			showNotification("Sync Ended", "Leader left the game", 3)
		end
	end
end))


-- ============================================
-- 7. GLOBAL SYNC LISTENER (FAIL-SAFE untuk Pihak Ketiga)
-- ============================================
trackConnection(globalSyncEvent.OnClientEvent:Connect(function(data)
	if data.type == "StartSync" then
		local targetPlayer = Players:GetPlayerByUserId(data.followerId)

		if targetPlayer and targetPlayer.Character then
			-- Klien pihak ketiga memuat dan mengoreksi TimePosition
			local targetAnimator = targetPlayer.Character.Humanoid.Animator
			if targetAnimator then
				local foundTrack = nil

				-- Cari animasi yang direplikasi Server
				task.wait(0.05) -- Beri sedikit waktu untuk replikasi standar

				for _, track in ipairs(targetAnimator:GetPlayingAnimationTracks()) do
					if track.Animation and track.Animation.AnimationId == data.animationId then
						foundTrack = track
						break
					end
				end

				if foundTrack then
					-- Koreksi posisi untuk semua Klien (meningkatkan sinkronisasi visual global)
					foundTrack.TimePosition = data.timePosition
				end
			end
		end
	end
end))


-- ============================================
-- 8. AVATAR CONTEXT MENU SETUP & THEME
-- ============================================
-- ... (Logika setup Context Menu sama) ...
local function waitForCoreScript()
	local success = false
	local attempts = 0
	local maxAttempts = 30
	repeat attempts += 1 success = pcall(function() StarterGui:SetCore("AvatarContextMenuEnabled", true) end)
		if not success then task.wait(1) end
	until success or attempts >= maxAttempts
	return success
end

if not waitForCoreScript() then warn("[MASTER CLIENT] Avatar Context Menu CoreScript gagal dimuat.") return end

StarterGui:SetCore("RemoveAvatarContextMenuOption", Enum.AvatarContextMenuOption.Emote)
StarterGui:SetCore("RemoveAvatarContextMenuOption", Enum.AvatarContextMenuOption.Chat)
StarterGui:SetCore("AvatarContextMenuTheme", {
	BackgroundImage = "", BackgroundTransparency = 0.3, BackgroundColor = Color3.fromRGB(40, 37, 37),
	NameTagColor = Color3.fromRGB(40, 37, 37), NameUnderlineColor = Color3.fromRGB(40, 37, 37),
	ButtonFrameColor = Color3.fromRGB(40, 37, 37), ButtonFrameTransparency = 0.3,
	ButtonUnderlineColor = Color3.fromRGB(40, 37, 37), Font = Enum.Font.Jura
})

local syncBind = Instance.new("BindableEvent")
local unsyncBind = Instance.new("BindableEvent")
local carryBind = Instance.new("BindableEvent")
local stopCarryBind = Instance.new("BindableEvent")

trackConnection(syncBind.Event:Connect(sync))
trackConnection(unsyncBind.Event:Connect(unsync))
trackConnection(carryBind.Event:Connect(carry))
trackConnection(stopCarryBind.Event:Connect(stopCarry))

pcall(function()
	StarterGui:SetCore("AddAvatarContextMenuOption", {"**Carry**", carryBind})
	StarterGui:SetCore("AddAvatarContextMenuOption", {"Stop Carry", stopCarryBind})
	StarterGui:SetCore("AddAvatarContextMenuOption", {"Sync", syncBind})
	StarterGui:SetCore("AddAvatarContextMenuOption", {"Unsync", unsyncBind})
end)

-- ============================================
-- 9. CLEANUP
-- ============================================

player.CharacterAdded:Connect(function()
	currentSyncTarget = nil
	clearPredictedAnimations(false)
	task.wait(1)
end)

Players.PlayerRemoving:Connect(function(leavingPlayer)
	if leavingPlayer == player then
		for i, conn in ipairs(connections) do
			if conn and conn.Connected then conn:Disconnect() end
			connections[i] = nil
		end
		clearPredictedAnimations(false)
		if syncBind then syncBind:Destroy() end
		if unsyncBind then unsyncBind:Destroy() end
		if carryBind then carryBind:Destroy() end
		if stopCarryBind then stopCarryBind:Destroy() end
	end
end)

SyncModule.notify("✓ MASTER CLIENT INITIALIZED")
--showNotification("System Ready", "Right-click players to access Carry and Sync options.", 5)]]></ProtectedString>
