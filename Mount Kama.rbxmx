			<Item class="LocalScript" referent="RBXCF63D03A7C17456B8258C26DE13C6DDE">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local mButton = script.Parent
local on = false

local frame = script.Parent.Parent:WaitForChild("Frame")
local warnaOn  = Color3.fromRGB(85, 255, 255)
local warnaOff = mButton.BackgroundColor3

local soundOn  = mButton:WaitForChild("SoundOn")
local soundOff = mButton:WaitForChild("SoundOff")
local xButton = script.Parent.Parent:WaitForChild("xButton")

frame.Visible = false
xButton.Visible = false




mButton.MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
	
	frame.Visible = on 
	xButton.Visible = on

	if on then
		soundOn:Play()
	else
		soundOff:Play()
	end
end)

xButton.MouseButton1Click:Connect(function()
	on = not on
	frame.Visible = on 
	xButton.Visible = on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff

	soundOff:Play()
end)
]]></ProtectedString>
