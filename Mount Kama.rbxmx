	<Item class="Script" referent="RBX772D9B873F5F480E85837F277A32DF88">
		<Properties>
			<ProtectedString name="Source"><![CDATA[-- SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- EVENTS
local PingEvent = ReplicatedStorage:WaitForChild("PingUpdate")
local PlatformEvent = ReplicatedStorage:WaitForChild("PlatformUpdate")

-- DATA
local playerPlatform = {}

-- PLATFORM SAVE
PlatformEvent.OnServerEvent:Connect(function(player, platform)
	playerPlatform[player] = platform
end)

Players.PlayerRemoving:Connect(function(player)
	playerPlatform[player] = nil
end)

-- GUI CREATOR
local function setupGui(character, player)
	local head = character:FindFirstChild("Head")
	if not head then return end
	if head:FindFirstChild("PingGui") then return end

	local gui = Instance.new("BillboardGui")
	gui.Name = "PingGui"
	gui.Adornee = head
	gui.Parent = head
	gui.Size = UDim2.new(3,0,1,0)
	gui.StudsOffset = Vector3.new(0,2,0)
	gui.AlwaysOnTop = true

	local label = Instance.new("TextLabel")
	label.Name = "PingLabel"
	label.Parent = gui
	label.BackgroundTransparency = 1
	label.Size = UDim2.new(1,0,1,0)
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.TextStrokeTransparency = 0
	label.TextColor3 = Color3.fromRGB(180,180,180)
	label.Text = "Loading..."
end

-- PLAYER
Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid")
		humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None

		setupGui(character, player)

		-- ini kunci anti ilang pas ganti avatar
		humanoid.HumanoidDescriptionApplied:Connect(function()
			task.wait(0.2)
			setupGui(character, player)
		end)
	end)
end)

-- PING UPDATE
PingEvent.OnServerEvent:Connect(function(player, ping)
	local char = player.Character
	if not char then return end

	local head = char:FindFirstChild("Head")
	if not head then return end

	local gui = head:FindFirstChild("PingGui")
	if not gui then
		setupGui(char, player)
		return
	end

	local label = gui:FindFirstChild("PingLabel")
	if not label then return end

	local icon = playerPlatform[player] or "❓"
	label.Text = icon .. " | " .. player.DisplayName .. " | " .. ping .. " ms"

	if ping < 100 then
		label.TextColor3 = Color3.fromRGB(0,255,0)
	elseif ping < 200 then
		label.TextColor3 = Color3.fromRGB(255,221,0)
	else
		label.TextColor3 = Color3.fromRGB(255,0,0)
	end
end)
]]></ProtectedString>
