	<Item class="Script" referent="RBX9A10A57C597648E5BD271A033D30BB78">
		<Properties>
			<ProtectedString name="Source"><![CDATA[-- ChangeAva (ServerScriptService)

local RS = game:GetService("ReplicatedStorage")
local changeEvent = RS:WaitForChild("ChangeAvatar")
local camEvent = RS:WaitForChild("CameraRebind")

local function ApplyAvatar(player, avatarName)
	local avatarFolder = RS:WaitForChild("Avatars")
  	local template = avatarFolder:FindFirstChild(avatarName)

	if not template then return end

	local oldChar = player.Character
	if not oldChar then return end

	local oldHRP = oldChar:FindFirstChild("HumanoidRootPart")
	if not oldHRP then return end
	local lastCFrame = oldHRP.CFrame

	-- clone avatar baru
	local newChar = template:Clone()
	newChar.Name = player.Name

	-- 🚫 FLAG SEBELUM MASUK WORKSPACE
	newChar:SetAttribute("IgnoreCheckpointTeleport", true)
	newChar.Parent = workspace

	local hrp = newChar:WaitForChild("HumanoidRootPart")
	newChar.PrimaryPart = hrp
	hrp.CFrame = lastCFrame
	hrp.Anchored = false

	local hum = newChar:WaitForChild("Humanoid")
	hum.WalkSpeed = 16
	hum.JumpPower = 50

	if not hum:FindFirstChild("Animator") then
		Instance.new("Animator", hum)
	end

	-- 🔑 SET CHARACTER DULU
	player.Character = newChar

	-- 🎥 BARU REBIND CAMERA
	camEvent:FireClient(player)

	-- reset flag
	task.delay(0.6, function()
		if newChar then
			newChar:SetAttribute("IgnoreCheckpointTeleport", false)
		end
	end)

	-- hapus lama
	task.delay(0.2, function()
		if oldChar then
			oldChar:Destroy()
		end
	end)
end

changeEvent.OnServerEvent:Connect(function(player, avatarName)
	ApplyAvatar(player, avatarName)
end)
]]></ProtectedString>
