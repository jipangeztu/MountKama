			<ProtectedString name="Source"><![CDATA[--!strict

--[[
	TryOn - Server
	Menyimpan & memuat TryOn player menggunakan DataStore
]]--

-- SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")
local DataStoreService = game:GetService("DataStoreService")

-- DATASTORE
local TryOnStore = DataStoreService:GetDataStore("TryOn_v1")


-- MODULES
local Settings = require(ReplicatedStorage.Settings)
local applyItemsToDescriptionAsync =
	require(ReplicatedStorage.Utility.applyItemsToDescriptionAsync)

local validateSimpleTable =
	require(ServerScriptService.Utility.TypeValidation.validateSimpleTable)
local validateNumber =
	require(ServerScriptService.Utility.TypeValidation.validateNumber)

-- REMOTES
local remotes = ReplicatedStorage.Remotes
local tryOnRemote = remotes.TryOn
local tryOnSyncRemote = remotes.TryOnSync


-- STATE (SESSION ONLY)
local latestTryOn: {
	[Player]: {
		assets: { number },
		bundles: { number },
	}
} = {}

--------------------------------------------------
-- APPLY TRY ON
--------------------------------------------------
local function tryOnItems(player: Player, assets: { number }, bundles: { number })
	if not player.Character then
		return
	end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	local description =
		Players:GetHumanoidDescriptionFromUserIdAsync(player.CharacterAppearanceId)

	applyItemsToDescriptionAsync(description, assets, bundles, true)
	humanoid:ApplyDescriptionAsync(description, Enum.AssetTypeVerification.Always)
end

--------------------------------------------------
-- CHARACTER ADDED
--------------------------------------------------
local function onCharacterAddedAsync(character: Model)
	local player = Players:GetPlayerFromCharacter(character)
	if not player then
		return
	end

	if not player:HasAppearanceLoaded() then
		player.CharacterAppearanceLoaded:Wait()
	end

	local data = latestTryOn[player]
	if not data then
		return
	end

	tryOnItems(player, data.assets, data.bundles)
end

--------------------------------------------------
-- PLAYER ADDED (LOAD DATA)
--------------------------------------------------
local function onPlayerAdded(player: Player)
	-- LOAD FROM DATASTORE
	local storedData
	pcall(function()
		storedData = TryOnStore:GetAsync(tostring(player.UserId))
	end)

	if type(storedData) == "table" then
		latestTryOn[player] = {
			assets = storedData.assets or {},
			bundles = storedData.bundles or {},
		}
	end

	player.CharacterAdded:Connect(onCharacterAddedAsync)

	if player.Character then
		task.spawn(onCharacterAddedAsync, player.Character)
	end
	
	if type(storedData) == "table" then
		latestTryOn[player] = {
			assets = storedData.assets or {},
			bundles = storedData.bundles or {},
		}

		-- 🔥 SYNC UI KE CLIENT
		tryOnSyncRemote:FireClient(
			player,
			latestTryOn[player].assets,
			latestTryOn[player].bundles
		)
	end

end

--------------------------------------------------
-- PLAYER REMOVING (SAVE DATA)
--------------------------------------------------
local function onPlayerRemoving(player: Player)
	local data = latestTryOn[player]
	if not data then
		return
	end

	pcall(function()
		TryOnStore:UpdateAsync(tostring(player.UserId), function()
			return {
				assets = table.clone(data.assets),
				bundles = table.clone(data.bundles),
			}
		end)
	end)

	latestTryOn[player] = nil
end

--------------------------------------------------
-- TRY ON REMOTE
--------------------------------------------------
local function onTryOnEvent(player: Player, assets: { number }, bundles: { number })
	if not validateSimpleTable(assets, "number", validateNumber) then
		return
	end

	if not validateSimpleTable(bundles, "number", validateNumber) then
		return
	end

	if #assets + #bundles > Settings.MAX_TRY_ON_ITEMS then
		return
	end

	latestTryOn[player] = {
		assets = table.clone(assets),
		bundles = table.clone(bundles),
	}

	tryOnItems(player, assets, bundles)
end

--------------------------------------------------
-- INIT
--------------------------------------------------
local function initialize()
	Players.PlayerAdded:Connect(onPlayerAdded)
	Players.PlayerRemoving:Connect(onPlayerRemoving)
	tryOnRemote.OnServerEvent:Connect(onTryOnEvent)
	
end

initialize()
]]></ProtectedString>
