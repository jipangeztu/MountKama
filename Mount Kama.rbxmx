					<ProtectedString name="Source"><![CDATA[--!strict

--[[
	TryOnButton - UI button untuk item yang sedang di Try On.
	Muncul hanya jika item ada di TryOn state.
]]--

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local tryOnSyncRemote 

local Cart = require(ReplicatedStorage.Libraries.Cart)
local TryOn = require(ReplicatedStorage.Libraries.TryOn)
local ItemContainer = require(ReplicatedStorage.Utility.ItemContainer)
local getItemIcon = require(ReplicatedStorage.Utility.getItemIcon)
local ActionsMenu = require(ReplicatedStorage.UI.Components.ActionsMenu)

local player = Players.LocalPlayer
local playerGui = player.PlayerGui
local remotes = ReplicatedStorage.Remotes
local purchaseRemote = remotes.Purchase
local tryOnSyncRemote = remotes.TryOnSync

local tryOnButtonTemplate = ReplicatedStorage.UI.Objects.TryOnButton

--------------------------------------------------
-- COMPONENT
--------------------------------------------------
local function TryOnButton(
	
	itemId: number,
	itemType: Enum.MarketplaceProductType
): ImageButton
	
	local icon = getItemIcon(itemId, itemType)

	local tryOnButton = tryOnButtonTemplate:Clone()
	tryOnButton.Image = icon
	
	--------------------------------------------------
	-- ACTIONS MENU
	--------------------------------------------------
	local function onActivated()
		local actions = {
			{
				name = "Take off",
				callback = function()
					TryOn.removeItem(itemId, itemType)
				end,
			},
			{
				name = "Buy",
				callback = function()
					purchaseRemote:FireServer(itemId, itemType)
				end,
			},
		}

		if not Cart.getItem(itemId, itemType) then
			table.insert(actions, {
				name = "Add to cart",
				callback = function()
					Cart.addItemAsync(itemId, itemType)
				end,
			})
		end

		local menu = ActionsMenu(tryOnButton, actions)
		menu.Parent = playerGui
	end

	--------------------------------------------------
	-- SYNC DENGAN TRYON
	--------------------------------------------------
	local function onItemRemoved(item: ItemContainer.ContainedItem)
		
		if item.id == itemId and item.type == itemType then
			tryOnButton:Destroy()
		end
	end

	tryOnButton.Activated:Connect(onActivated)
	local removedConn = TryOn.itemRemoved:Connect(onItemRemoved)

	tryOnButton.Destroying:Once(function()
		tryOnSyncRemote:FireServer(itemId, itemType)
		removedConn:Disconnect()
	end)

	return tryOnButton
end

return TryOnButton
]]></ProtectedString>
