				<Item class="LocalScript" referent="RBXDD84904A49D142849955027D6AC97FB8">
					<Properties>
						<ProtectedString name="Source"><![CDATA[-- SERVICES
local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")

-- PLAYER
local player = Players.LocalPlayer
local button = script.Parent -- ImageButton

-- CONFIG
local VIP_GAMEPASS_ID = 1684320630

-- IMAGE CONFIG
local IMAGE_BUY = "rbxassetid://77154229372955"   -- ganti image BUY VIP
local IMAGE_OWNED = "rbxassetid://77154229372955" -- ganti image VIP OWNED

-- UPDATE BUTTON STATE
local function updateButton()
	local isVIP = player:GetAttribute("VIP") == true

	if isVIP then
		button.Image = IMAGE_OWNED
		button.AutoButtonColor = false
		button.ImageTransparency = 0.3
	else
		button.Image = IMAGE_BUY
		button.AutoButtonColor = true
		button.ImageTransparency = 0
	end
end

-- INITIAL LOAD
updateButton()

-- LISTEN ATTRIBUTE CHANGE
player:GetAttributeChangedSignal("VIP"):Connect(updateButton)

-- BUTTON CLICK
button.MouseButton1Click:Connect(function()
	if player:GetAttribute("VIP") then
		return -- sudah VIP
	end

	MarketplaceService:PromptGamePassPurchase(player, VIP_GAMEPASS_ID)
end)
]]></ProtectedString>
