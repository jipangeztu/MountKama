				<Item class="LocalScript" referent="RBX16A6B1C3E60145C79DAB637C917ABF1E">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local button = script.Parent
local parentFrame = button.Parent

local teleportEvent = RS:WaitForChild("ResetPlayerEvent")
local statusEvent = RS:WaitForChild("DifficultyStatus")

local kesulitanGui = playerGui:WaitForChild("KesulitanGui")

-- default mati
kesulitanGui.Enabled = false

button.MouseButton1Click:Connect(function()
	-- kirim reset ke server
	teleportEvent:FireServer("ResetCP")

	-- tutup UI lama
	parentFrame.Visible = false
end)

-- TUNGGU SERVER SIAP
statusEvent.OnClientEvent:Connect(function(hasData, difficulty)
	-- kalau server bilang belum ada difficulty
	-- artinya siap untuk pilih ulang
	--[[task.delay(1.5, function()
		kesulitanGui.Enabled = true
	end)]]
	
	if not hasData then
	task.delay(1.5, function()
		kesulitanGui.Enabled = true
	end)
		
	end
end)
]]></ProtectedString>
						<bool name="Disabled">false</bool>
