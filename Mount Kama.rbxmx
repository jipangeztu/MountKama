			<Item class="LocalScript" referent="RBX7958A558BACB4B5F8FFC77EAD2B2B456">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local frame = script.Parent
local sf = frame:WaitForChild("ScrollingFrame")
local xb = frame:WaitForChild("xB")

local guiService = game:GetService("GuiService")
local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local guiNotif = playerGui:FindFirstChild("PemberitahuanGui")
guiNotif.Enabled = true

task.wait(4)
frame.Visible = true


xb.mouseButton1Click:Connect(function()
	guiNotif:Destroy()
end)]]></ProtectedString>
