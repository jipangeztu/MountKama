	<Item class="Script" referent="RBXA55D63491EF046DEAFEE421DB03CA950">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")

local originalDescriptions = {}

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid")
		originalDescriptions[player] = humanoid:GetAppliedDescription()
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	originalDescriptions[player] = nil
end)

-- RemoteEvent: ResetTryOn
game.ReplicatedStorage.Remotes.ResetTryOn.OnServerEvent:Connect(function(player)
	local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	local originalDesc = originalDescriptions[player]
	if originalDesc then
		humanoid:ApplyDescription(originalDesc)
	end
end)
]]></ProtectedString>
