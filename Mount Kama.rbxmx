			<Item class="LocalScript" referent="RBX945C4858924F48AE8D10358CFB7E9226">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:FindFirstChild("PlayerGui")

local touchGui = playerGui:FindFirstChild("TouchGui")

local frame = script.Parent
local TweenService = game:GetService("TweenService")
local on = false

local isOpen = false
local rotated = false
local button = script.Parent.Parent :WaitForChild("AvatarMenu")
local warnaOn  = Color3.fromRGB(40, 255, 29)
local warnaOff = button.BackgroundColor3

local sound = script.Parent.Parent:WaitForChild("AvatarMenu"):WaitForChild("SoundOff")



frame.Visible = false

local tweenInfo = TweenInfo.new(
	0.25,
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)
function toggleFrame()
	isOpen = not isOpen
	rotated = not rotated

	-- rotasi tombol (tetap ada)
	TweenService:Create(button, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()

	on = not on
	button.BackgroundColor3 = on and warnaOn or warnaOff

	-- frame tanpa efek transparansi
	frame.Visible = isOpen
	if touchGui then 
		touchGui.Enabled = not touchGui.Enabled
	end
end

button.MouseButton1Click:Connect(function()

	toggleFrame()
end)
frame.Exit.MouseButton1Click:Connect(function()
	
	
	sound:Play()
	toggleFrame()
end)]]></ProtectedString>
