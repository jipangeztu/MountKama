	player.CharacterAdded:Connect(function(char)

		if player:GetAttribute("IgnoreCheckpointTeleport") then
			player:SetAttribute("IgnoreCheckpointTeleport", false)
			return
		end

		local cf = player:GetAttribute("CheckpointCFrame")
		if cf then
			local hrp = char:WaitForChild("HumanoidRootPart")
			local hum = char:WaitForChild("Humanoid")

			hum:ChangeState(Enum.HumanoidStateType.Physics)
			task.wait(0.1)
