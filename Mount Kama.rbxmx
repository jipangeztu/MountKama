	<Item class="Script" referent="RBXDF0434C94A8F455BA7313D103E168A7C">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local allowedUsers = {
	[8981440268] = true,  -- Jipang (OWNER)
	[8815015003] = true,  -- Dillah
	[10327418957] = true,  -- juri
	[9131575266] = true,  -- ridho
	[947749461]	= true, --isan
	[2573681427] =true, --aeri
	[4284014929]  = true, -- livy
	[590583166]  = true, -- udin
	[10404516311] = true, -- msa
	
}

local OWNER_ID = 8981440268

local Players = game:GetService("Players")
local ServerStorage = game:GetService("ServerStorage")

local toolsFolder = ServerStorage:WaitForChild("AdminToolsGear")
local adminGuiTemplate = ServerStorage:WaitForChild("AdminGui")
local ownerGuiTemplate = ServerStorage:WaitForChild("OwnerGui") -- GUI khusus owner
local TweenService = game:GetService("TweenService")

--------------------------------------------------
-- TAG
--------------------------------------------------

local function applySmoothGradient(textLabel, isOwner)
	local gradient = Instance.new("UIGradient")
	gradient.Parent = textLabel

	gradient.Rotation = 0
	gradient.Offset = Vector2.new(-0.12, 0)

	if isOwner then
		gradient.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(170, 0, 255)),
			ColorSequenceKeypoint.new(0.25, Color3.fromRGB(121, 43, 255)),
			ColorSequenceKeypoint.new(0.5, Color3.fromRGB(73, 213, 255)),
			ColorSequenceKeypoint.new(0.75, Color3.fromRGB(121, 43, 255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(170, 0, 255)),
		})
	else
		gradient.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(253, 255, 116)),
			ColorSequenceKeypoint.new(0.25, Color3.fromRGB(255, 184, 134)),
			ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 172, 29)),
			ColorSequenceKeypoint.new(0.75, Color3.fromRGB(255, 129, 26)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(253, 255, 116)),
		})
	end

	local tweenInfo = TweenInfo.new(
		0.1, -- durasi
		Enum.EasingStyle.Sine,
		Enum.EasingDirection.InOut
	)

	local tweenRight = TweenService:Create(
		gradient,
		tweenInfo,
		{ Offset = Vector2.new(1, 0) }
	)

	local tweenLeft = TweenService:Create(
		gradient,
		tweenInfo,
		{ Offset = Vector2.new(-1, 0) }
	)

	local function playLoop()
		local tween = TweenService:Create(
			gradient,
			TweenInfo.new(2.5, Enum.EasingStyle.Linear),
			{ Offset = Vector2.new(0.8, 0) }
		)

		tween.Completed:Connect(function()
			gradient.Offset = Vector2.new(-0.77, 0)
			playLoop()
		end)

		tween:Play()
	end

	playLoop()

	-- ping-pong loop
	--[[tweenRight.Completed:Connect(function()
		tweenLeft:Play()
	end)

	tweenLeft.Completed:Connect(function()
		tweenRight:Play()
	end)

	tweenRight:Play()]]
end



local function addTag(character, isOwner)
	local head = character:FindFirstChild("Head")
	if not head then return end

	local gui = character:FindFirstChild("AdminTag")
	if not gui then
		gui = Instance.new("BillboardGui")
		gui.Name = "AdminTag"
		gui.Size = UDim2.new(3, 0, 1, 0)
		gui.StudsOffset = Vector3.new(0, 3.5, 0)
		gui.AlwaysOnTop = true
		gui.ResetOnSpawn = false
		gui.Parent = character

		local label = Instance.new("TextLabel")
		label.Name = "Label"
		label.Parent = gui
		label.BackgroundTransparency = 1
		label.Size = UDim2.new(1, 0, 1, 0)
		label.TextScaled = true
		label.Font = Enum.Font.BuilderSansBold
		label.TextStrokeTransparency = 0
		label.TextColor3 = Color3.fromRGB(255,255,255)
		label.Text = isOwner and "[OWNER]" or "[ADMIN]"

		applySmoothGradient(label, isOwner)
	end

	gui.Adornee = head
end


--------------------------------------------------
-- GUI
--------------------------------------------------
local function giveGui(player, isOwner)
	local playerGui = player:WaitForChild("PlayerGui")

	if isOwner then
		if not playerGui:FindFirstChild(ownerGuiTemplate.Name) then
			local gui = ownerGuiTemplate:Clone()
			gui.ResetOnSpawn = false
			gui.Parent = playerGui
		end
	else
		if not playerGui:FindFirstChild(adminGuiTemplate.Name) then
			local gui = adminGuiTemplate:Clone()
			gui.ResetOnSpawn = false
			gui.Parent = playerGui
		end
	end
end

--------------------------------------------------
-- PLAYER ADDED
--------------------------------------------------
Players.PlayerAdded:Connect(function(player)
	if not allowedUsers[player.UserId] then return end

	local isOwner = player.UserId == OWNER_ID

	-- tools
	for _, tool in ipairs(toolsFolder:GetChildren()) do
		if tool:IsA("Tool") then
			tool:Clone().Parent = player.Backpack
			tool:Clone().Parent = player.StarterGear
		end
	end
	player.CharacterAdded:Connect(function(character)
		addTag(character, isOwner)
		giveGui(player, isOwner)

		-- 🔥 INI KUNCI UTAMA
		character.DescendantAdded:Connect(function(obj)
			if obj.Name == "Head" then
				task.wait()
				addTag(character, isOwner)
			end
		end)
	end)

end)
]]></ProtectedString>
