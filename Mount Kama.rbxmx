	<Item class="ModuleScript" referent="RBX7A93D8EEF37A40CCADB59669F58B2337">
		<Properties>
			<Content name="LinkedSource"><null></null></Content>
			<ProtectedString name="Source"><![CDATA[--!strict
local DataStoreService = game:GetService("DataStoreService")
local store = DataStoreService:GetDataStore("PlayerFrames")

local FrameDataStore = {}

-- Save semua frame anak ke DataStore
function FrameDataStore:Save(player: Player, frames: {any})
	local success, err = pcall(function()
		-- Serialize frames jadi table sederhana
		local dataToSave = {}
		for _, f in ipairs(frames) do
			table.insert(dataToSave, {
				Template = f.Template, -- nama template frame
				Position = {f.Position.X.Scale, f.Position.X.Offset, f.Position.Y.Scale, f.Position.Y.Offset},
				Text = f.Text or "" -- contoh property, bisa ditambah sesuai kebutuhan
			})
		end
		store:SetAsync(player.UserId, dataToSave)
	end)
	if not success then
		warn("Gagal save frames: "..err)
	end
end

-- Load semua frame anak dari DataStore
function FrameDataStore:Load(player: Player)
	local success, data = pcall(function()
		return store:GetAsync(player.UserId)
	end)
	local frames: {any} = {}
	if success and data then
		for _, f in ipairs(data) do
			table.insert(frames, {
				Template = f.Template,
				Position = {f.Position[1], f.Position[2], f.Position[3], f.Position[4]},
				Text = f.Text
			})
		end
	end
	return frames
end

return FrameDataStore
]]></ProtectedString>
