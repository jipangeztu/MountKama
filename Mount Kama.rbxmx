			<Item class="LocalScript" referent="RBX39064CBEC5294D13913416C75BF2C541">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--================================
-- HYBRID SHIFT LOCK (GUI + SHIFT)
--================================

local button = script.Parent

-- SERVICES
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- STATE
local shiftLockOn = false
local rotateConnection


--------------------------------------------------
-- CHARACTER ROTATION (FOLLOW CAMERA)
--------------------------------------------------
local function startCharacterRotate()
	if rotateConnection then return end

	rotateConnection = RunService.RenderStepped:Connect(function()
		if not shiftLockOn then return end

		local char = player.Character
		if not char then return end

		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end

		local cam = workspace.CurrentCamera
		local look = cam.CFrame.LookVector

		local flatLook = Vector3.new(look.X, 0, look.Z)
		if flatLook.Magnitude > 0 then
			local target = CFrame.new(hrp.Position, hrp.Position + flatLook)

			-- SMOOTH ROTATION (mirip shift lock asli)
			hrp.CFrame = hrp.CFrame:Lerp(target, 0.15)
		end
	end)
end

local function stopCharacterRotate()
	if rotateConnection then
		rotateConnection:Disconnect()
		rotateConnection = nil
	end
end

--------------------------------------------------
-- UPDATE UI
--------------------------------------------------
local function updateButton()
	if shiftLockOn then
		button.Text = "SHIFT LOCK ON"
		button.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
	else
		button.Text = "SHIFT LOCK OFF"
		button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
	end
end

--------------------------------------------------
-- APPLY SHIFT LOCK
--------------------------------------------------
local function applyShiftLock()
	local char = player.Character
	if not char then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	if shiftLockOn then
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
		hum.CameraOffset = Vector3.new(0, 0, 0)
		hum.AutoRotate = false
		startCharacterRotate()
	else
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		hum.CameraOffset = Vector3.zero
		hum.AutoRotate = true
		stopCharacterRotate()
	end
end

--------------------------------------------------
-- TOGGLE
--------------------------------------------------
local function toggleShiftLock()
	shiftLockOn = not shiftLockOn
	applyShiftLock()
	updateButton()
end

--------------------------------------------------
-- UI BUTTON
--------------------------------------------------
button.Activated:Connect(toggleShiftLock)

--------------------------------------------------
-- KEYBOARD SHIFT
--------------------------------------------------
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.LeftAlt then
		toggleShiftLock()
	end
end)

--------------------------------------------------
-- RESPAWN SAFE
--------------------------------------------------
player.CharacterAdded:Connect(function()
	task.wait(0.1)
	applyShiftLock()
	updateButton()
end)

--------------------------------------------------
updateButton()
]]></ProtectedString>
