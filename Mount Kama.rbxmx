				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<string name="Name">RestrictedItems</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
			</Properties>
		</Item>
		<Item class="ModuleScript" referent="RBX824DAE89A4BC474C85DD111F51234C3C">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[--[[
	TryOn - Client Module
	Mengelola item Try On di client dan sinkron dengan server
]]--

local AvatarEditorService = game:GetService("AvatarEditorService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- SETTINGS & UTIL
local Settings = require(ReplicatedStorage.Settings)
local ItemDetailsCache = require(ReplicatedStorage.Libraries.ItemDetailsCache)
local ItemContainer = require(ReplicatedStorage.Utility.ItemContainer)
local getBundleCategory = require(ReplicatedStorage.Utility.getBundleCategory)
local getAccessoryCategory = require(ReplicatedStorage.Utility.getAccessoryCategory)

-- REMOTES
local remotes = ReplicatedStorage.Remotes
local tryOnRemote = remotes.TryOn
local loadTryOnRemote = remotes.LoadTryOn -- << INI BARU
local tryOnSyncRemote = remotes.TryOnSync

-- STATE
local container = ItemContainer.new()
local originalItemsLoaded = false

local isAdding = false


--------------------------------------------------
-- UPDATE KE SERVER
--------------------------------------------------
local function updateWearing()
	local items = container:getItems()
	local assets = {}
	local bundles = {}

	for _, item in items do
		if item.type == Enum.MarketplaceProductType.AvatarAsset then
			table.insert(assets, item.id)
		elseif item.type == Enum.MarketplaceProductType.AvatarBundle then
			table.insert(bundles, item.id)
		end
	end

	tryOnRemote:FireServer(assets, bundles)
end

--------------------------------------------------
-- MODULE API
--------------------------------------------------
local TryOn = {
	itemAdded = container.itemAdded,
	itemRemoved = container.itemRemoved,
}

function TryOn.getItem(
	itemId: number,
	itemType: Enum.MarketplaceProductType
): ItemContainer.ContainedItem?
	return container:getItem(itemId, itemType)
end

--------------------------------------------------
-- ADD ITEM
--------------------------------------------------
function TryOn.addItemAsync(itemId: number, itemType: Enum.MarketplaceProductType)
	if isAdding then
		return
	end

	isAdding = true

	local category

	if itemType == Enum.MarketplaceProductType.AvatarBundle then
		local bundleDetails = ItemDetailsCache.getBundleDetailsAsync(itemId)
		if bundleDetails then
			local bundleType = Enum.BundleType[bundleDetails.BundleType]
			category = getBundleCategory(bundleType)
		end
	else
		local assetDetails = ItemDetailsCache.getAssetDetailsAsync(itemId)
		if assetDetails then
			local assetType = Enum.AvatarAssetType[assetDetails.AssetType]
			local accessoryType = AvatarEditorService:GetAccessoryType(assetType)
			category = getAccessoryCategory(accessoryType)
		end
	end

	if not category then
		warn(`Failed to get category for {itemId}-{itemType}`)
		isAdding = false
		return
	end

	-- Remove similar items (kecuali Hat)
	if category ~= "Hat" and category ~= "Unknown" then
		for _, item in container:getItems() do
			if item.data.category == category then
				container:removeItem(item.id, item.type)
			end
		end
	end

	if #container:getItems() < Settings.MAX_TRY_ON_ITEMS then
		container:addItem(itemId, itemType, { category = category })
	end

	isAdding = false
	updateWearing()
end

--------------------------------------------------
-- REMOVE ITEM
--------------------------------------------------
function TryOn.removeItem(itemId: number, itemType: Enum.MarketplaceProductType)
	container:removeItem(itemId, itemType)
	updateWearing()
end

--------------------------------------------------
-- SET ITEMS (DARI SERVER)
--------------------------------------------------
function TryOn.setItemsAsync(items)
	-- bersihin dulu
	for _, item in container:getItems() do
		container:removeItem(item.id, item.type)
	end

	-- tambahin ulang lewat jalur RESMI
	for _, item in items do
		TryOn.addItemAsync(item.id, item.type)
	end
end



--------------------------------------------------
-- GET ITEMS
--------------------------------------------------
function TryOn.getItems(): { ItemContainer.ContainedItem }
	return container:getItems()
end

function TryOn.loadFromHumanoidDescription(desc: HumanoidDescription)
	if originalItemsLoaded then return end
	originalItemsLoaded = true

	local items = {}

	-- accessories
	for _, acc in desc:GetAccessories(true) do
		table.insert(items,{
			id = acc.AssetId,
			type = Enum.MarketplaceProductType.AvatarAsset,
		})
	end

	local props = {"Hat","HairAccessory","FaceAccessory","NeckAccessory","ShoulderAccessory","FrontAccessory","BackAccessory","WaistAccessory"}

	for _, prop in props do
		local str = desc[prop]
		if typeof(str) == "string" then
			for id in string.gmatch(str,"%d+") do
				table.insert(items,{
					id = tonumber(id),
					type = Enum.MarketplaceProductType.AvatarAsset,
				})
			end
		end
	end

	-- clothing
	local clothing = {"Shirt","Pants","Face"}
	for _, prop in clothing do
		local id = desc[prop]
		if typeof(id) == "number" and id > 0 then
			table.insert(items,{
				id = id,
				type = Enum.MarketplaceProductType.AvatarAsset,
			})
		end
	end

	for _, item in items do
		TryOn.addItemAsync(item.id,item.type)
	end


	updateWearing()
end

--------------------------------------------------
-- LOAD DARI SERVER (INIT)
--------------------------------------------------
loadTryOnRemote.OnClientEvent:Connect(function(
	data: { { id: number, type: string } }
)
	local items = {}

	for _, item in data do
		local itemType = Enum.MarketplaceProductType[item.type]
		if itemType then
			table.insert(items, {
				id = item.id,
				type = itemType,
			})
		end
	end

	TryOn.setItemsAsync(items)
	updateWearing()
end)

--------------------------------------------------

return TryOn
]]></ProtectedString>
