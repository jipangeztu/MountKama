local frame = script.Parent

local lighting = game:GetService("Lighting")
local skyFolder = game.ReplicatedStorage:FindFirstChild("Sky")  -- folder Sky
local atmosphereFolder = game.ReplicatedStorage:FindFirstChild("Atmosphere")  -- folder Atmosphere


frame.Anime.MouseButton1Click:Connect(function()
	local skyName = "Anime"  -- ubah sesuai nama Sky di ReplicatedStorage
	local atmosphereName = skyName
	
	-- hapus sky lama
	for _, obj in pairs(lighting:GetChildren()) do
		if obj:IsA("Sky") then
			obj:Destroy()
		end
	end

	for _, obj in pairs(lighting:GetChildren()) do
		if obj:IsA("Atmosphere") then
			obj:Destroy()
		end
	end



	-- clone sky baru
	local sky = skyFolder:FindFirstChild(skyName):Clone()
	sky.Parent = lighting
	local atmosphere = atmosphereFolder:FindFirstChild(atmosphereName):Clone()
	atmosphere.Parent = lighting
	lighting.ClockTime = 15.8
	lighting.Brightness = 1
	lighting.GeographicLatitude = 79
	lighting.ExposureCompensation = 0.69
	lighting.OutdoorAmbient = Color3.fromRGB(53, 145, 145)
end)
