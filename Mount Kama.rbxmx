	<Item class="Script" referent="RBXFEE7BAE44C4E4F759C2DB860F1085640">
		<Properties>
			<ProtectedString name="Source"><![CDATA[--================================
-- SERVICES
--================================
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local RS = game:GetService("ReplicatedStorage")

--================================
-- REMOTES
--================================
local selectEvent = RS:WaitForChild("SelectDifficulty")
local statusEvent = RS:WaitForChild("DifficultyStatus")
local requestEvent = RS:WaitForChild("RequestDifficultyStatus")

--================================
-- DATASTORE
--================================
local DifficultyStore = DataStoreService:GetDataStore("PlayerDifficulty_v2")


requestEvent.OnServerEvent:Connect(function(player)
	local diff = player:GetAttribute("Difficulty")

	if diff then
		statusEvent:FireClient(player, true, diff)
	else
		statusEvent:FireClient(player, false)
	end
end)
--================================
-- DATASTORE : SAVE
--================================
local function saveDifficulty(player, difficulty)
	local success, err = pcall(function()
		DifficultyStore:SetAsync(player.UserId, difficulty)
	end)

	if not success then
		warn("Gagal save difficulty:", err)
	end
end

--================================
-- DATASTORE : LOAD
--================================
local function loadDifficulty(player)
	local data
	local success, err = pcall(function()
		data = DifficultyStore:GetAsync(player.UserId)
	end)

	if success then
		return data
	end

	return nil
end

--================================
-- PLAYER JOIN
--================================
Players.PlayerAdded:Connect(function(player)
	local difficulty = loadDifficulty(player)

	if difficulty then
		-- simpan state global
		player:SetAttribute("Difficulty", difficulty)

		-- ❗ SERVER TIDAK SPAWN MAP
		-- client akan spawn sendiri

		statusEvent:FireClient(player, true, difficulty)
	else
		statusEvent:FireClient(player, false)
	end
end)

--================================
-- PILIH DARI GUI
--================================
selectEvent.OnServerEvent:Connect(function(player, difficultyName)
	-- validasi ringan
	if type(difficultyName) ~= "string" then return end

	-- simpan state
	player:SetAttribute("Difficulty", difficultyName)

	-- save datastore
	saveDifficulty(player, difficultyName)

	-- ❗ TIDAK ADA SPAWN MAP DI SINI

	-- beri tahu client
	statusEvent:FireClient(player, true, difficultyName)
end)
]]></ProtectedString>
