					<Item class="LocalScript" referent="RBXB630E47338714D1792387CBE9C73495A">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local button = script.Parent
local Lighting = game:GetService("Lighting")

local cc = Lighting:WaitForChild("SunRays")

-- ukuran (opsional)
--------------------------------------------------
-- UPDATE VISUAL BUTTON
--------------------------------------------------
local function updateButton()
	if cc.Enabled then
		button.BackgroundColor3 = Color3.fromRGB(0, 200, 0) -- hijau
		button.Text = "ON"
	else
		button.BackgroundColor3 = Color3.fromRGB(200, 0, 0) -- merah
		button.Text = "OFF"
	end
end

--------------------------------------------------
-- TOGGLE
--------------------------------------------------
button.MouseButton1Click:Connect(function()
	cc.Enabled = not cc.Enabled
	updateButton()
end)


cc:GetPropertyChangedSignal("Enabled"):Connect(updateButton)
--------------------------------------------------
-- INIT (sinkron dari awal)
--------------------------------------------------
updateButton()
]]></ProtectedString>
