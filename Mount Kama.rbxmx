				<ProtectedString name="Source"><![CDATA[--!strict

--[[ 
	Shop - Global Marketplace (FIXED INITIAL LOAD)
]]

local AvatarEditorService = game:GetService("AvatarEditorService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local Constants = require(ReplicatedStorage.Constants)
local Settings = require(ReplicatedStorage.Settings)
local Types = require(ReplicatedStorage.Utility.Types)
local Cart = require(ReplicatedStorage.Libraries.Cart)
local ModalManager = require(ReplicatedStorage.Libraries.ModalManager)
local RestrictedItems = require(ReplicatedStorage.Libraries.RestrictedItems)


local ItemFilters = require(script.ItemFilters)
local SortingFilters = require(script.SortingFilters)
local ingestCatalogPage = require(script.ingestCatalogPage)
local disconnectAndClear = require(ReplicatedStorage.Utility.disconnectAndClear)
local connectTreeVisibilityChanged = require(ReplicatedStorage.Utility.connectTreeVisibilityChanged)

local ItemTile = require(ReplicatedStorage.UI.Components.ItemTile)
local DropdownButton = require(ReplicatedStorage.UI.Components.DropdownButton)
local ResponsiveGrid = require(ReplicatedStorage.UI.Components.ResponsiveGrid)
local CartButton = require(ReplicatedStorage.UI.Components.CartButton)
local LoadingDisplay = require(ReplicatedStorage.UI.Components.LoadingDisplay)

-- PLAYER / GUI
local player = Players.LocalPlayer
local playerGui = player.PlayerGui
local shoppingGui = playerGui:WaitForChild("ShoppingGui")
local shopFrame = shoppingGui:WaitForChild("ShopFrame")
local topBar = shopFrame:WaitForChild("TopBar")
local searchFrame = topBar:WaitForChild("SearchFrame")
local searchBox = searchFrame:WaitForChild("SearchBox")
local closeButton = topBar:WaitForChild("CloseButton")
local shopButton = shoppingGui:WaitForChild("ShopButton")
local countLabel = shopButton:WaitForChild("CountLabel")

-- STATE
local searchParams = CatalogSearchParams.new()
local connections: { RBXScriptConnection } = {}
local isLoading = false
local searchedOnce = false

local itemFilterDropdown: GuiButton
local sortingFilterDropdown: GuiButton
local itemsFrame: ScrollingFrame
local loadingDisplay: Frame



-- UTIL
local function setLoading(v: boolean)
	isLoading = v
	if loadingDisplay then
		loadingDisplay.Visible = v
	end
end

local function clearItemTiles()
	for _, c in itemsFrame:GetChildren() do
		if c:IsA("GuiObject") then
			c:Destroy()
		end
	end
end

local function displayPage(catalogPage: Types.CatalogPage)
	for _, itemDetails in catalogPage do
		local itemType = Enum.MarketplaceProductType[`Avatar{itemDetails.ItemType}`]
		if RestrictedItems.isRestricted(itemDetails.Id, itemType) then
			continue
		end

		local tile = ItemTile(itemDetails)
		tile.Parent = itemsFrame
	end
end

local function shouldLoadNextPage(): boolean
	local bottom =
		itemsFrame.AbsoluteWindowSize.Y * (2 - Constants.SCROLL_LOAD_FACTOR)
		+ itemsFrame.CanvasPosition.Y

	return bottom >= itemsFrame.AbsoluteCanvasSize.Y
end

local function displayPagesAsync(catalogPages: CatalogPages)
	clearItemTiles()
	disconnectAndClear(connections)
	itemsFrame.CanvasPosition = Vector2.zero

	local function loadNextPageAsync()
		if isLoading or catalogPages.IsFinished then
			return
		end

		setLoading(true)
		catalogPages:AdvanceToNextPageAsync()
		setLoading(false)

		local page = catalogPages:GetCurrentPage()
		ingestCatalogPage(page)
		displayPage(page)
	end

	table.insert(
		connections,
		itemsFrame:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
			if shouldLoadNextPage() then
				loadNextPageAsync()
			end
		end)
	)

	local firstPage = catalogPages:GetCurrentPage()
	ingestCatalogPage(firstPage)
	displayPage(firstPage)

	while shouldLoadNextPage() and not catalogPages.IsFinished do
		loadNextPageAsync()
	end
end

-- SEARCH
local function searchAsync()
	if isLoading then return end

	setLoading(true)
	local pages = AvatarEditorService:SearchCatalogAsync(searchParams)
	setLoading(false)

	displayPagesAsync(pages)
end

-- UI EVENTS
local function toggleShop()
	if ModalManager.getModal() == shopFrame then
		ModalManager.pop(shopFrame)
	else
		ModalManager.push(shopFrame)
	end
end

local function updateCount()
	local c = #Cart.getItems()
	countLabel.Text = tostring(c)
	countLabel.Visible = c > 0
end

local function onItemFilterChanged(filterName: string)
	local filter = ItemFilters.filters[filterName]
	searchParams.AssetTypes = filter.assets
	searchParams.BundleTypes = filter.bundles
	searchAsync()
end

local function onSortingFilterChanged(filterName: string)
	searchParams.SortType = SortingFilters.filters[filterName]
	searchAsync()
end

-- INIT
local function onSearch()
	searchParams.SearchKeyword = searchBox.Text
	searchAsync()
end


local function initialize()
	shopButton.Activated:Connect(toggleShop)
	closeButton.Activated:Connect(toggleShop)

	Cart.itemAdded:Connect(updateCount)
	Cart.itemRemoved:Connect(updateCount)
	
	-- SEARCH BOX
	searchBox.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			onSearch()
		end
	end)

	local function onSearch()
		searchParams.SearchKeyword = searchBox.Text
		searchAsync()
	end


	UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode == Settings.SHOP_GAMEPAD_KEY_CODE then
			toggleShop()
		end
	end)

	itemsFrame = ResponsiveGrid(Constants.ITEM_TILE_SIZE, Constants.ITEM_TILE_PADDING)
	itemsFrame.Parent = shopFrame

	itemFilterDropdown = DropdownButton(
		ItemFilters.list,
		ItemFilters.list[1],
		onItemFilterChanged
	)
	itemFilterDropdown.Parent = topBar

	sortingFilterDropdown = DropdownButton(
		SortingFilters.list,
		SortingFilters.list[1],
		onSortingFilterChanged
	)
	sortingFilterDropdown.Parent = topBar

	CartButton().Parent = topBar

	loadingDisplay = LoadingDisplay()
	loadingDisplay.Parent = shopFrame

	-- GLOBAL MARKETPLACE PARAMS
	--searchParams.CreatorName = nil
	searchParams.Limit = Constants.PAGE_SIZE
	searchParams.IncludeOffSale = false
	searchParams.AssetTypes = ItemFilters.filters[ItemFilters.list[1]].assets
	searchParams.BundleTypes = ItemFilters.filters[ItemFilters.list[1]].bundles
	searchParams.SortType = SortingFilters.filters[SortingFilters.list[1]]
	searchParams.SearchKeyword = ""

	updateCount()
end

-- 🔥 INI KUNCI UTAMANYA
connectTreeVisibilityChanged(shopFrame, function(isVisible)
	if isVisible and not searchedOnce then
		searchedOnce = true
		searchAsync()
	end
end)

initialize()
]]></ProtectedString>
