	<Item class="Script" referent="RBX9A545286ACD540A8A77068D6B3201837">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local event = RS:WaitForChild("AdminCPTeleport")
local cpFolder = Workspace:WaitForChild("CP")

local function getHRP(char)
	return char and char:FindFirstChild("HumanoidRootPart")
end

event.OnServerEvent:Connect(function(player, cpName)
	if typeof(cpName) ~= "string" then return end

	local cp = cpFolder:FindFirstChild(cpName)
	if not cp or not cp:IsA("BasePart") then return end

	local char = player.Character
	local hrp = getHRP(char)
	if not hrp then return end

	hrp.CFrame = cp.CFrame * CFrame.new(0, 3, 0)
end)
]]></ProtectedString>
