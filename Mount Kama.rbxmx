		</Properties>
		<Item class="LocalScript" referent="RBX97786B9635C1475AAE0DD4719A5CE340">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local RS = game:GetService("ReplicatedStorage")
local notifyEvent = RS:WaitForChild("CheckpointNotify")
local label = script.Parent:WaitForChild("CheckpointLabel")

label.Position = UDim2.new(0.5, 0, 0.1, 0)
-- daftar checkpoint yg sudah pernah tampil
local shown = {}

notifyEvent.OnClientEvent:Connect(function(cpName)

	-- kalau sudah pernah muncul, langsung stop
	if shown[cpName] then
		return
	end

	-- tandai sudah pernah
	shown[cpName] = true

	label.Text = "Checkpoint " .. cpName
	label.Visible = true

	task.wait(2)

	for i = 1, 30 do
		label.TextTransparency = i/30
		task.wait(0.03)
	end

	label.Visible = false
	label.TextTransparency = 0
end)
]]></ProtectedString>
				<bool name="Disabled">false</bool>
				<Content name="LinkedSource"><null></null></Content>
				<token name="RunContext">0</token>
				<string name="ScriptGuid">{A4A4D6B3-516C-4642-BB22-4D317B73609D}</string>
				<BinaryString name="AttributesSerialize"></BinaryString>
				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<string name="Name">cpNotif</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
			</Properties>
		</Item>
		<Item class="LocalScript" referent="RBXEB47BD0FB2164B34B1104D9766655391">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ScreenGui target
local speedGui = playerGui:FindFirstChild("Speed")
local emoteGui = playerGui:FindFirstChild("EmoteSystemGui")
local adminGui = playerGui:FindFirstChild("AdminGui")
local ownerGui = playerGui:FindFirstChild("OwnerGui")
local robuxGui = playerGui:FindFirstChild("RobuxGui")
local shopGui = playerGui:FindFirstChild("ShoppingGui")
local inventory = playerGui:FindFirstChild("Custom Inventory")


local menu = script.Parent:WaitForChild("Menu")
local am = script.Parent:WaitForChild("AvatarMenu")
local rb = script.Parent:WaitForChild("ResetButton")
local rab = script.Parent:WaitForChild("ResetAvabutton")
local langitMnu = script.Parent:WaitForChild("LangitMenu")
local tb = script.Parent:WaitForChild("ToggleButton")
local tep = script.Parent:WaitForChild("360")
local tm = script.Parent:WaitForChild("TitleMenu")
local jb = script.Parent:WaitForChild("JumpButton")	
local sb = script.Parent:WaitForChild("Setting")


local TweenService = game:GetService("TweenService")

local rotated = false
local tweenInfo = TweenInfo.new(
	0.24, -- durasi
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)



--posisi

--visibilitas
langitMnu.Visible = false
am.Visible = false
rb.Visible = false
rab.Visible = false
tb.Visible = false
tep.Visible = false
tm.Visible = false
jb.Visible = false
sb.Visible = false

local function guiHide()
	if adminGui then
		adminGui.Enabled = not adminGui.Enabled
	end
	if ownerGui then
		ownerGui.Enabled = not ownerGui.Enabled
	end
	if speedGui then
		speedGui.Enabled = not speedGui.Enabled
	end
	if emoteGui then
		emoteGui.Enabled = not emoteGui.Enabled
	end
	if robuxGui then
		robuxGui.Enabled = not robuxGui.Enabled
	end
	if shopGui then
		shopGui.Enabled = not shopGui.Enabled
	end
	if inventory then
		inventory.Enabled = not inventory.Enabled
	end
end

local buttonData = {}

for _, btn in ipairs({am, rb, rab, langitMnu, tb, tep , tm, jb, sb}) do
	buttonData[btn] = {
		pos = btn.Position,
		size = btn.Size
	}
end


local function showButton(btn, show)
	local data = buttonData[btn]

	if show then
		btn.Visible = true
		btn.Position = menu.Position
		btn.Size = UDim2.new(0,0,0,0)
	end

	local goal = {}
	if show then
		goal.Position = data.pos
		goal.Size = data.size
	else
		goal.Position = menu.Position
		goal.Size = UDim2.new(0,0,0,0)
	end

	local tween = TweenService:Create(btn, tweenInfo, goal)
	tween:Play()

	if not show then
		tween.Completed:Once(function()
			btn.Visible = false
		end)
	end
end


menu.MouseButton1Click:Connect(function()
	rotated = not rotated

	-- rotasi menu
	TweenService:Create(menu, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()

	-- tombol muncul satu-satu (acak)
	local buttons = {am, rb, rab, langitMnu, tb, tep, tm, jb, sb}

	for _, btn in ipairs(buttons) do
		task.delay(math.random(0,15)/100, function()
			showButton(btn, rotated)
		end)
	end
	guiHide()
end)

am.MouseButton1Click:Connect(function()
	rotated = not rotated

	-- rotasi menu
	TweenService:Create(menu, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()

	-- tombol muncul satu-satu (acak)
	local buttons = {am, rb, rab, langitMnu, tb, tep, tm, jb, sb}

	for _, btn in ipairs(buttons) do
		task.delay(math.random(0,15)/100, function()
			showButton(btn, false)
		end)
	end
	guiHide()
end)

sb.MouseButton1Click:Connect(function()
	

	rotated = not rotated

	-- rotasi menu
	TweenService:Create(menu, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()

	-- tombol muncul satu-satu (acak)
	local buttons = {am, rb, rab, langitMnu, tb, tep, tm, jb, sb}

	for _, btn in ipairs(buttons) do
		task.delay(math.random(0,15)/100, function()
			showButton(btn, false)
		end)
	end
	guiHide()
end)

tep.MouseButton1Click:Connect(function()
	rotated = not rotated
	TweenService:Create(menu, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()

	-- tombol muncul satu-satu (acak)
	local buttons = {am, rb, rab, langitMnu, tb, tep, tm, jb, sb}

	for _, btn in ipairs(buttons) do
		task.delay(math.random(0,15)/100, function()
			showButton(btn, false)
		end)
	end
	guiHide()
end)

tm.MouseButton1Click:Connect(function()
	rotated = not rotated
	TweenService:Create(menu, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()

	-- tombol muncul satu-satu (acak)
	local buttons = {am, rb, rab, langitMnu, tb, tep, tm, jb, sb}

	for _, btn in ipairs(buttons) do
		task.delay(math.random(0,15)/100, function()
			showButton(btn, false)
		end)
	end
	guiHide()
end)

script.Parent:WaitForChild("Fcontrol"):WaitForChild("Exit").MouseButton1Click:Connect(function()
	guiHide()
end)]]></ProtectedString>
