		<Item class="LocalScript" referent="RBX21DFE66AA41448FA850046DF324BB77C">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer

local statusEvent = ReplicatedStorage:WaitForChild("DifficultyStatus")
local selectEvent = ReplicatedStorage:WaitForChild("SelectDifficulty")

local difficultiesFolder = ReplicatedStorage:WaitForChild("Difficulties")

local screenGui = script.Parent
local frame = screenGui:WaitForChild("TingkatFrame")
local frame2 = screenGui:WaitForChild("HardFrame")

--------------------------------------------------
-- STATE
--------------------------------------------------
local hasChosen = false
local activeMap
local statusLocked = false -- 🔥 KUNCI STATUS


--------------------------------------------------
-- DEFAULT
--------------------------------------------------
task.wait(5)
screenGui.Enabled = true


--------------------------------------------------
-- MAP CONTROL (GRAPHIC STYLE)
--------------------------------------------------
local function clearMap()
	if activeMap then
		activeMap:Destroy()
		activeMap = nil
	end
end

local function spawnMap(difficultyName)
	local source = difficultiesFolder:FindFirstChild(difficultyName)
	if not source then return end

	clearMap()

	local clone = source:Clone()
	clone.Name = "LocalDifficultyMap"
	clone.Parent = Workspace -- ⚠️ LOCAL ONLY

	activeMap = clone
end

--------------------------------------------------
-- OPEN GUI
--------------------------------------------------
local function openGui()
	hasChosen = false
	screenGui.Enabled = true
end

--------------------------------------------------
-- TERIMA STATUS DARI SERVER
--------------------------------------------------
--------------------------------------------------
-- TERIMA STATUS DARI SERVER
--------------------------------------------------
statusEvent.OnClientEvent:Connect(function(hasData, difficulty)

	if hasData and difficulty then
		-- 🔒 PLAYER SUDAH PUNYA DIFFICULTY
		hasChosen = true
		screenGui.Enabled = false

		-- spawn map kalau belum ada / beda
		if not activeMap or activeMap.Name ~= difficulty then
			spawnMap(difficulty)
		end
	else
		-- 🔓 PLAYER BOLEH PILIH ULANG (RESET CP / PLAYER BARU)
		hasChosen = false
		clearMap()
		screenGui.Enabled = true
	end

end)




--------------------------------------------------
-- BUTTONS
--------------------------------------------------
local function choose(name)
	if hasChosen then return end
	hasChosen = true

	-- 🔥 LOCAL SPAWN (KUNCI ANTI NUMPUK)
	spawnMap(name)

	-- 🔥 SERVER CUMA SIMPAN STATE
	selectEvent:FireServer(name)

	screenGui.Enabled = false
end

frame.Easy.MouseButton1Click:Connect(function()
	choose("Easy")
end)

frame.Normal.MouseButton1Click:Connect(function()
	choose("Normal")
end)

frame.Hard.MouseButton1Click:Connect(function()
	frame.Visible = false
	frame2.Visible = true
	--choose("Hard")
end)

frame.Continued.MouseButton1Click:Connect(function()
	
	screenGui.Enabled = false
end)

frame2.Ya.MouseButton1Click:Connect(function()
	choose("Hard")
	frame2.Visible = false
	frame.Visible = true
end)

frame2.Tidak.MouseButton1Click:Connect(function()
	frame.Visible = true
	frame2.Visible = false	
end)

-- 🔥 REQUEST STATUS SETELAH CLIENT SIAP
task.wait() -- 1 frame cukup
ReplicatedStorage:WaitForChild("RequestDifficultyStatus"):FireServer()

]]></ProtectedString>
