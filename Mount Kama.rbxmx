					<ProtectedString name="Source"><![CDATA[--!strict

--[[
	ItemButton - UI button untuk item (icon + try on indicator).
	Menampilkan status Try On dan toggle saat diklik.
	Digunakan di Shop dan Cart.
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- MODULES
local TryOn = require(ReplicatedStorage.Libraries.TryOn)
local ItemContainer = require(ReplicatedStorage.Utility.ItemContainer)
local getItemIcon = require(ReplicatedStorage.Utility.getItemIcon)

-- TEMPLATE
local itemButtonTemplate = ReplicatedStorage.UI.Objects.ItemButton

--------------------------------------------------
-- COMPONENT
--------------------------------------------------
local function ItemButton(
	itemId: number,
	itemType: Enum.MarketplaceProductType
): ImageButton
	-- Ambil icon
	local icon = getItemIcon(itemId, itemType)

	-- Clone UI
	local itemButton = itemButtonTemplate:Clone()
	itemButton.Image = icon
	itemButton.TryOnFrame.Visible = false -- default OFF

	--------------------------------------------------
	-- SYNC STATE (PENTING)
	--------------------------------------------------
	local function syncState()
		itemButton.TryOnFrame.Visible =
			TryOn.getItem(itemId, itemType) ~= nil
	end

	--------------------------------------------------
	-- CLICK
	--------------------------------------------------
	local function onActivated()
		if TryOn.getItem(itemId, itemType) then
			TryOn.removeItem(itemId, itemType)
		else
			TryOn.addItemAsync(itemId, itemType)
		end
	end

	--------------------------------------------------
	-- TRY ON EVENTS
	--------------------------------------------------
	local function onItemAdded(item: ItemContainer.ContainedItem)
		if item.id == itemId and item.type == itemType then
			itemButton.TryOnFrame.Visible = true
		end
	end

	local function onItemRemoved(item: ItemContainer.ContainedItem)
		if item.id == itemId and item.type == itemType then
			itemButton.TryOnFrame.Visible = false
		end
	end

	--------------------------------------------------
	-- CONNECTIONS
	--------------------------------------------------
	itemButton.Activated:Connect(onActivated)

	local addedConnection = TryOn.itemAdded:Connect(onItemAdded)
	local removedConnection = TryOn.itemRemoved:Connect(onItemRemoved)

	-- Cleanup
	itemButton.Destroying:Once(function()
		addedConnection:Disconnect()
		removedConnection:Disconnect()
	end)

	-- ⏳ Sync SETELAH TryOn load dari server
	task.defer(syncState)

	return itemButton
end

return ItemButton
]]></ProtectedString>
