--[[
	Dropdown - Basic dropdown UI component
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local connectTreeVisibilityChanged = require(ReplicatedStorage.Utility.connectTreeVisibilityChanged)
local safeClamp = require(ReplicatedStorage.Utility.safeClamp)

local dropdownGuiTemplate = ReplicatedStorage.UI.Objects.DropdownGui
local dropdownOptionTemplate = ReplicatedStorage.UI.Objects.DropdownOptionButton

-- ===== CONFIG =====
local OPTION_HEIGHT = 32
local MAX_VISIBLE_OPTIONS = 6
-- ==================

local function DropdownDisplay<T>(
	options: { T },
	updateFunction: (T) -> (),
	parent: GuiObject
): ScreenGui

	-- Clone ScreenGui so dropdown appears above everything
	local dropdownDisplay = dropdownGuiTemplate:Clone() :: DropdownGui
	local dropdownFrame = dropdownDisplay.DropdownFrame

	-- Create option buttons
	for _, value in options do
		local optionButton = dropdownOptionTemplate:Clone()
		optionButton.Text = tostring(value)
		optionButton.Parent = dropdownFrame

		optionButton.Activated:Connect(function()
			dropdownDisplay:Destroy()
			updateFunction(value)
		end)
	end

	-- Update dropdown size & position
	local function updateSizeAndPosition()
		local xPosition = parent.AbsolutePosition.X
		local yPosition = parent.AbsolutePosition.Y + parent.AbsoluteSize.Y

		local optionCount = #options
		local visibleOptions = math.min(optionCount, MAX_VISIBLE_OPTIONS)
		local dropdownHeight = visibleOptions * OPTION_HEIGHT

		xPosition = safeClamp(
			xPosition,
			0,
			dropdownDisplay.AbsoluteSize.X - parent.AbsoluteSize.X
		)

		yPosition = safeClamp(
			yPosition,
			0,
			dropdownDisplay.AbsoluteSize.Y - dropdownHeight
		)

		dropdownFrame.Position = UDim2.fromOffset(xPosition, yPosition)
		dropdownFrame.Size = UDim2.fromOffset(
			parent.AbsoluteSize.X,
			dropdownHeight
		)
	end

	-- Close dropdown if parent becomes invisible
	local function onTreeVisibilityChanged(isVisible: boolean)
		if not isVisible then
			dropdownDisplay:Destroy()
		end
	end

	-- Fullscreen input sink (click outside closes dropdown)
	dropdownDisplay.InputSinkButton.Activated:Connect(function()
		dropdownDisplay:Destroy()
	end)

	-- React to size & position changes
	dropdownFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateSizeAndPosition)

	local positionChangedConnection =
		parent:GetPropertyChangedSignal("AbsolutePosition"):Connect(updateSizeAndPosition)

	local sizeChangedConnection =
		parent:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateSizeAndPosition)

	local disconnectTreeVisibilityChanged =
		connectTreeVisibilityChanged(parent, onTreeVisibilityChanged)

	-- Cleanup
	dropdownDisplay.Destroying:Once(function()
		positionChangedConnection:Disconnect()
		sizeChangedConnection:Disconnect()
		disconnectTreeVisibilityChanged()
	end)

	updateSizeAndPosition()

	return dropdownDisplay
end

return DropdownDisplay
]]></ProtectedString>
