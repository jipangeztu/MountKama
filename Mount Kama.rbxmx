	<Item class="Script" referent="RBX7048B7664E5D4B31BFAC3FB14AC3CAC5">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local DataStoreService = game:GetService("DataStoreService")
local Players = game.Players

local cpStore = DataStoreService:GetDataStore("SavedCheckpointID_v1")

Players.PlayerAdded:Connect(function(player)
	local success, savedId = pcall(function()
		return cpStore:GetAsync("CP_" .. player.UserId)
	end)

	if success and typeof(savedId) == "number" then
		player:SetAttribute("Checkpoint", savedId)
	else
		player:SetAttribute("Checkpoint", 0)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	local id = player:GetAttribute("Checkpoint")
	if id ~= nil then
		pcall(function()
			cpStore:SetAsync("CP_" .. player.UserId, id)
		end)
	end
end)

game:BindToClose(function()
	for _, player in ipairs(Players:GetPlayers()) do
		local id = player:GetAttribute("Checkpoint")
		if id ~= nil then
			pcall(function()
				cpStore:SetAsync("CP_" .. player.UserId, id)
			end)
		end
	end
end)
]]></ProtectedString>
