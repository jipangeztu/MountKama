			<Item class="LocalScript" referent="RBX84D7CCE3B1784272B867C9C3D548294F">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local button = script.Parent
local xbutton = script.Parent.Parent:WaitForChild("xAva")
local frame = button.Parent:WaitForChild("AvatarFrame")
local TweenService = game:GetService("TweenService")
local on = false

local warnaOn  = Color3.fromRGB(40, 255, 29)
local warnaOff = button.BackgroundColor3

local isOpen = false
local rotated = false

frame.Visible = false
xbutton.Visible = false

xbutton.Position = UDim2.new(0.65, 0, 0.17, 0)
xbutton.Size     = UDim2.new(0.08, 0, 0.08, 0)
xbutton.AnchorPoint = Vector2.new(0.5, 0.5)

local tweenInfo = TweenInfo.new(
	0.25,
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)

function toggleFrame()
	isOpen = not isOpen
	rotated = not rotated

	-- rotasi tombol (tetap ada)
	TweenService:Create(button, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()
	
	on = not on
	button.BackgroundColor3 = on and warnaOn or warnaOff

	-- frame tanpa efek transparansi
	frame.Visible = isOpen
	xbutton.Visible = isOpen
end
button.MouseButton1Click:Connect(function()
	
	toggleFrame()
end)
xbutton.MouseButton1Click:Connect(function()
	
	toggleFrame()
end)


]]></ProtectedString>
