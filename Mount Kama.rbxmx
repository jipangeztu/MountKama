		<Item class="LocalScript" referent="RBX9177EBA633284AABB858568FC997376A">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--[[
	SYNC CLIENT SCRIPT
	Client-side sync system with Avatar Context Menu
	Version 4.1 - Clean Architecture
]]

-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer

-- Import shared module
local SyncModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("SyncModule"))

-- ============================================
-- WAIT FOR DEPENDENCIES
-- ============================================

repeat task.wait() until player.Character
task.wait(1)

local remoteFolder = ReplicatedStorage:WaitForChild("Remotes", 10)
if not remoteFolder then
	warn("[CLIENT SYNC] Remote folder not found!")
	return
end

local syncFolder = remoteFolder:WaitForChild("Sync", 10)
if not syncFolder then
	warn("[CLIENT SYNC] Sync folder not found!")
	return
end

local syncRemote = syncFolder:WaitForChild("SyncRemote", 10)
local unsyncRemote = syncFolder:WaitForChild("UnsyncRemote", 10)
local emotesFolder = ReplicatedStorage:WaitForChild("Emotes", 10)

if not syncRemote or not unsyncRemote or not emotesFolder then
	warn("[CLIENT SYNC] ERROR: Missing required dependencies!")
	return
end

SyncModule.debugPrint("CLIENT", "All dependencies loaded")

-- ============================================
-- STATE MANAGEMENT
-- ============================================

local currentSyncTarget = nil
local predictedAnimations = {}
local connections = {}

-- ============================================
-- UTILITY FUNCTIONS
-- ============================================

local function trackConnection(conn)
	table.insert(connections, conn)
	return conn
end

local function showNotification(title, text, duration)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = title,
			Text = text,
			Duration = duration or 3
		})
	end)
end

-- ============================================
-- CLIENT-SIDE PREDICTION
-- ============================================

local function predictLeaderAnimations(leaderPlayer)
	SyncModule.debugPrint("PREDICTION", "Start for", leaderPlayer.Name)

	if not leaderPlayer or not leaderPlayer.Character then return end

	local leaderHumanoid = leaderPlayer.Character:FindFirstChild("Humanoid")
	if not leaderHumanoid then return end

	local leaderAnimator = leaderHumanoid:FindFirstChild("Animator")
	if not leaderAnimator then return end

	local myCharacter = player.Character
	if not myCharacter then return end

	local myHumanoid = myCharacter:FindFirstChild("Humanoid")
	if not myHumanoid then return end

	local myAnimator = myHumanoid:FindFirstChild("Animator")
	if not myAnimator then return end

	for _, track in pairs(predictedAnimations) do
		if track and track.IsPlaying then
			track:Stop(0)
		end
	end
	predictedAnimations = {}

	local leaderTracks = leaderAnimator:GetPlayingAnimationTracks()
	local predictedCount = 0

	for _, leaderTrack in ipairs(leaderTracks) do
		if SyncModule.isEmoteAnimation(leaderTrack.Animation, emotesFolder) then
			local success, result = pcall(function()
				local track = myAnimator:LoadAnimation(leaderTrack.Animation)
				track:Play(0, 1, 1)
				track.TimePosition = leaderTrack.TimePosition
				track:AdjustSpeed(leaderTrack.Speed)

				if leaderTrack.WeightCurrent and leaderTrack.WeightCurrent > 0 then
					track:AdjustWeight(leaderTrack.WeightCurrent)
				end

				return track
			end)

			if success and result then
				table.insert(predictedAnimations, result)
				predictedCount = predictedCount + 1
				SyncModule.debugPrint("PREDICTION", "Success:", leaderTrack.Animation.Name)
			end
		end
	end

	SyncModule.debugPrint("PREDICTION", "Complete -", predictedCount, "emotes")
end

local function clearPredictedAnimations(waitForServer)
	SyncModule.debugPrint("CLEAR_PREDICTION", "Wait for server:", waitForServer)

	if waitForServer then
		local myAnimator = player.Character 
			and player.Character:FindFirstChild("Humanoid") 
			and player.Character.Humanoid:FindFirstChild("Animator")

		if myAnimator then
			local startTime = tick()

			while tick() - startTime < 0.5 do
				local currentTracks = myAnimator:GetPlayingAnimationTracks()

				local hasServerAnims = false
				for _, track in ipairs(currentTracks) do
					local isPredicted = false
					for _, pTrack in ipairs(predictedAnimations) do
						if track == pTrack then
							isPredicted = true
							break
						end
					end
					if not isPredicted and SyncModule.isEmoteAnimation(track.Animation, emotesFolder) then
						hasServerAnims = true
						SyncModule.debugPrint("SERVER_ANIM", "Detected:", track.Animation.Name)
						break
					end
				end

				if hasServerAnims then
					break
				end

				task.wait(0.05)
			end
		end
	end

	for _, track in pairs(predictedAnimations) do
		if track then
			if track.IsPlaying then
				track:Stop(0)
			end
			task.spawn(function()
				task.wait(0.1)
				if track then
					track:Destroy()
				end
			end)
		end
	end
	predictedAnimations = {}
end

-- ============================================
-- SYNC FUNCTIONS
-- ============================================

local function sync(targetPlayer)
	SyncModule.debugPrint("SYNC_REQUEST", "Target:", targetPlayer and targetPlayer.Name or "nil")

	if not targetPlayer then
		showNotification("Sync Error", "No target selected", 3)
		return
	end

	if targetPlayer == player then
		showNotification("Sync Error", "Cannot sync with yourself", 3)
		return
	end

	if not syncRemote then
		showNotification("Sync Error", "Sync system not ready", 3)
		return
	end

	if not player.Character or not targetPlayer.Character then
		showNotification("Sync Error", "Character not loaded", 3)
		return
	end

	if not player.Character:FindFirstChild("Humanoid") or 
		not targetPlayer.Character:FindFirstChild("Humanoid") then
		return
	end

	currentSyncTarget = targetPlayer
	predictLeaderAnimations(targetPlayer)
	syncRemote:FireServer(targetPlayer)

	showNotification("Syncing...", "Requesting sync with " .. targetPlayer.Name, 2)
end

local function unsync()
	SyncModule.debugPrint("UNSYNC_REQUEST", "Stopping sync")
	currentSyncTarget = nil
	clearPredictedAnimations(false)

	if unsyncRemote then
		unsyncRemote:FireServer()
	end

	showNotification("Unsynced", "Sync stopped", 2)
end

-- ============================================
-- REMOTE EVENT HANDLERS
-- ============================================

trackConnection(syncRemote.OnClientEvent:Connect(function(data)
	SyncModule.debugPrint("SERVER_RESPONSE", data and data.cmd or "nil")

	if not data or type(data) ~= "table" then return end

	if data.cmd == "InitialSync" then
		clearPredictedAnimations(true)
		showNotification(
			"✓ Sync Success",
			"Synced with " .. (currentSyncTarget and currentSyncTarget.Name or "player"),
			3
		)

	elseif data.cmd == "SyncFailed" then
		clearPredictedAnimations(false)
		currentSyncTarget = nil
		showNotification(
			"✗ Sync Failed",
			data.reason or "Unable to sync",
			4
		)
	end
end))

trackConnection(unsyncRemote.OnClientEvent:Connect(function(data)
	if not data or type(data) ~= "table" then return end

	if data.cmd == "UnsyncCompleted" then
		currentSyncTarget = nil
		clearPredictedAnimations(false)

	elseif data.cmd == "LeaderLeft" then
		if currentSyncTarget and data.leaderUserId and 
			currentSyncTarget.UserId == data.leaderUserId then
			currentSyncTarget = nil
			clearPredictedAnimations(false)
			showNotification("Sync Ended", "Leader left the game", 3)
		end
	end
end))

-- ============================================
-- AVATAR CONTEXT MENU
-- ============================================

pcall(function()
	StarterGui:SetCore("AvatarContextMenuEnabled", true)
	StarterGui:SetCore("RemoveAvatarContextMenuOption", Enum.AvatarContextMenuOption.Chat)
end)

local syncBindable = Instance.new("BindableEvent")
local unsyncBindable = Instance.new("BindableEvent")

trackConnection(syncBindable.Event:Connect(sync))
trackConnection(unsyncBindable.Event:Connect(unsync))

pcall(function()
	StarterGui:SetCore("AddAvatarContextMenuOption", {"Sync", syncBindable})
	StarterGui:SetCore("AddAvatarContextMenuOption", {"Unsync", unsyncBindable})
end)

-- ============================================
-- CHARACTER RESPAWN HANDLING
-- ============================================

player.CharacterAdded:Connect(function()
	currentSyncTarget = nil
	clearPredictedAnimations(false)
	task.wait(1)
end)

-- ============================================
-- CLEANUP
-- ============================================

Players.PlayerRemoving:Connect(function(leavingPlayer)
	if leavingPlayer == player then
		for i, conn in ipairs(connections) do
			if conn and conn.Connected then
				conn:Disconnect()
			end
			connections[i] = nil
		end

		clearPredictedAnimations(false)

		if syncBindable then
			syncBindable:Destroy()
		end
		if unsyncBindable then
			unsyncBindable:Destroy()
		end
	end
end)

-- ============================================
-- INITIALIZATION COMPLETE
-- ============================================

SyncModule.notify("✓ CLIENT SYNC INITIALIZED")
SyncModule.notify("Right-click players to Sync/Unsync")]]></ProtectedString>
				<bool name="Disabled">false</bool>
