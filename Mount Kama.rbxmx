			<Item class="LocalScript" referent="RBXD03E81A46D8840C38CA31E010B1D9E6D">
				<Properties>
					<ProtectedString name="Source"><![CDATA[

local mButton = script.Parent
local on = false

local warnaOn  = Color3.fromRGB(85, 255, 255)
local warnaOff = mButton.BackgroundColor3
local cam = script.Parent.Parent:WaitForChild("AvatarMenu")
local tep = script.Parent.Parent:WaitForChild("360")
local soundOn  = mButton:WaitForChild("SoundOn")
local soundOff = mButton:WaitForChild("SoundOff")

mButton.MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff

	if on then
		soundOn:Play()
	else
		soundOff:Play()
	end
end)


tep.MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
end)

cam.MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
end)

script.Parent.Parent:WaitForChild("Setting").MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
end)

script.Parent.Parent:WaitForChild("TitleMenu").MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
end)

script.Parent.Parent:WaitForChild("xSeting").MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
end)
]]></ProtectedString>
