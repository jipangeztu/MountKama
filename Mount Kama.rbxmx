			<Item class="LocalScript" referent="RBX8A6285BFF1C54C2E9A5E193DCFBCB55B">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--!strict
-- Inspect Player Button Script

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Constants = require(ReplicatedStorage.Constants)
local ItemDetailsCache = require(ReplicatedStorage.Libraries.ItemDetailsCache)
local ModalManager = require(ReplicatedStorage.Libraries.ModalManager)
local TryOn = require(ReplicatedStorage.Libraries.TryOn)


local ResponsiveGrid = require(ReplicatedStorage.UI.Components.ResponsiveGrid)
local ItemTile = require(ReplicatedStorage.UI.Components.ItemTile)
local LoadingDisplay = require(ReplicatedStorage.UI.Components.LoadingDisplay)

--------------------------------------------------
-- PLAYER & GUI
--------------------------------------------------
local player = Players.LocalPlayer :: Player
local playerGui = player:WaitForChild("PlayerGui")

local shoppingGui = playerGui:WaitForChild("ShoppingGui")
local inspectFrame = shoppingGui:WaitForChild("InspectFrame")
local topBar = inspectFrame:WaitForChild("TopBar")
local closeButton = topBar:WaitForChild("CloseButton")

-- 🔥 BUTTON GUI (YANG KAMU MAU)
local inspectButton = script.Parent 

--------------------------------------------------
-- STATE
--------------------------------------------------
local inspectingItems: { { id: number, type: Enum.MarketplaceProductType } } = {}
local itemsFrame: ScrollingFrame
local loadingDisplay: Frame
local isLoading = false

--------------------------------------------------
-- UTILS
--------------------------------------------------
local function setLoading(state: boolean)
	isLoading = state
	loadingDisplay.Visible = state
end

local function clearItems()
	for _, child in itemsFrame:GetChildren() do
		if child:IsA("GuiObject") then
			child:Destroy()
		end
	end
end

--------------------------------------------------
-- GET PLAYER AVATAR ITEMS
--------------------------------------------------
local function getPlayerAvatarItems(): { { id: number, type: Enum.MarketplaceProductType } }
	local result = {}

	local character = player.Character
	if not character then
		return result
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return result
	end

	local desc = humanoid:GetAppliedDescription()

	-- Accessories
	for _, acc in desc:GetAccessories(true) do
		table.insert(result, {
			id = acc.AssetId,
			type = Enum.MarketplaceProductType.AvatarAsset,
		})
	end

	-- Body + Clothing
	local props = {
		"Head",
		"Torso",
		"LeftArm",
		"RightArm",
		"LeftLeg",
		"RightLeg",
		"Shirt",
		"Pants",
		"Face",
		
	}

	for _, prop in props do
		local id = (desc :: any)[prop]
		if typeof(id) == "number" and id > 0 then
			table.insert(result, {
				id = id,
				type = Enum.MarketplaceProductType.AvatarAsset,
			})
		end
	end

	return result
end

--------------------------------------------------
-- INSPECT PLAYER
--------------------------------------------------
local function inspectPlayer()
	if isLoading then return end

	local character = player.Character
	if character then
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			local desc = humanoid:GetAppliedDescription()

			-- 🔥 MASUKKAN ITEM ASLI KE TRYON
			TryOn.loadFromHumanoidDescription(desc)
		end
	end


	table.clear(inspectingItems)

	for _, item in getPlayerAvatarItems() do
		table.insert(inspectingItems, item)
	end

	clearItems()
	ModalManager.push(inspectFrame)
	setLoading(true)

	for _, item in inspectingItems do
		local details

		if item.type == Enum.MarketplaceProductType.AvatarAsset then
			details = ItemDetailsCache.getAssetDetailsAsync(item.id)
		else
			details = ItemDetailsCache.getBundleDetailsAsync(item.id)
		end

		if details then
			ItemTile(details).Parent = itemsFrame
		end
	end

	setLoading(false)
end

--------------------------------------------------
-- BUTTON EVENT (INI INTINYA)
--------------------------------------------------
inspectButton.Activated:Connect(function()
	inspectPlayer()
end)

--------------------------------------------------
-- CLOSE
--------------------------------------------------
closeButton.Activated:Connect(function()
	ModalManager.pop(inspectFrame)
end)

--------------------------------------------------
-- INIT UI
--------------------------------------------------
itemsFrame = inspectFrame:FindFirstChild("ResponsiveGrid")
if not itemsFrame then
	itemsFrame = ResponsiveGrid(Constants.ITEM_TILE_SIZE, Constants.ITEM_TILE_PADDING)
	itemsFrame.Name = "ResponsiveGrid"
	itemsFrame.Parent = inspectFrame
end


loadingDisplay = inspectFrame:FindFirstChild("LoadingDisplay")
if not loadingDisplay then
	loadingDisplay = LoadingDisplay()
	loadingDisplay.Name = "LoadingDisplay"
	loadingDisplay.Parent = inspectFrame
end

]]></ProtectedString>
