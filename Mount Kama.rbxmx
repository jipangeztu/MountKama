local on = false

local warnaOn  = Color3.fromRGB(255, 0, 4)
local warnaOff = mButton.BackgroundColor3

local frame = script.Parent.Parent:WaitForChild("360Frame")

mButton.MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
end)

frame.Keluar.MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff
end)]]></ProtectedString>
