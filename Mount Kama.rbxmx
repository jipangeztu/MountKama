					<Item class="LocalScript" referent="RBX7A4FCFA5BF164BFA99C71CDF03D77507">
						<Properties>
							<ProtectedString name="Source"><![CDATA[-- LocalScript (Button Donasi)

local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local PRODUCT_ID = 3511904533 -- ProductId kamu

local button = script.Parent
button.Text = "Loading..."


-- ambil info produk
local success, info = pcall(function()
	return MarketplaceService:GetProductInfo(PRODUCT_ID, Enum.InfoType.Product)
end)

if success and info then
	-- 💰 harga robux
	button.Text = info.PriceInRobux .. " Robux"
else
	button.Text = "?"
	warn("Gagal ambil harga product")
end

-- beli
button.MouseButton1Click:Connect(function()
	MarketplaceService:PromptProductPurchase(player, PRODUCT_ID)
	button:WaitForChild("SoundOn"):Play()
	
end)
]]></ProtectedString>
