					<Item class="LocalScript" referent="RBX742E809F81C9438AB006A74B8E44456D">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local UIS = game:GetService("UserInputService")
local frame = script.Parent
local fill = frame:WaitForChild("Fill")
local knob = frame:WaitForChild("Knob")

local SoundService = game:GetService("SoundService")
local group = SoundService:WaitForChild("SFX")

knob.AnchorPoint = Vector2.new(0.5, 0.5)

local dragging = false
local minX = 0
local maxX = frame.AbsoluteSize.X

local off = knob.Off

local function setValue(value)
	value = math.clamp(value, 0, 0.9)
	fill.AnchorPoint = Vector2.new(0, 0.5)
	fill.Position = UDim2.new(0, 0, 0.5, 0)

	fill.Size = UDim2.new(value, 0, 1, 0)

	knob.Position = UDim2.new(value, 0, 0.5, 0)
	
	if value == 0 then
		off.Visible = true
	else
		off.Visible = false
	end

	group.Volume = value
end

local function update(input)
	local x = input.Position.X - frame.AbsolutePosition.X
	local value = x / maxX
	setValue(value)
end

knob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (
		input.UserInputType == Enum.UserInputType.Touch
			or input.UserInputType == Enum.UserInputType.MouseMovement
		) then
		update(input)
	end
end)]]></ProtectedString>
