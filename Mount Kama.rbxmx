	<Item class="Script" referent="RBX74598C44C4784DBFA32FEA328970C9D7">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local cpFolder = Workspace:WaitForChild("CP")
local startPart = Workspace:WaitForChild("Start")

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(char)
		local hrp = char:WaitForChild("HumanoidRootPart")
		local humanoid = char:WaitForChild("Humanoid")

		-- tunggu karakter benar-benar siap
		task.wait(0.1)

		-- 🚫 skip teleport kalau lagi ganti avatar
		if char:GetAttribute("IgnoreCheckpointTeleport") then
			char:SetAttribute("IgnoreCheckpointTeleport", false)
			return
		end

		local id = player:GetAttribute("Checkpoint") or 0
		local target

		if id == 0 then
			target = startPart
		else
			target = cpFolder:FindFirstChild(tostring(id))
		end

		if target then
			-- teleport aman
			hrp:PivotTo(target.CFrame + Vector3.new(0, 4, 0))
		end

		-- 🔧 reset movement (INI PENTING)
		humanoid.WalkSpeed = 16
		humanoid.JumpPower = 50
		humanoid:ChangeState(Enum.HumanoidStateType.Running)
	end)
end)
]]></ProtectedString>
