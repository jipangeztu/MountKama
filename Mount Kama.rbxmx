			<ProtectedString name="Source"><![CDATA[local RS = game:GetService("ReplicatedStorage")
local event = RS:WaitForChild("SelectDifficulty")

local difficultiesFolder = RS:WaitForChild("Difficulties")

--------------------------------------------------
-- EVENT
--------------------------------------------------
event.OnServerEvent:Connect(function(player, difficultyName)
	-- validasi difficulty
	if not difficultiesFolder:FindFirstChild(difficultyName) then
		return
	end

	-- SIMPAN STATE PLAYER
	player:SetAttribute("Difficulty", difficultyName)

	-- (opsional, untuk debug)
	-- print(player.Name, "memilih difficulty:", difficultyName)
end)
