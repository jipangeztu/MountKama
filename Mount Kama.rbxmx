	<Item class="Script" referent="RBX5110B9B1248B447C802D35DEB130E2CA">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local RS = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")

local toggleEvent = RS:WaitForChild("ToggleAuraEvent")
local AURA_FOLDER = RS:WaitForChild("AURA")

local AURA_TAG = "AURATITTLE"

local function clearAura(char)
	for _, obj in ipairs(CollectionService:GetTagged(AURA_TAG)) do
		if obj:IsDescendantOf(char) then
			obj:Destroy()
		end
	end
end

local function applyAura(char, auraName)
	local aura = AURA_FOLDER:FindFirstChild(auraName)
	if not aura then return end

	clearAura(char)

	for _, part in ipairs(aura:GetChildren()) do
		local body = char:FindFirstChild(part.Name)
		if body then
			for _, obj in ipairs(part:GetChildren()) do
				if CollectionService:HasTag(obj, AURA_TAG) then
					local clone = obj:Clone()
					clone.Parent = body
					CollectionService:AddTag(clone, AURA_TAG)
				end
			end
		end
	end
end

toggleEvent.OnServerEvent:Connect(function(player, auraName)
	local char = player.Character
	if not char then return end

	if auraName == nil then
		clearAura(char)
	else
		applyAura(char, auraName)
	end
end)
]]></ProtectedString>
