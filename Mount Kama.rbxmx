			<Item class="LocalScript" referent="RBXCF40BA68D0254B949ECF404CBB93FDE3">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ScreenGui target
local speedGui = playerGui:FindFirstChild("Speed")
local emoteGui = playerGui:FindFirstChild("EmoteSystemGui")
local adminGui = playerGui:FindFirstChild("AdminGui")
local ownerGui = playerGui:FindFirstChild("OwnerGui")
local robuxGui = playerGui:FindFirstChild("RobuxGui")
local shopGui = playerGui:FindFirstChild("ShoppingGui")

-- ImageButton ini sendiri
local menuButton = script.Parent

menuButton.MouseButton1Click:Connect(function()
	if adminGui then
		adminGui.Enabled = not adminGui.Enabled
	end
	if ownerGui then
		ownerGui.Enabled = not ownerGui.Enabled
	end
	if speedGui then
		speedGui.Enabled = not speedGui.Enabled
	end
	if emoteGui then
