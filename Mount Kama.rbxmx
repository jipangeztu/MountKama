					<Item class="LocalScript" referent="RBX3A54D22101E94D5DA5DC4D27FCB01F16">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local player = Players.LocalPlayer

local frame = script.Parent

local hide = frame:WaitForChild("Hide")
local show = frame:WaitForChild("Show")



-- STATE AWAL
local hidden = false

--------------------------------------------------
-- FUNCTION APPLY STATE
--------------------------------------------------
local function applyState()
	for _, plr in pairs(Players:GetPlayers()) do
		if plr.Character then
			local head = plr.Character:FindFirstChild("Head")
			if head then
				local ping = head:FindFirstChild("PingGui")
				if ping then
					ping.Enabled = not hidden
				end

				local admin = plr.Character:FindFirstChild("AdminTag", true)
				if admin then
					admin.Enabled = not hidden
				end

				local summit = plr.Character:FindFirstChild("SummitGui", true)
				if summit then
					summit.Enabled = not hidden
				end

			end
		end
	end
end

--------------------------------------------------
-- TOGGLE
--------------------------------------------------
--------------------------------------------------
-- INIT (INI PENTING)
--------------------------------------------------


hide.MouseButton1Click:Connect(function()
	hide.Transparency = 0
	hide.BackgroundColor3 = Color3.fromRGB(1, 255, 39)
	show.Transparency = 0.5
	show.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
	hidden =true
	applyState()
end)
show.MouseButton1Click:Connect(function()
	show.Transparency = 0
	show.BackgroundColor3 = Color3.fromRGB(1, 255, 39)
	hide.Transparency = 0.5
	hide.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
	hidden = false
	applyState()
end)
]]></ProtectedString>
