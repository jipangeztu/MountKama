					<ProtectedString name="Source"><![CDATA[--!strict
--[[
	ItemFilters - SAFE VERSION
	Assets dan Bundles dipisah supaya SearchCatalogAsync tidak error
]]

local ItemFilters = {

	list = {
		-- GENERAL
		"All",
		--"All Bundles",

		-- BODY
		"Body Parts",
		"Heads",

