			</Item>
			<Item class="LocalScript" referent="RBX68A0EF0C4B8544A196EB9412F2CDE1B7">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local button = script.Parent

-- state
local active = false

-- interval auto tap (detik)
local INTERVAL = 0.2

-- fungsi yang dianggap "aksi tombol"
local function onButtonAction()
	print("BUTTON ACTION TRIGGERED")
	-- taruh logic aslinya di sini
end

-- loop auto tap
task.spawn(function()
	while true do
		if active then
			onButtonAction()
		end
		task.wait(INTERVAL)
	end
end)

-- toggle saat ditekan
button.MouseButton1Click:Connect(function()
	active = not active
end)
]]></ProtectedString>
