					<Item class="LocalScript" referent="RBX58CB8487F3BF40BE826168A15C05BD12">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local button = script.Parent
local RS = game:GetService("ReplicatedStorage")
local event = RS:WaitForChild("ChangeAvatar")

button.MouseButton1Click:Connect(function()
	-- ini contoh, kamu bisa ganti pakai dropdown / input lain
	local avatarName = "Dillah"

	event:FireServer(avatarName)
end)
]]></ProtectedString>
