	<Item class="Script" referent="RBXC31955E6CAFE4B32920F362690FC38C7">
		<Properties>
			<ProtectedString name="Source"><![CDATA[--[[
	=====================================================
	        EMOTE FAVORITE DATASTORE SYSTEM
	        (Standalone Version)
	=====================================================
	ServerScriptService > EmoteFavoriteDataStore
	
	Features:
	- Save/Load favorite emotes per player
	- Auto-save on favorite toggle
	- Auto-save before player leaves
	- Data validation and error handling
	- Retry mechanism for failed saves
]]

local DataStoreService = game:GetService("DataStoreService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ==================== CONFIGURATION ====================
local CONFIG = {
	DATASTORE_NAME = "EmoteFavoritesV1",
	AUTO_SAVE_INTERVAL = 300,
	SAVE_ON_LEAVE = true,
	MAX_FAVORITES = 50,
	RETRY_ATTEMPTS = 3,
	RETRY_DELAY = 1,
	DEBUG_MODE = false,
}

-- ==================== DATASTORE SETUP ====================
local EmoteFavoriteStore = DataStoreService:GetDataStore(CONFIG.DATASTORE_NAME)

-- Store player data in memory
local PlayerFavorites = {}
local PlayerDataLoaded = {}

-- ==================== REMOTE EVENTS ====================
local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes"):FindFirstChild("EmoteRemotes")
if not remotesFolder then
	remotesFolder = Instance.new("Folder")
	remotesFolder.Name = "EmoteRemotes"
	remotesFolder.Parent = ReplicatedStorage
end

local LoadFavoritesRemote = remotesFolder:FindFirstChild("LoadFavorites")
if not LoadFavoritesRemote then
	LoadFavoritesRemote = Instance.new("RemoteFunction")
	LoadFavoritesRemote.Name = "LoadFavorites"
	LoadFavoritesRemote.Parent = remotesFolder
end

local SaveFavoriteRemote = remotesFolder:FindFirstChild("SaveFavorite")
if not SaveFavoriteRemote then
	SaveFavoriteRemote = Instance.new("RemoteEvent")
	SaveFavoriteRemote.Name = "SaveFavorite"
	SaveFavoriteRemote.Parent = remotesFolder
end

-- ==================== UTILITY FUNCTIONS ====================
local function debugPrint(...)
	if CONFIG.DEBUG_MODE then
		print("[EmoteDataStore]", ...)
	end
end

local function getDataKey(player)
	return "Player_" .. player.UserId
end

-- Validate favorites data
local function validateFavorites(favorites)
	if type(favorites) ~= "table" then
		return {}
	end

	local validated = {}
	for _, emoteName in ipairs(favorites) do
		if type(emoteName) == "string" and #validated < CONFIG.MAX_FAVORITES then
			table.insert(validated, emoteName)
		end
	end

	return validated
end

-- ==================== LOAD FAVORITES ====================
local function loadPlayerFavorites(player)
	local key = getDataKey(player)
	local attempts = 0
	local success = false
	local data = nil

	repeat
		attempts = attempts + 1

		local loadSuccess, result = pcall(function()
			return EmoteFavoriteStore:GetAsync(key)
		end)

		if loadSuccess then
			success = true
			data = result
			debugPrint("Loaded favorites for", player.Name, "- Attempts:", attempts)
		else
			warn("[EmoteDataStore] Load failed for", player.Name, "- Error:", result, "- Attempt:", attempts)
			if attempts < CONFIG.RETRY_ATTEMPTS then
				task.wait(CONFIG.RETRY_DELAY)
			end
		end

	until success or attempts >= CONFIG.RETRY_ATTEMPTS

	-- Process data
	if data and type(data) == "table" and data.Favorites then
		PlayerFavorites[player.UserId] = validateFavorites(data.Favorites)
	else
		PlayerFavorites[player.UserId] = {}
	end

	PlayerDataLoaded[player.UserId] = true

	return PlayerFavorites[player.UserId]
end

-- ==================== SAVE FAVORITES ====================
local function savePlayerFavorites(player, favorites)
	if not player or not player.Parent then
		return false
	end

	local key = getDataKey(player)
	local attempts = 0
	local success = false

	-- Validate before saving
	favorites = validateFavorites(favorites or PlayerFavorites[player.UserId] or {})

	local dataToSave = {
		Favorites = favorites,
		LastSaved = os.time()
	}

	repeat
		attempts = attempts + 1

		local saveSuccess, result = pcall(function()
			EmoteFavoriteStore:SetAsync(key, dataToSave)
		end)

		if saveSuccess then
			success = true
			PlayerFavorites[player.UserId] = favorites
			debugPrint("Saved favorites for", player.Name, "- Count:", #favorites, "- Attempts:", attempts)
		else
			warn("[EmoteDataStore] Save failed for", player.Name, "- Error:", result, "- Attempt:", attempts)
			if attempts < CONFIG.RETRY_ATTEMPTS then
				task.wait(CONFIG.RETRY_DELAY)
			end
		end

	until success or attempts >= CONFIG.RETRY_ATTEMPTS

	return success
end

-- ==================== FAVORITE MANAGEMENT ====================
local function toggleFavorite(player, emoteName)
	if not PlayerDataLoaded[player.UserId] then
		warn("[EmoteDataStore] Data not loaded for", player.Name)
		return false
	end

	local favorites = PlayerFavorites[player.UserId] or {}
	local found = false
	local index = 0

	-- Check if already favorited
	for i, name in ipairs(favorites) do
		if name == emoteName then
			found = true
			index = i
			break
		end
	end

	if found then
		-- Remove from favorites
		table.remove(favorites, index)
		debugPrint(player.Name, "removed favorite:", emoteName)
	else
		-- Add to favorites (with limit check)
		if #favorites >= CONFIG.MAX_FAVORITES then
			warn("[EmoteDataStore]", player.Name, "reached max favorites limit")
			return false
		end
		table.insert(favorites, emoteName)
		debugPrint(player.Name, "added favorite:", emoteName)
	end

	PlayerFavorites[player.UserId] = favorites

	-- Auto-save
	task.spawn(function()
		savePlayerFavorites(player, favorites)
	end)

	return true, favorites
end

local function getFavorites(player)
	if not PlayerDataLoaded[player.UserId] then
		return {}
	end
	return PlayerFavorites[player.UserId] or {}
end

-- ==================== AUTO SAVE SYSTEM ====================
local function startAutoSave()
	task.spawn(function()
		while true do
			task.wait(CONFIG.AUTO_SAVE_INTERVAL)

			for _, player in ipairs(Players:GetPlayers()) do
				if PlayerDataLoaded[player.UserId] then
					task.spawn(function()
						savePlayerFavorites(player)
					end)
				end
			end

			debugPrint("Auto-save completed for all players")
		end
	end)
end

-- ==================== PLAYER EVENTS ====================
Players.PlayerAdded:Connect(function(player)
	debugPrint(player.Name, "joined - Loading favorites...")

	task.spawn(function()
		loadPlayerFavorites(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	if CONFIG.SAVE_ON_LEAVE and PlayerDataLoaded[player.UserId] then
		debugPrint(player.Name, "leaving - Saving favorites...")
		savePlayerFavorites(player)
	end

	-- Cleanup
	task.wait(1)
	PlayerFavorites[player.UserId] = nil
	PlayerDataLoaded[player.UserId] = nil
end)

-- ==================== REMOTE HANDLERS ====================
LoadFavoritesRemote.OnServerInvoke = function(player)
	-- Wait for data to load if not ready
	local timeout = 0
	while not PlayerDataLoaded[player.UserId] and timeout < 10 do
		task.wait(0.5)
		timeout = timeout + 0.5
	end

	return getFavorites(player)
end

SaveFavoriteRemote.OnServerEvent:Connect(function(player, emoteName)
	if type(emoteName) ~= "string" or emoteName == "" then
		warn("[EmoteDataStore] Invalid emote name from", player.Name)
		return
	end

	local success, favorites = toggleFavorite(player, emoteName)

	if success then
		-- Send updated favorites back to client
		SaveFavoriteRemote:FireClient(player, favorites)
	end
end)

-- ==================== INITIALIZE ====================

-- Start auto-save
startAutoSave()

-- Save all data on server shutdown
game:BindToClose(function()

	for _, player in ipairs(Players:GetPlayers()) do
		if PlayerDataLoaded[player.UserId] then
			savePlayerFavorites(player)
		end
	end

	task.wait(3)
end)]]></ProtectedString>
