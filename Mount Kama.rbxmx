				<bool name="DefinesCapabilities">false</bool>
				<string name="Name">Types</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
			</Properties>
		</Item>
		<Item class="ModuleScript" referent="RBX486B69B1B2A34B63A5C69FDD50F9AFCE">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[--!strict

local applyAssetAsync = require(script.applyAssetAsync)
local applyBundleAsync = require(script.applyBundleAsync)

local function isAnimationBundle(bundleId: number): boolean
	-- animation bundle IDs biasanya terdeteksi di applyBundleAsync
	-- fallback aman: animation HARUS replace
	return false
end

local function applyItemsToDescriptionAsync(
	description: HumanoidDescription,
	assetIds: { number },
	bundleIds: { number },
	replace: boolean?
): HumanoidDescription

	-- =========================
	-- APPLY BUNDLES
	-- =========================
	for _, bundleId in bundleIds do
		local shouldReplace = false

		-- animasi: replace
		if replace or isAnimationBundle(bundleId) then
			shouldReplace = true
		end

		applyBundleAsync(description, bundleId, shouldReplace)
	end

	-- =========================
	-- APPLY ASSETS
	-- =========================
	for _, assetId in assetIds do
		-- assets SELALU stack
		applyAssetAsync(description, assetId, false)
	end

	return description
end

return applyItemsToDescriptionAsync
]]></ProtectedString>
