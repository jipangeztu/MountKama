					<ProtectedString name="Source"><![CDATA[--!strict

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local popupTemplate = ReplicatedStorage.UI.Objects.CategoryPopup
local optionTemplate = popupTemplate.OptionButton

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

type SubCategory = {
	name: string,
	assets: { Enum.AvatarAssetType },
	bundles: { Enum.BundleType },
}

local function CategoryPopup(
	anchor: GuiObject,
	subCategories: { SubCategory },
	onSelect: (SubCategory) -> ()
)
	local popup = popupTemplate:Clone()
	popup.Parent = playerGui

	local frame = popup.Frame

	frame.Position = UDim2.fromOffset(
		anchor.AbsolutePosition.X,
		anchor.AbsolutePosition.Y + anchor.AbsoluteSize.Y
	)

	for _, sub in subCategories do
		local btn = optionTemplate:Clone()
		btn.Text = sub.name
		btn.Parent = frame

		btn.Activated:Connect(function()
			popup:Destroy()
			onSelect(sub)
		end)
	end

	popup.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			popup:Destroy()
		end
	end)
end

return CategoryPopup
]]></ProtectedString>
