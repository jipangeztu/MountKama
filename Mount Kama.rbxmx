			<Item class="LocalScript" referent="RBX0350A63DA9694CD2AFCA63EA51ADD043">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local button = script.Parent
local frame = button.Parent:WaitForChild("TittleAura")
local TweenService = game:GetService("TweenService")

-- penting! frame harus punya AnchorPoint = (0.5,0.5)

local openPos = frame.Position       -- posisi terbuka
local closedPos = UDim2.new(-1, 0, 0.5, 0)  -- posisi tertutup

local isOpen = false

frame.Visible = false
frame.Position = closedPos

button.MouseButton1Click:Connect(function()
	-- kalau pertama kali dibuka, bikin visible
	if frame.Visible == false then
		frame.Visible = true
	end

	isOpen = not isOpen

	local tujuan = isOpen and openPos or closedPos
	local tween = TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = tujuan
	})
	tween:Play()
end)

script.Parent.Parent:WaitForChild("TittleAura"):WaitForChild("Tutup").MouseButton1Click:Connect(function()
	if frame.Visible == false then
		frame.Visible = true
	end

	isOpen = not isOpen

	local tujuan = isOpen and openPos or closedPos
	local tween = TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = tujuan
	})
	tween:Play()
end)


]]></ProtectedString>
