							<ProtectedString name="Source"><![CDATA[local button = script.Parent
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local event = RS:WaitForChild("AdminCPTeleport")
local player = Players.LocalPlayer

local cpNumber = tonumber(button.Name)
button.Text = "CP " .. cpNumber

local leaderstats = player:WaitForChild("leaderstats")
local cpValue = leaderstats:WaitForChild("Checkpoint")

local WARNA_AKTIF = Color3.fromRGB(255, 0, 0)
local WARNA_NORMAL = button.BackgroundColor3

--------------------------------------------------
-- UPDATE WARNA
--------------------------------------------------
local function updateColor()
	if cpValue.Value == cpNumber then
		button.BackgroundColor3 = WARNA_AKTIF
	else
		button.BackgroundColor3 = WARNA_NORMAL
	end
end

--------------------------------------------------
-- CLICK
--------------------------------------------------
button.MouseButton1Click:Connect(function()
	event:FireServer(tostring(cpNumber))
end)

--------------------------------------------------
-- LISTENER VALUE
--------------------------------------------------
cpValue:GetPropertyChangedSignal("Value"):Connect(updateColor)

--------------------------------------------------
-- INIT
--------------------------------------------------
updateColor()
]]></ProtectedString>
