	<Item class="Script" referent="RBXF95EA112116A4F6CB3870D3E18CAE2FB">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local RS = game:GetService("ReplicatedStorage")

local teleportEvent = RS:WaitForChild("ResetPlayerEvent")
local statusEvent = RS:WaitForChild("DifficultyStatus")

teleportEvent.OnServerEvent:Connect(function(player)
	--========================
	-- RESET CHECKPOINT
	--========================
	player:SetAttribute("Checkpoint", 0)

	if player:FindFirstChild("leaderstats")
		and player.leaderstats:FindFirstChild("Checkpoint") then
		player.leaderstats.Checkpoint.Value = 0
	end

	--========================
	-- RESET DIFFICULTY STATE
	--========================
	player:SetAttribute("Difficulty", nil)

	--========================
	-- RESPAWN
	--========================
	task.wait(0.1)
	player:LoadCharacter()

	--========================
	-- SERVER SIAP → BUKA GUI
	--========================
	statusEvent:FireClient(player, false)
end)
]]></ProtectedString>
