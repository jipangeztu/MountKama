				<Properties>
					<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local player = Players.LocalPlayer
local mButton = script.Parent  -- tombol atau imagelabel

local userId = player.UserId

local thumbType = Enum.ThumbnailType.HeadShot
local thumbSize = Enum.ThumbnailSize.Size420x420

local content, isReady = Players:GetUserThumbnailAsync(userId, thumbType, thumbSize)

mButton.Image = content
local on = false

local soundOn  = mButton:WaitForChild("SoundOn")
local soundOff = mButton:WaitForChild("SoundOff")



mButton.MouseButton1Click:Connect(function()


	if on then
		soundOn:Play()
	else
		soundOff:Play()
	end
end)
]]></ProtectedString>
