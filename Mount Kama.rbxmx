					<Item class="LocalScript" referent="RBX4B243B41F43248F8B741ADA687622F5A">
						<Properties>
							<ProtectedString name="Source"><![CDATA[-- SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local cc = Lighting:WaitForChild("ColorCorrection")
local blur = Lighting:WaitForChild("Blur")
local bloom = Lighting:WaitForChild("Bloom")
local sunrays = Lighting:WaitForChild("SunRays")
local depthOfField = Lighting:WaitForChild("DepthOfField")

-- PLAYER
local player = Players.LocalPlayer
local PlayerGui = player:WaitForChild("PlayerGui")
local graphicGui = PlayerGui:WaitForChild("GraphicGui")
local framG = graphicGui:WaitForChild("Frame")

-- GUI
local frame = script.Parent

local highbutton = frame:WaitForChild("High")
local lowbutton = frame:WaitForChild("Low")
local max = frame:WaitForChild("Max")

-- REMOTE
local SaveGraphic = ReplicatedStorage:WaitForChild("SaveGraphic")
local LoadGraphic = ReplicatedStorage:WaitForChild("LoadGraphic")
-- GRAPHIC ASSET
local highGraphicFolder = ReplicatedStorage:WaitForChild("High Graphic")
local maxGraphicFolder = ReplicatedStorage:WaitForChild("Max Graphic")
local HIGH_CLONE = "HighGraphic_Clone"
local MAX_CLONE = "MaxGraphic_Clone"

local transOn = 0
local transOff = 0.5
local offColor = Color3.fromRGB(199, 19, 19)
local onColor = Color3.fromRGB(1, 255, 39)

-- JANGAN LANGSUNG ENABLE
 graphicGui.Enabled = false
-- FUNCTION APPLY GRAPHIC


local function applyHigh()
	

	if Workspace:FindFirstChild(MAX_CLONE) then
		Workspace[MAX_CLONE]:Destroy()
	end

	if not Workspace:FindFirstChild(HIGH_CLONE) then
		local clone = highGraphicFolder:Clone()
		clone.Name = HIGH_CLONE
		clone.Parent = Workspace
	end
	highbutton.Transparency = transOn
	highbutton.BackgroundColor3 = onColor
	lowbutton.Transparency = transOff
	lowbutton.BackgroundColor3 = offColor
	max.Transparency = transOff
	max.BackgroundColor3 = offColor

	
	Lighting.GlobalShadows = true
	cc.Enabled = false
	bloom.Enabled = false
	sunrays.Enabled = false
	depthOfField.Enabled = false
	blur.Enabled = false
	
	graphicGui.Enabled = false

end


local function applyLow()

	if Workspace:FindFirstChild(HIGH_CLONE) then
		Workspace[HIGH_CLONE]:Destroy()
	end
	if Workspace:FindFirstChild(MAX_CLONE) then
		Workspace[MAX_CLONE]:Destroy()
	end


	lowbutton.Transparency = transOn
	lowbutton.BackgroundColor3 = onColor
	highbutton.Transparency = transOff
	highbutton.BackgroundColor3 = offColor
	max.Transparency = transOff
	max.BackgroundColor3 = offColor
	
	Lighting.GlobalShadows = false
	cc.Enabled = false
	bloom.Enabled = false
	sunrays.Enabled = false
	depthOfField.Enabled = false
	blur.Enabled = false
	
	graphicGui.Enabled = false
end

local function applyMax()

	if not Workspace:FindFirstChild(MAX_CLONE) then
		local clone = maxGraphicFolder:Clone()
		clone.Name = MAX_CLONE
		clone.Parent = Workspace
	end
	if Workspace:FindFirstChild(HIGH_CLONE) then
		Workspace[HIGH_CLONE]:Destroy()
	end

	max.Transparency = transOn
	max.BackgroundColor3 = onColor
	highbutton.Transparency = transOff
	highbutton.BackgroundColor3 = offColor
	lowbutton.Transparency = transOff
	lowbutton.BackgroundColor3 = offColor
	
	

	
	Lighting.GlobalShadows = true
	cc.Enabled = true
	bloom.Enabled = true
	sunrays.Enabled = true
	depthOfField.Enabled = true
	blur.Enabled = true
	
	graphicGui.Enabled = false
end


-- BUTTON
highbutton.MouseButton1Click:Connect(function()

	
	SaveGraphic:FireServer("High")

	applyHigh()
end)

lowbutton.MouseButton1Click:Connect(function()


	SaveGraphic:FireServer("Low")

	applyLow()
end)

max.MouseButton1Click:Connect(function()
	if Workspace:FindFirstChild(HIGH_CLONE) then
		Workspace[HIGH_CLONE]:Destroy()
	end

   SaveGraphic:FireServer("Max")
	applyMax()
	
end)

framG.High.MouseButton1Click:Connect(function()
	SaveGraphic:FireServer("High")
	applyHigh()
end)

framG.Low.MouseButton1Click:Connect(function()
	SaveGraphic:FireServer("Low")
	applyLow()
end)

framG.Max.MouseButton1Click:Connect(function()
	SaveGraphic:FireServer("Max")
	applyMax()
end)



LoadGraphic.OnClientEvent:Connect(function(mode)
	if mode == "High" then
		applyHigh()
	elseif mode == "Low" then
		applyLow()
	elseif mode == "Max" then
		applyMax()
	else
		graphicGui.Enabled = true
	end
	
end)
]]></ProtectedString>
