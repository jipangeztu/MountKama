	<Item class="Script" referent="RBX3C00CAB9B2CF4E45A74AB5FE3B3BF468">
		<Properties>
			<ProtectedString name="Source"><![CDATA[--====================================
-- FINISH COUNT DATASTORE SERVICE
--====================================

local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local FinishStore = DataStoreService:GetDataStore("FinishCount_v1")

--------------------------------------------------
-- LOAD
--------------------------------------------------
local function loadData(player)
	local data

	local success, err = pcall(function()
		data = FinishStore:GetAsync(player.UserId)
	end)

	if type(data) ~= "table" then
		data = {
			Easy = 0,
			Normal = 0,
			Hard = 0
		}
	end

	-- set attribute
	player:SetAttribute("EasyFinishCount", data.Easy or 0)
	player:SetAttribute("NormalFinishCount", data.Normal or 0)
	player:SetAttribute("HardFinishCount", data.Hard or 0)
end

--------------------------------------------------
-- SAVE
--------------------------------------------------
local function saveData(player)
	local data = {
		Easy = player:GetAttribute("EasyFinishCount") or 0,
		Normal = player:GetAttribute("NormalFinishCount") or 0,
		Hard = player:GetAttribute("HardFinishCount") or 0,
	}

	local success, err = pcall(function()
		FinishStore:SetAsync(player.UserId, data)
	end)

	if not success then
		warn("Gagal save FinishCount:", err)
	end
end

--------------------------------------------------
-- PLAYER LIFECYCLE
--------------------------------------------------
Players.PlayerAdded:Connect(loadData)
Players.PlayerRemoving:Connect(saveData)

game:BindToClose(function()
	for _, player in ipairs(Players:GetPlayers()) do
		saveData(player)
	end
end)
]]></ProtectedString>
