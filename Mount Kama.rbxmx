			<Item class="LocalScript" referent="RBX32012FFAA4294C5890EAF9DAF28A6AB4">
				<Properties>
					<ProtectedString name="Source"><![CDATA[-- 🎵 Music Player Toggle Script
-- Place inside: ToggleButton

local TweenService = game:GetService("TweenService")
local toggleBtn = script.Parent
local mainFrame = toggleBtn.Parent:WaitForChild("MainFrame")

local isOpen = false
local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

-- Original positions
local openPos = UDim2.new(1, -200, 1, -120)
local closedPos = UDim2.new(1, 350, 1, -120) -- moves offscreen

-- Start hidden
mainFrame.Position = closedPos

local function togglePlayer()
	isOpen = not isOpen

	if isOpen then
		
		TweenService:Create(mainFrame, tweenInfo, {Position = openPos}):Play()
	else
		
		TweenService:Create(mainFrame, tweenInfo, {Position = closedPos}):Play()
	end
end

toggleBtn.MouseButton1Click:Connect(togglePlayer)]]></ProtectedString>
