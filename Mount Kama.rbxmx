				<string name="ScriptGuid">{E4413652-A54F-4007-8608-6CAC5C843F85}</string>
				<BinaryString name="AttributesSerialize"></BinaryString>
				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<string name="Name">Music</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
			</Properties>
		</Item>
		<Item class="LocalScript" referent="RBX12EAE0254520475998A91F0E60B5004C">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local PingEvent = ReplicatedStorage:WaitForChild("PingUpdate")
local PingFunc = ReplicatedStorage:WaitForChild("Ping")

while task.wait(1) do
	local start = tick()

	-- aman, nggak bakal matiin loop
	pcall(function()
		PingFunc:InvokeServer()
	end)

	local ping = math.floor((tick() - start) * 1000)
	PingEvent:FireServer(ping)
end
]]></ProtectedString>
