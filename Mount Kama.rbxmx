			<Item class="LocalScript" referent="RBX616516D3E3FA459D865D2489365D3EBA">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local mButton = script.Parent
local on = false

local warnaOn  = Color3.fromRGB(85, 255, 255)
local warnaOff = mButton.BackgroundColor3

local adminPanel = script.Parent.Parent:WaitForChild("AdminPanel")
local cpTele  = script.Parent.Parent:WaitForChild("CpTeleport")

local soundOn  = mButton:WaitForChild("SoundOn")
local soundOff = mButton:WaitForChild("SoundOff")

-- AWALNYA PANEL MATI
adminPanel.Visible = false
cpTele.Visible = false

mButton.MouseButton1Click:Connect(function()
	on = not on
	mButton.BackgroundColor3 = on and warnaOn or warnaOff

	-- 🔥 INI INTINYA
	adminPanel.Visible = on
	cpTele.Visible = on

	if on then
		soundOn:Play()
	else
		soundOff:Play()
	end
end)
]]></ProtectedString>
