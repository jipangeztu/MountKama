				<BinaryString name="AttributesSerialize"></BinaryString>
				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<string name="Name">AvatarContextMenu</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
			</Properties>
		</Item>
		<Item class="LocalScript" referent="RBX25476892D70B481587C0979AE1D10E68">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--================================
-- CAMERA ZOOM OUT + ORBIT + ZOOM IN
-- (REPEATABLE)
--================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local camera = Workspace.CurrentCamera

-- TARGET PART
local targetPart = Workspace:WaitForChild("SummitCamera")

-- CONFIG
local ZOOM_OUT_TIME = 10
local HOLD_TIME = 1.2
local ZOOM_IN_TIME = 2

local START_DISTANCE = 100
local MAX_DISTANCE = 800
local HEIGHT_OFFSET = 70
local ROTATE_SPEED = math.rad(26)

local playing = false
local angle = 0

local function getHumanoid()
	local char = player.Character or player.CharacterAdded:Wait()
	return char:WaitForChild("Humanoid")
end

local function easeInOut(t)
	return t * t * (3 - 2 * t)
end

local function playCameraSequence()
	if playing then return end
	playing = true
	angle = 0

	local humanoid = getHumanoid()
	local oldType = camera.CameraType
	local oldSubject = camera.CameraSubject

	camera.CameraType = Enum.CameraType.Scriptable
	camera.CameraSubject = nil

	local center = targetPart.Position
	local startTime = tick()
	local phase = "ZoomOut"
	local holdStart = 0

	local connection
	connection = RunService.RenderStepped:Connect(function(dt)
		local now = tick()
		angle += ROTATE_SPEED * dt

		local distance

		if phase == "ZoomOut" then
			local a = math.clamp((now - startTime) / ZOOM_OUT_TIME, 0, 1)
			distance = START_DISTANCE + (MAX_DISTANCE - START_DISTANCE) * easeInOut(a)
			if a >= 1 then
				phase = "Hold"
				holdStart = now
			end

		elseif phase == "Hold" then
			distance = MAX_DISTANCE
			if now - holdStart >= HOLD_TIME then
				phase = "ZoomIn"
				startTime = now
			end

		elseif phase == "ZoomIn" then
			local a = math.clamp((now - startTime) / ZOOM_IN_TIME, 0, 1)
			distance = MAX_DISTANCE + (START_DISTANCE - MAX_DISTANCE) * easeInOut(a)
			if a >= 1 then
				connection:Disconnect()
				camera.CameraType = oldType
				camera.CameraSubject = humanoid
				playing = false
				return
			end
		end

		local x = math.cos(angle) * distance
		local z = math.sin(angle) * distance
		camera.CFrame = CFrame.new(
			center + Vector3.new(x, HEIGHT_OFFSET, z),
			center
		)
	end)
end

--========================
-- SUMMIT LISTENER
--========================
local leaderstats = player:WaitForChild("leaderstats")
local summit = leaderstats:WaitForChild("Summit")

local lastValue = summit.Value

summit:GetPropertyChangedSignal("Value"):Connect(function()
	if summit.Value > lastValue then
		playCameraSequence()
	end
	lastValue = summit.Value
end)
]]></ProtectedString>
