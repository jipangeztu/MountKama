		<Item class="LocalScript" referent="RBX15CCEA8455AD48FF8539D105D2FC0BB4">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local player = Players.LocalPlayer
local SoundService = game:GetService("SoundService")

local CPFolder = workspace:WaitForChild("CP")
local leaderstats = player:WaitForChild("leaderstats")
local cpValue = leaderstats:WaitForChild("Checkpoint")
local cpSound = SoundService:FindFirstChild("Cp")

local function setParticle(cp, touched)
	local on = cp:FindFirstChild("ON")
	local off = cp:FindFirstChild("OFF")
	cpSound:Play()

	if on and on:IsA("ParticleEmitter") then
		on.Enabled = touched
	end
	if off and off:IsA("ParticleEmitter") then
		off.Enabled = not touched
	end
end

local function updateAll()
	for _, cp in ipairs(CPFolder:GetChildren()) do
		if cp:IsA("BasePart") then
			local index = tonumber(cp.Name)
			if index then
				setParticle(cp, index <= cpValue.Value)
			end
		end
	end
end

-- default saat spawn
updateAll()

-- update realtime
cpValue.Changed:Connect(updateAll)
]]></ProtectedString>
