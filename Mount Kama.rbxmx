				<Item class="LocalScript" referent="RBX5A140E71EA334417A5B0B510FF819666">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local button = script.Parent

local toggled = false
local originalColor

-- ambil warna awal
if button:IsA("ImageButton") then
	originalColor = button.ImageColor3
else
	originalColor = button.BackgroundColor3
end

button.MouseButton1Click:Connect(function()
	toggled = not toggled

	if toggled then
		if button:IsA("ImageButton") then
			button.ImageColor3 = Color3.fromRGB(255, 0, 0)
		else
			button.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
		end
	else
		if button:IsA("ImageButton") then
			button.ImageColor3 = originalColor
		else
			button.BackgroundColor3 = originalColor
		end
	end
end)
]]></ProtectedString>
