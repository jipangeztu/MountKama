			<Item class="LocalScript" referent="RBXA02EFF01767148BFB559F572A7501860">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local button = script.Parent

local TweenService = game:GetService("TweenService")
local rotated = false
local tweenInfo = TweenInfo.new(
	0.25, -- durasi
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)

button.MouseButton1Click:Connect(function()
	rotated = not rotated

	-- rotasi menu
	TweenService:Create(button, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()
end)

script.Parent.Parent:WaitForChild("TittleAura"):WaitForChild("Tutup").MouseButton1Click:Connect(function()
	rotated = not rotated
	TweenService:Create(button, tweenInfo, {
		Rotation = rotated and 45 or 0
	}):Play()
end)]]></ProtectedString>
