	<Item class="Script" referent="RBX97BB1082A80D4E5CB82EA88E49559AA7">
		<Properties>
			<ProtectedString name="Source"><![CDATA[-- ============================================
-- CARRY SERVER HANDLER (DIFFICULTY SAFE)
-- ============================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local carryRemote = ReplicatedStorage:WaitForChild("CarryRemote")

carryRemote.OnServerEvent:Connect(function(player, action, data)
	if action ~= "Request" then return end
	if type(data) ~= "table" then return end

	local targetId = data.targetId
	if not targetId then return end

	local targetPlayer = Players:GetPlayerByUserId(targetId)
	if not targetPlayer then return end
	if targetPlayer == player then return end

	-- ===============================
	-- DIFFICULTY VALIDATION (FINAL)
	-- ===============================
	local playerDifficulty = player:GetAttribute("Difficulty")
	local targetDifficulty = targetPlayer:GetAttribute("Difficulty")

	if not playerDifficulty or not targetDifficulty then
		warn("[Carry] Ditolak: difficulty belum dipilih")
		return
	end

	if playerDifficulty ~= targetDifficulty then
		warn(
			"[Carry] Ditolak: difficulty beda",
			player.Name, "(" .. playerDifficulty .. ")",
			targetPlayer.Name, "(" .. targetDifficulty .. ")"
		)
		return
	end

	-- ===============================
	-- LULUS → LOGIC CARRY DI SINI
	-- ===============================
	print(
		"[Carry] DIIZINKAN:",
		player.Name,
		"->",
		targetPlayer.Name,
		"| Difficulty:",
		playerDifficulty
	)

	-- TODO:
	-- - Weld character
	-- - Set NetworkOwnership
	-- - Animasi carry
end)
]]></ProtectedString>
