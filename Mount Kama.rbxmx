			<Item class="LocalScript" referent="RBX09E4E6A533E6455D8D5F11B2554C8771">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local button = script.Parent
local frame = button.Parent:WaitForChild("SettingFrame")
local TweenService = game:GetService("TweenService")
local xSetting = script.Parent.Parent:WaitForChild("xSetting")

-- penting! frame harus punya AnchorPoint = (0.5,0.5)

local openSize = frame.Size       -- ganti frame.Size
local closedSize = UDim2.new(0.8, 0, 0, 0)  -- Ganti Size ke 0
local TweenService = game:GetService("TweenService")
local rotated = false
local tweenInfo = TweenInfo.new(
	0.25, -- durasi
	Enum.EasingStyle.Quad,
	Enum.EasingDirection.Out
)

local on = false

local warnaOn  = Color3.fromRGB(218, 6, 255)
local warnaOff = button.BackgroundColor3
	
xSetting.Visible = false



local isOpen = false

frame.Visible = false
--frame.Position = closedSize


local function toggleFrame()
	rotated = not rotated
	on = not on
	isOpen = not isOpen
	button.BackgroundColor3 = on and warnaOn or warnaOff

	-- rotasi menu
	TweenService:Create(button, tweenInfo, {
		Rotation = rotated and 90 or 0
	}):Play()
	
	if frame.Visible == false then
		frame.Visible = isOpen
	end

	

	local tujuan = isOpen and openSize or closedSize
	local tween = TweenService:Create(frame, tweenInfo, {
		Size = tujuan
	})
	tween:Play()

	
	if xSetting.Visible == false then
		task.delay(0.4, function()
			xSetting.Visible = isOpen
		end)
	
	else
		xSetting.Visible = false
	end
	
end

button.MouseButton1Click:Connect(function()
	-- kalau pertama kali dibuka, bikin visible
	toggleFrame()
end)

xSetting.MouseButton1Click:Connect(function()
	
	toggleFrame()
	task.wait(0.25)
	frame.Visible = false
end)]]></ProtectedString>
