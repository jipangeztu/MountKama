		<Properties>
			<ProtectedString name="Source"><![CDATA[local DataStoreService = game:GetService("DataStoreService")
local GraphicStore = DataStoreService:GetDataStore("GraphicSetting")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SaveGraphic = ReplicatedStorage:WaitForChild("SaveGraphic")
local LoadGraphic = ReplicatedStorage:WaitForChild("LoadGraphic")

game.Players.PlayerAdded:Connect(function(player)
	local mode

	pcall(function()
		mode = GraphicStore:GetAsync(player.UserId)
	end)

	player:WaitForChild("PlayerGui")
	task.wait(0.3)

	LoadGraphic:FireClient(player, mode)
end)

SaveGraphic.OnServerEvent:Connect(function(player, mode)
	if mode ~= "High" and mode ~= "Low" and mode ~= "Max" then return end

	pcall(function()
		GraphicStore:SetAsync(player.UserId, mode)
	end)
end)
]]></ProtectedString>
