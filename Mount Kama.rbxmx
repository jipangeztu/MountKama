			<Item class="LocalScript" referent="RBXA5AB07C757444FEB863AEF8E0F184904">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local cam = workspace.CurrentCamera
local player = game.Players.LocalPlayer



local freecam = false
local speed = 30
local sensitivity = 0.2

local move = Vector3.zero
local yaw, pitch = 0, 0
local camCFrame = cam.CFrame
local rotating = false

local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
local hrp = char:WaitForChild("HumanoidRootPart")

local button = script.Parent
local control = script.Parent.Parent:WaitForChild("Fcontrol")

local rUp, rDown, rLeft, rRight = false, false, false, false
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ScreenGui target
local speedGui = playerGui:FindFirstChild("Speed")
local emoteGui = playerGui:FindFirstChild("EmoteSystemGui")
local adminGui = playerGui:FindFirstChild("AdminGui")
local ownerGui = playerGui:FindFirstChild("OwnerGui")
local robuxGui = playerGui:FindFirstChild("RobuxGui")
local shopGui = playerGui:FindFirstChild("ShoppingGui")
local inventory = playerGui:FindFirstChild("Custom Inventory")

-- ImageButton ini sendiri


-- TOGGLE FREECAM
button.MouseButton1Click:Connect(function()
	freecam = not freecam

	if freecam then
		cam.CameraType = Enum.CameraType.Scriptable
		UIS.MouseBehavior = Enum.MouseBehavior.Default

		camCFrame = cam.CFrame

		local rx, ry, rz = cam.CFrame:ToOrientation()
		pitch = math.deg(rx)
		yaw = math.deg(ry)

		move = Vector3.zero

		hrp.Anchored = true
	else
		cam.CameraType = Enum.CameraType.Custom
		cam.CameraSubject = hum
		UIS.MouseBehavior = Enum.MouseBehavior.Default

		hrp.Anchored = false
	end
	if adminGui then
		adminGui.Enabled = not adminGui.Enabled
	end
	if ownerGui then
		ownerGui.Enabled = not ownerGui.Enabled
	end
	if speedGui then
		speedGui.Enabled = not speedGui.Enabled
	end
	if emoteGui then
		emoteGui.Enabled = not emoteGui.Enabled
	end
	if robuxGui then
		robuxGui.Enabled = not robuxGui.Enabled
	end
	if shopGui then
		shopGui.Enabled = not shopGui.Enabled
	end
	if inventory then
		inventory.Enabled = not inventory.Enabled
	end
	control.Visible = freecam
end)

-- INPUT BEGIN
UIS.InputBegan:Connect(function(i, gp)
	if gp then return end

	if i.UserInputType == Enum.UserInputType.MouseButton2 and freecam then
		rotating = true
		UIS.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
	end

	if not freecam then return end

	if i.KeyCode == Enum.KeyCode.W then move += Vector3.new(0,0,1) end
	if i.KeyCode == Enum.KeyCode.S then move += Vector3.new(0,0,-1) end
	if i.KeyCode == Enum.KeyCode.A then move += Vector3.new(-1,0,0) end
	if i.KeyCode == Enum.KeyCode.D then move += Vector3.new(1,0,0) end
	if i.KeyCode == Enum.KeyCode.E then move += Vector3.new(0,1,0) end
	if i.KeyCode == Enum.KeyCode.Q then move += Vector3.new(0,-1,0) end
end)

-- INPUT END
UIS.InputEnded:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton2 then
		rotating = false
		UIS.MouseBehavior = Enum.MouseBehavior.Default
	end

	if not freecam then return end

	if i.KeyCode == Enum.KeyCode.W then move -= Vector3.new(0,0,1) end
	if i.KeyCode == Enum.KeyCode.S then move -= Vector3.new(0,0,-1) end
	if i.KeyCode == Enum.KeyCode.A then move -= Vector3.new(-1,0,0) end
	if i.KeyCode == Enum.KeyCode.D then move -= Vector3.new(1,0,0) end
	if i.KeyCode == Enum.KeyCode.E then move -= Vector3.new(0,1,0) end
	if i.KeyCode == Enum.KeyCode.Q then move -= Vector3.new(0,-1,0) end
end)

-- MOUSE LOOK (RMB ONLY)
UIS.InputChanged:Connect(function(input, gp)
	if not freecam or not rotating or gp then return end
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		yaw -= input.Delta.X * sensitivity
		pitch = math.clamp(pitch - input.Delta.Y * sensitivity, -80, 80)
	end
end)

control.Up.MouseButton1Down:Connect(function()
	move += Vector3.new(0,0,1)
end)
control.Up.MouseButton1Up:Connect(function()
	move -= Vector3.new(0,0,1)
end)
control.Down.MouseButton1Down:Connect(function()
	move -= Vector3.new(0,0,1)
end)
control.Down.MouseButton1Up:Connect(function()
	move += Vector3.new(0,0,1)
end)
control.Left.MouseButton1Down:Connect(function()
	move += Vector3.new(-1,0,0)
end)
control.Left.MouseButton1Up:Connect(function()
	move -= Vector3.new(-1,0,0)
end)
control.Right.MouseButton1Down:Connect(function()
	move += Vector3.new(1,0,0)
end)
control.Right.MouseButton1Up:Connect(function()
	move -= Vector3.new(1,0,0)
end)
control.Atas.MouseButton1Down:Connect(function()
	move += Vector3.new(0,1,0)
end)
control.Atas.MouseButton1Up:Connect(function()
	move -= Vector3.new(0,1,0)
end)
control.Bawah.MouseButton1Down:Connect(function()
	move += Vector3.new(0,-1,0)
end)
control.Bawah.MouseButton1Up:Connect(function()
	move -= Vector3.new(0,-1,0)
end)
control.Rup.MouseButton1Down:Connect(function()
	rUp = true
end)
control.Rup.MouseButton1Up:Connect(function()
	rUp = false
end)

control.Rdown.MouseButton1Down:Connect(function()
	rDown = true
end)
control.Rdown.MouseButton1Up:Connect(function()
	rDown = false
end)

control.Rleft.MouseButton1Down:Connect(function()
	rLeft = true
end)
control.Rleft.MouseButton1Up:Connect(function()
	rLeft = false
end)

control.Rright.MouseButton1Down:Connect(function()
	rRight = true
end)
control.Rright.MouseButton1Up:Connect(function()
	rRight = false
end)
control.Exit.MouseButton1Down:Connect(function()
	freecam = not freecam

	if freecam then
		cam.CameraType = Enum.CameraType.Scriptable
		UIS.MouseBehavior = Enum.MouseBehavior.Default

		camCFrame = cam.CFrame
		yaw, pitch = 0, 0
		move = Vector3.zero

		hrp.Anchored = true
	else
		cam.CameraType = Enum.CameraType.Custom
		cam.CameraSubject = hum
		UIS.MouseBehavior = Enum.MouseBehavior.Default

		hrp.Anchored = false
	end
end)
-- CAMERA UPDATE (ROBLOX STYLE)
RunService.RenderStepped:Connect(function(dt)
	if not freecam then return end
	local rotSpeed = 60 -- derajat per detik

	if rUp then
		pitch = math.clamp(pitch + rotSpeed * dt, -80, 80)
	end
	if rDown then
		pitch = math.clamp(pitch - rotSpeed * dt, -80, 80)
	end
	if rLeft then
		yaw += rotSpeed * dt
	end
	if rRight then
		yaw -= rotSpeed * dt
	end

	local rot = CFrame.fromOrientation(math.rad(pitch), math.rad(yaw), 0)
	camCFrame = CFrame.new(camCFrame.Position) * rot

	local moveWorld =
		camCFrame.LookVector * move.Z +
		camCFrame.RightVector * move.X +
		Vector3.yAxis * move.Y

	camCFrame += moveWorld * speed * dt
	cam.CFrame = camCFrame
end)
]]></ProtectedString>
