			<Item class="LocalScript" referent="RBX09583332D1B8457EA7296970AF371B9A">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local button = script.Parent
local frame = button.Parent:WaitForChild("ResetFrame")

frame.Visible = false  -- awalnya mati
frame.Position = UDim2.new(0.5, 0, 0.5, 0)  -- di tengah
frame.AnchorPoint = Vector2.new(0.5, 0.5)  -- agar tetap di tengah

button.MouseButton1Click:Connect(function()
	frame.Visible = not frame.Visible
end)
]]></ProtectedString>
