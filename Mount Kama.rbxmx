			<Item class="LocalScript" referent="RBX167D0A758F1F4AC8B2F782E2225E93ED">
				<Properties>
					<ProtectedString name="Source"><![CDATA[-- SERVICES
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

-- PLAYER
local player = Players.LocalPlayer
local button = script.Parent

-- UI SETUP
-- DATA
local jumpPowers = {50, 55, 60, 65, 75}
local speeds     = {16, 36, 46, 66, 76}
local labels     = {"Coil : 0", "Coil : 1", "Coil : 2", "Coil : 3", "VIP Coil"}
local colors = {
	Color3.fromRGB(0, 255, 8),
	Color3.fromRGB(255, 170, 0),
	Color3.fromRGB(0, 234, 255),
	Color3.fromRGB(255, 0, 4),
	Color3.fromRGB(221, 26, 255)
}

-- STATE CONFIG
local MAX_STATE_NORMAL = 4
local MAX_STATE_VIP = 5

local humanoid
local state = 1

-- VIP STATUS
local isVIP = player:GetAttribute("VIP") == true

player:GetAttributeChangedSignal("VIP"):Connect(function()
	isVIP = player:GetAttribute("VIP") == true
end)

-- APPLY STATE
local function apply()
	if not humanoid or humanoid.Health <= 0 then return end

	-- anti bypass
	if state == 5 and not isVIP then
		state = 1
	end

	humanoid.WalkSpeed = speeds[state]
	humanoid.JumpPower = jumpPowers[state]
	humanoid.PlatformStand = false
	humanoid:ChangeState(Enum.HumanoidStateType.Running)

	button.Text = labels[state]
	button.BackgroundColor3 = colors[state]
	button.TextSize = (state == 5) and 30 or 15
end

-- CHARACTER LOAD
local function onCharacterAdded(char)
	humanoid = char:WaitForChild("Humanoid")
	state = 1
	task.wait(0.3)
	apply()
end

player.CharacterAdded:Connect(onCharacterAdded)
if player.Character then
	onCharacterAdded(player.Character)
end

-- CHANGE STATE FUNCTION
local function nextState()
	local maxState = isVIP and MAX_STATE_VIP or MAX_STATE_NORMAL

	state += 1
	if state > maxState then
		state = 1
	end

	apply()
end

-- INPUT (SHIFT)
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.LeftControl then
		nextState()
	end
end)

-- BUTTON CLICK
button.MouseButton1Click:Connect(function()
	nextState()
end)
]]></ProtectedString>
