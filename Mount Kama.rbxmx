	<Item class="Script" referent="RBXC1428BEDCB5846BFB9ECC52F3541C3A3">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local TeleportEvent = RS:WaitForChild("AdminTeleport")

-- OWNER SHIELD (ANTI BRING)
local bringImmune = {
	[8981440268] = true,  -- Jipang (OWNER)
	[8815015003] = true,  -- Dillah
	[10327418957] = true,  -- juri
	[9131575266] = true,  -- ridho
	[947749461]	= true, --isan
	[2573681427] =true, --aeri
	[4284014929]  = true, -- livy
	[590583166]  = true, -- udin
	[10404516311] = true, -- msa
} 

--------------------------------------------------
local function getHRP(character)
	return character and character:FindFirstChild("HumanoidRootPart")
end

--------------------------------------------------
TeleportEvent.OnServerEvent:Connect(function(player, action, targetName)
	if typeof(action) ~= "string" or typeof(targetName) ~= "string" then
		return
	end

	local target = Players:FindFirstChild(targetName)
	if not target then return end

	-- 🔒 owner shield
	if action == "bring" and bringImmune[target.UserId] then
		warn("TRY BRING OWNER:", player.Name)
		return
	end

	local char = player.Character
	local targetChar = target.Character
	if not char or not targetChar then return end

	local hrp = getHRP(char)
	local targetHrp = getHRP(targetChar)
	if not hrp or not targetHrp then return end

	if action == "tele" then
		-- ADMIN KE PLAYER
		hrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, -3)

	elseif action == "bring" then
		-- PLAYER KE ADMIN
		targetHrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -3)
	end
end)
]]></ProtectedString>
