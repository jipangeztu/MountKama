				<Item class="LocalScript" referent="RBXB5501DC028D64D8A82D7E9B3D8541C1A">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local gui = script.Parent

local toggleEvent = RS:WaitForChild("ToggleAuraEvent")

local currentAura = nil

for _, btn in ipairs(gui:GetChildren()) do
	if not btn:IsA("TextButton") then continue end

	btn.BackgroundColor3 = Color3.fromRGB(200,0,0)

	btn.MouseButton1Click:Connect(function()
		-- klik aura yang sama → MATI
		if currentAura == btn.Name then
			toggleEvent:FireServer(nil)
			currentAura = nil
			btn.BackgroundColor3 = Color3.fromRGB(200,0,0)
			return
		end

		-- reset semua tombol
		for _, b in ipairs(gui:GetChildren()) do
			if b:IsA("TextButton") then
				b.BackgroundColor3 = Color3.fromRGB(200,0,0)
			end
		end

		-- nyalakan aura
		toggleEvent:FireServer(btn.Name)
		currentAura = btn.Name
		btn.BackgroundColor3 = Color3.fromRGB(0,200,0)
	end)
end
]]></ProtectedString>
