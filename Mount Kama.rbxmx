		<Item class="Script" referent="RBXB5D0E34E1CF54EAB83896DCDF6FCBB85">
			<Properties>
				<ProtectedString name="Source"><![CDATA[game.Players.PlayerAdded:Connect(function(player)
	--========================
	-- LEADERSTATS
	--========================
	local folder = Instance.new("Folder")
	folder.Name = "leaderstats"
	folder.Parent = player

	-- Checkpoint
	local cpValue = Instance.new("IntValue")
	cpValue.Name = "Checkpoint"
	cpValue.Value = 0
	cpValue.Parent = folder

	-- Summit
	local summitValue = Instance.new("IntValue")
	summitValue.Name = "Summit"
	summitValue.Value = 0
	summitValue.Parent = folder

	--========================
	-- DIFFICULTY (BARU)
	--========================
	local difficultyValue = Instance.new("StringValue")
	difficultyValue.Name = "Difficulty"
	difficultyValue.Value = "" -- ✅ JANGAN Normal
	difficultyValue.Parent = folder


	--========================
	-- SYNC DARI ATTRIBUTE
	--========================
	-- tunggu attribute Difficulty di-set oleh DifficultyService
	task.spawn(function()
		while not player:GetAttribute("Difficulty") do
			task.wait()
		end

		difficultyValue.Value = player:GetAttribute("Difficulty")
	end)

	-- update realtime kalau difficulty berubah
	player:GetAttributeChangedSignal("Difficulty"):Connect(function()
		local diff = player:GetAttribute("Difficulty")
		if diff then
			difficultyValue.Value = diff
		end
	end)
end)
]]></ProtectedString>
