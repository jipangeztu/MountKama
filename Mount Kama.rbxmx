	<Item class="Folder" referent="RBX9C2D09E0FA7D449FAD3A159AACD49B6B">
		<Properties>
			<BinaryString name="AttributesSerialize"></BinaryString>
			<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">SyncScript</string>
			<int64 name="SourceAssetId">-1</int64>
			<BinaryString name="Tags"></BinaryString>
		</Properties>
		<Item class="Script" referent="RBX6C4743B8A2DC4E68AB23BAED4526F536">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--[[
	SYNC SERVER SCRIPT
	Ditingkatkan: Menggunakan Validasi Ketat, Replikasi Otoritatif, dan Pengembalian Otoritas Jaringan.
]]

-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

-- Import modules
local SyncModule = require(ReplicatedStorage.Modules.SyncModule)
local ServerSyncModule = require(ServerStorage.Modules.ServerSyncModule)

-- ============================================
-- SETUP REMOTES & EMOTES
-- ============================================
local remoteFolder = ReplicatedStorage:FindFirstChild("Remotes")
if not remoteFolder then remoteFolder = Instance.new("Folder") remoteFolder.Name = "Remotes" remoteFolder.Parent = ReplicatedStorage end

local syncFolder = remoteFolder:FindFirstChild("Sync")
if not syncFolder then syncFolder = Instance.new("Folder") syncFolder.Name = "Sync" syncFolder.Parent = remoteFolder end

local SyncRemote = syncFolder:FindFirstChild("SyncRemote")
if not SyncRemote then SyncRemote = Instance.new("RemoteEvent") SyncRemote.Name = "SyncRemote" SyncRemote.Parent = syncFolder end

local UnsyncRemote = syncFolder:FindFirstChild("UnsyncRemote")
if not UnsyncRemote then UnsyncRemote = Instance.new("RemoteEvent") UnsyncRemote.Name = "UnsyncRemote" UnsyncRemote.Parent = syncFolder end

local GlobalSyncEvent = remoteFolder:FindFirstChild("GlobalSyncEvent") -- Ambil Remote Event Baru
if not GlobalSyncEvent then GlobalSyncEvent = Instance.new("RemoteEvent") GlobalSyncEvent.Name = "GlobalSyncEvent" GlobalSyncEvent.Parent = remoteFolder end


local emotesFolder = ReplicatedStorage:FindFirstChild("Emotes")
if not emotesFolder then
	error("[SYNC] CRITICAL: ReplicatedStorage.Emotes not found! Sync disabled.")
end

local remotes = {
	SyncRemote = SyncRemote,
	UnsyncRemote = UnsyncRemote,
	GlobalSyncEvent = GlobalSyncEvent -- Tambahkan ke Remotes table
}

-- ============================================
-- REMOTE EVENT HANDLERS (DENGAN PERBAIKAN VALIDASI)
-- ============================================
local MAX_SYNC_DISTANCE = 40 

SyncRemote.OnServerEvent:Connect(function(player, targetPlayer)
	-- 1. Validasi Dasar & Self-Sync
	if not targetPlayer or not targetPlayer:IsA("Player") or targetPlayer == player then
		SyncRemote:FireClient(player, {cmd = "SyncFailed", reason = "Invalid target/self sync"})
		return
	end

	-- Ambil komponen karakter
	local leaderCharacter = targetPlayer.Character
	local followerCharacter = player.Character

	if not leaderCharacter or not followerCharacter then
		SyncRemote:FireClient(player, {cmd = "SyncFailed", reason = "Characters not loaded"})
		return
	end

	local leaderHRP = leaderCharacter:FindFirstChild("HumanoidRootPart")
	local leaderHumanoid = leaderCharacter:FindFirstChild("Humanoid")
	local followerHRP = followerCharacter:FindFirstChild("HumanoidRootPart")

	-- 2. Validasi Keberadaan Komponen & Status
	if not leaderHRP or not followerHRP or not leaderHumanoid then
		SyncRemote:FireClient(player, {cmd = "SyncFailed", reason = "Missing components (HRP/Humanoid)"})
		return
	end

	if leaderHumanoid.Health <= 0 then
		SyncRemote:FireClient(player, {cmd = "SyncFailed", reason = "Target is down/dead"})
		return
	end

	-- 3. Validasi Jarak
	local distance = (leaderHRP.Position - followerHRP.Position).Magnitude
	if distance > MAX_SYNC_DISTANCE then
		SyncRemote:FireClient(player, {cmd = "SyncFailed", reason = "Target too far ("..math.floor(distance).." stud)"})
		return
	end

	-- 4. Pendelegasian ke Modul Server
	local success = ServerSyncModule.syncAnimations(player, targetPlayer, emotesFolder, remotes)

	if not success then
		SyncRemote:FireClient(player, {cmd = "SyncFailed", reason = "Sync logic failed on server"})
	end
end)

UnsyncRemote.OnServerEvent:Connect(function(player)
	SyncModule.debugPrint("REMOTE", "Unsync request from", player.Name)

	ServerSyncModule.stopSyncing(player, emotesFolder)

	-- Pastikan kepemilikan jaringan dikembalikan setelah unsync
	local HRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if HRP then
		HRP:SetNetworkOwner(player) 
		SyncModule.debugPrint("NETWORK", player.Name .. " ownership returned to client.")
	end

	UnsyncRemote:FireClient(player, {cmd = "UnsyncCompleted"})
end)

-- ============================================
-- PLAYER MANAGEMENT
-- ============================================

Players.PlayerRemoving:Connect(function(player)
	ServerSyncModule.cleanupPlayer(player, emotesFolder)

	UnsyncRemote:FireAllClients({
		cmd = "LeaderLeft",
		leaderUserId = player.UserId
	})
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		ServerSyncModule.cleanupOnRespawn(player, emotesFolder)

		-- Kembalikan kepemilikan jaringan pada respawn
		local HRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if HRP then
			HRP:SetNetworkOwner(player)
		end
	end)
end)

-- ============================================
-- INITIALIZATION
-- ============================================

SyncModule.notify("✓ SERVER INITIALIZED")]]></ProtectedString>
