		<Item class="ModuleScript" referent="RBX14D287683ECF4EF7B1660AC90A4EF5A0">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[--[[
	SYNC MODULE - REPLICATEDSTORAGE
	Shared functions between client and server
	Version 4.1 - Clean Architecture
]]

local SyncModule = {}

-- ============================================
-- CONFIGURATION
-- ============================================

SyncModule.CONFIG = {
	-- Performance
	SyncUpdateRate = 0.033,
	RateLimitCooldown = 100,

	-- Animation
	FadeInTime = 0,
	FadeOutTime = 0.1,
	AnimationPriority = Enum.AnimationPriority.Action4,

	-- Chain Sync
	AllowChainSync = true,
	MaxChainDepth = 50,
	PreventCircularSync = true,

	-- Features
	PreloadAnimations = true,
	EnableNetworkCompensation = true,

	-- Debug
	DebugMode = false, -- Set to true to enable debug messages
	ShowSyncNotifications = true,
}

-- ============================================
-- UTILITY FUNCTIONS
-- ============================================

function SyncModule.debugPrint(category, ...)
	if SyncModule.CONFIG.DebugMode then
		print(string.format("[SYNC][%.3f][%s]", tick(), category), ...)
	end
end

function SyncModule.notify(msg)
	if SyncModule.CONFIG.ShowSyncNotifications then
		print("[SYNC]", msg)
	end
end

function SyncModule.isEmoteAnimation(animation, emotesFolder)
	if not animation or not emotesFolder then return false end

	if animation:IsDescendantOf(emotesFolder) then
		return true
	end

	local animId = animation.AnimationId
	if animId and animId ~= "" then
		for _, emote in ipairs(emotesFolder:GetDescendants()) do
			if emote:IsA("Animation") and emote.AnimationId == animId then
				return true
			end
		end
	end

	for _, emote in ipairs(emotesFolder:GetDescendants()) do
		if emote:IsA("Animation") and emote.Name == animation.Name then
			return true
		end
	end

	return false
end

function SyncModule.waitForChildSafe(parent, childName, timeout)
	local startTime = tick()
	timeout = timeout or 10

	while not parent:FindFirstChild(childName) do
		if tick() - startTime > timeout then
			SyncModule.debugPrint("ERROR", "Timeout waiting for:", childName)
			return nil
		end
		task.wait(0.1)
	end

	return parent:FindFirstChild(childName)
end

function SyncModule.waitForHumanoid(character, playerName, timeout)
	local startTime = tick()
	timeout = timeout or 3

	while not character:FindFirstChild("Humanoid") do
		if tick() - startTime > timeout then
			SyncModule.debugPrint("ERROR", playerName, "humanoid timeout")
			return nil
		end
		task.wait(0.1)
	end

	return character:FindFirstChild("Humanoid")
end

function SyncModule.canSync(follower, leader)
	if not follower or not leader then return false end
	if not follower.Character or not leader.Character then return false end

	local followerHumanoid = follower.Character:FindFirstChild("Humanoid")
	local leaderHumanoid = leader.Character:FindFirstChild("Humanoid")

	return followerHumanoid ~= nil and leaderHumanoid ~= nil
end

function SyncModule.validateSyncRequest(follower, leader)
	if not follower then
		return false, "No follower provided"
	end

	if not leader then
		return false, "No leader provided"
	end

	if follower == leader then
		return false, "Cannot sync with self"
	end

	if not SyncModule.canSync(follower, leader) then
		return false, "Characters not ready"
	end

	return true, "Valid"
end

-- ============================================
-- ANIMATION HELPERS
-- ============================================

function SyncModule.getTrackInfo(track)
	if not track then return nil end

	return {
		Name = track.Animation.Name,
		AnimationId = track.Animation.AnimationId,
		TimePosition = track.TimePosition,
		Speed = track.Speed,
		IsPlaying = track.IsPlaying,
		Length = track.Length,
		Looped = track.Looped,
		WeightCurrent = track.WeightCurrent
	}
end

function SyncModule.isEmoteTrack(track, emotesFolder)
	if not track or not track.Animation then return false end
	return SyncModule.isEmoteAnimation(track.Animation, emotesFolder)
end

return SyncModule]]></ProtectedString>
