		<Item class="ModuleScript" referent="RBXE4A6987F2EA74BA7A71378C298AF0BE1">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[--[[
	SERVER SYNC MODULE - SERVERSTORAGE (SECURE)
	Server-side logic - Not accessible by clients
	Version 4.1 - Clean Architecture
]]

local ServerSyncModule = {}

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Import shared module
local SyncModule = require(ReplicatedStorage.Modules.SyncModule)

-- ============================================
-- SERVER STATE (SECURE)
-- ============================================

local syncedAnimations = {}
local syncingPlayers = {}
local syncFollowers = {}
local isLeader = {}
local playerConnections = {}
local rateLimitCache = {}
local rootLeaders = {}
local preloadedTracks = {}
local playerPings = {}

-- ============================================
-- RATE LIMITING
-- ============================================

function ServerSyncModule.canPerformAction(userId)
	local now = tick()
	local last = rateLimitCache[userId] or 0

	if now - last >= SyncModule.CONFIG.RateLimitCooldown then
		rateLimitCache[userId] = now
		return true
	end

	SyncModule.debugPrint("RATELIMIT", "User", userId, "must wait", 
		SyncModule.CONFIG.RateLimitCooldown - (now - last), "seconds")
	return false
end

-- ============================================
-- NETWORK COMPENSATION
-- ============================================

RunService.Heartbeat:Connect(function()
	for _, player in ipairs(Players:GetPlayers()) do
		local ping = player:GetNetworkPing()
		playerPings[player.UserId] = ping
	end
end)

function ServerSyncModule.getNetworkDelay(player)
	if not SyncModule.CONFIG.EnableNetworkCompensation then
		return 0
	end
	return playerPings[player.UserId] or 0.1
end

-- ============================================
-- CHAIN SYNC MANAGEMENT
-- ============================================

function ServerSyncModule.getRootLeader(player)
	if not SyncModule.CONFIG.AllowChainSync then 
		return player 
	end

	local visited, current, depth = {}, player, 0

	while syncingPlayers[current.UserId] do
		if visited[current.UserId] then
			return SyncModule.CONFIG.PreventCircularSync and nil or current
		end

		visited[current.UserId] = true
		depth = depth + 1

		if SyncModule.CONFIG.MaxChainDepth > 0 and depth > SyncModule.CONFIG.MaxChainDepth then
			return nil
		end

		current = syncingPlayers[current.UserId]
	end

	return current
end

-- ============================================
-- CONNECTION MANAGEMENT
-- ============================================

function ServerSyncModule.disconnectPlayerConnections(userId)
	if playerConnections[userId] then
		for _, conn in pairs(playerConnections[userId]) do
			if conn and typeof(conn) == "RBXScriptConnection" and conn.Connected then
				conn:Disconnect()
			end
		end
		playerConnections[userId] = nil
	end
end

-- ============================================
-- ANIMATION SYNC FUNCTIONS
-- ============================================

function ServerSyncModule.preloadFollowerAnimations(followerAnimator, leaderAnimator, 
	followerUserId, emotesFolder)

	if not SyncModule.CONFIG.PreloadAnimations then return end

	local tracks = leaderAnimator:GetPlayingAnimationTracks()

	if not preloadedTracks[followerUserId] then
		preloadedTracks[followerUserId] = {}
	end

	for _, leaderTrack in ipairs(tracks) do
		if SyncModule.isEmoteTrack(leaderTrack, emotesFolder) then
			local animId = leaderTrack.Animation.AnimationId

			if not preloadedTracks[followerUserId][animId] then
				local followerTrack = followerAnimator:LoadAnimation(leaderTrack.Animation)
				followerTrack.Priority = SyncModule.CONFIG.AnimationPriority
				followerTrack.Looped = leaderTrack.Looped
				preloadedTracks[followerUserId][animId] = followerTrack

				SyncModule.debugPrint("PRELOAD", "Cached:", animId)
			end
		end
	end
end

function ServerSyncModule.playAnimationInstantly(followerAnimator, leaderTrack, 
	followerUserId, followerPlayer, emotesFolder)

	local animId = leaderTrack.Animation.AnimationId

	local followerTrack = preloadedTracks[followerUserId] 
		and preloadedTracks[followerUserId][animId]

	if not followerTrack then
		followerTrack = followerAnimator:LoadAnimation(leaderTrack.Animation)
		followerTrack.Priority = SyncModule.CONFIG.AnimationPriority
		followerTrack.Looped = leaderTrack.Looped

		if not preloadedTracks[followerUserId] then
			preloadedTracks[followerUserId] = {}
		end
		preloadedTracks[followerUserId][animId] = followerTrack
	end

	followerTrack:AdjustSpeed(leaderTrack.Speed)
	followerTrack:Play(SyncModule.CONFIG.FadeInTime, 1, 1)

	local networkDelay = ServerSyncModule.getNetworkDelay(followerPlayer)
	local compensatedTime = leaderTrack.TimePosition + networkDelay

	if not followerTrack.Looped and followerTrack.Length > 0 then
		compensatedTime = math.min(compensatedTime, followerTrack.Length)
	end

	followerTrack.TimePosition = compensatedTime

	if leaderTrack.WeightCurrent and leaderTrack.WeightCurrent > 0 then
		followerTrack:AdjustWeight(leaderTrack.WeightCurrent)
	end

	syncedAnimations[followerUserId] = syncedAnimations[followerUserId] or {}
	syncedAnimations[followerUserId][animId] = followerTrack

	SyncModule.debugPrint("PLAY", leaderTrack.Animation.Name, "@", compensatedTime)

	local stopConn
	stopConn = followerTrack.Stopped:Connect(function()
		if syncedAnimations[followerUserId] then
			syncedAnimations[followerUserId][animId] = nil
		end
		if stopConn and stopConn.Connected then
			stopConn:Disconnect()
		end
		stopConn = nil
	end)

	if not playerConnections[followerUserId] then
		playerConnections[followerUserId] = {}
	end
	if not playerConnections[followerUserId].animStopConns then
		playerConnections[followerUserId].animStopConns = {}
	end
	playerConnections[followerUserId].animStopConns[animId] = stopConn

	return followerTrack
end

-- ============================================
-- STOP SYNCING
-- ============================================

function ServerSyncModule.stopSyncing(player, emotesFolder)
	local userId = player.UserId
	local leader = syncingPlayers[userId]

	SyncModule.debugPrint("UNSYNC", player.Name)

	ServerSyncModule.disconnectPlayerConnections(userId)

	syncingPlayers[userId] = nil
	local root = rootLeaders[userId]
	rootLeaders[userId] = nil

	root = root or leader
	if root and syncFollowers[root.UserId] then
		for i, follower in ipairs(syncFollowers[root.UserId]) do
			if follower.UserId == userId then
				table.remove(syncFollowers[root.UserId], i)
				break
			end
		end

		if #syncFollowers[root.UserId] == 0 then
			isLeader[root.UserId] = nil
			syncFollowers[root.UserId] = nil
		end
	end

	local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
	if humanoid then
		local animator = humanoid:FindFirstChild("Animator")
		if animator then
			for _, track in pairs(animator:GetPlayingAnimationTracks()) do
				if SyncModule.isEmoteTrack(track, emotesFolder) then
					track:Stop(SyncModule.CONFIG.FadeOutTime)
				end
			end
		end
	end

	syncedAnimations[userId] = nil

	if preloadedTracks[userId] then
		for animId, track in pairs(preloadedTracks[userId]) do
			if track then
				track:Destroy()
			end
		end
		preloadedTracks[userId] = nil
	end

	SyncModule.notify("Stopped syncing: " .. player.Name)
end

-- ============================================
-- MAIN SYNC FUNCTION
-- ============================================

function ServerSyncModule.syncAnimations(follower, leader, emotesFolder, remotes)
	SyncModule.debugPrint("SYNC_REQUEST", follower.Name, "→", leader.Name)

	local isValid, errorMsg = SyncModule.validateSyncRequest(follower, leader)
	if not isValid then
		SyncModule.debugPrint("ERROR", errorMsg)
		return false
	end

	if not ServerSyncModule.canPerformAction(follower.UserId) then
		SyncModule.debugPrint("RATELIMIT", follower.Name)
		return false
	end

	local rootLeader = ServerSyncModule.getRootLeader(leader)
	if not rootLeader or rootLeader == follower then
		if SyncModule.CONFIG.PreventCircularSync then
			SyncModule.debugPrint("CIRCULAR", "Prevented")
			return false
		end
		rootLeader = leader
	end

	if syncingPlayers[follower.UserId] then
		SyncModule.debugPrint("CLEANUP", "Stopping previous sync")
		ServerSyncModule.stopSyncing(follower, emotesFolder)
	end

	local humanoid1 = SyncModule.waitForHumanoid(follower.Character, follower.Name, 3)
	local humanoid2 = SyncModule.waitForHumanoid(rootLeader.Character, rootLeader.Name, 3)

	if not humanoid1 or not humanoid2 then
		SyncModule.debugPrint("ERROR", "Failed to get humanoids")
		return false
	end

	local animator1 = humanoid1:FindFirstChild("Animator")
	local animator2 = humanoid2:FindFirstChild("Animator")

	if not animator1 or not animator2 then
		SyncModule.debugPrint("ERROR", "Animator not found")
		return false
	end

	SyncModule.debugPrint("VALIDATE", "All checks passed for", follower.Name)

	syncingPlayers[follower.UserId] = rootLeader
	rootLeaders[follower.UserId] = rootLeader
	syncFollowers[rootLeader.UserId] = syncFollowers[rootLeader.UserId] or {}
	table.insert(syncFollowers[rootLeader.UserId], follower)
	syncedAnimations[follower.UserId] = {}
	playerConnections[follower.UserId] = {}

	if not isLeader[leader.UserId] then
		isLeader[leader.UserId] = true
	end

	SyncModule.debugPrint("SYNC_START", follower.Name, "→", rootLeader.Name)

	ServerSyncModule.preloadFollowerAnimations(animator1, animator2, follower.UserId, emotesFolder)

	local syncCount = 0
	for _, leaderTrack in ipairs(animator2:GetPlayingAnimationTracks()) do
		if SyncModule.isEmoteTrack(leaderTrack, emotesFolder) then
			ServerSyncModule.playAnimationInstantly(animator1, leaderTrack, 
				follower.UserId, follower, emotesFolder)
			syncCount = syncCount + 1
		end
	end

	SyncModule.debugPrint("SYNC_INITIAL", "Synced", syncCount, "active emotes")

	if remotes and remotes.SyncRemote then
		remotes.SyncRemote:FireClient(follower, {
			cmd = "InitialSync",
			leaderUserId = rootLeader.UserId
		})
	end

	local animPlayedConn = animator2.AnimationPlayed:Connect(function(track)
		if rootLeaders[follower.UserId] ~= rootLeader then return end
		if not SyncModule.isEmoteTrack(track, emotesFolder) then return end

		SyncModule.debugPrint("EVENT", "Emote played:", track.Animation.Name)
		ServerSyncModule.playAnimationInstantly(animator1, track, 
			follower.UserId, follower, emotesFolder)
	end)

	playerConnections[follower.UserId].animPlayed = animPlayedConn

	local lastUpdate = tick()
	local renderConn

	renderConn = RunService.Heartbeat:Connect(function()
		local now = tick()

		if now - lastUpdate < SyncModule.CONFIG.SyncUpdateRate then return end
		lastUpdate = now

		if syncingPlayers[follower.UserId] ~= rootLeader then
			if renderConn then renderConn:Disconnect() end
			return
		end

		local currentRoot = rootLeaders[follower.UserId]
		if not currentRoot or not currentRoot.Character then
			ServerSyncModule.stopSyncing(follower, emotesFolder)
			if renderConn then renderConn:Disconnect() end
			return
		end

		local rootAnimator = currentRoot.Character:FindFirstChild("Humanoid")
		if not rootAnimator then
			ServerSyncModule.stopSyncing(follower, emotesFolder)
			if renderConn then renderConn:Disconnect() end
			return
		end

		rootAnimator = rootAnimator:FindFirstChild("Animator")
		if not rootAnimator then
			ServerSyncModule.stopSyncing(follower, emotesFolder)
			if renderConn then renderConn:Disconnect() end
			return
		end

		local leaderTracks = rootAnimator:GetPlayingAnimationTracks()
		local activeAnimIds = {}

		for _, leaderTrack in ipairs(leaderTracks) do
			if SyncModule.isEmoteTrack(leaderTrack, emotesFolder) then
				local animId = leaderTrack.Animation.AnimationId
				activeAnimIds[animId] = true

				local followerTrack = syncedAnimations[follower.UserId] 
					and syncedAnimations[follower.UserId][animId]

				if followerTrack and followerTrack.IsPlaying then
					local drift = math.abs(followerTrack.TimePosition - leaderTrack.TimePosition)
					if drift > 0.1 then
						followerTrack.TimePosition = leaderTrack.TimePosition
					end

					if math.abs(followerTrack.Speed - leaderTrack.Speed) > 0.01 then
						followerTrack:AdjustSpeed(leaderTrack.Speed)
					end

					if leaderTrack.WeightCurrent and followerTrack.WeightCurrent then
						local weightDiff = math.abs(followerTrack.WeightCurrent - leaderTrack.WeightCurrent)
						if weightDiff > 0.01 then
							followerTrack:AdjustWeight(leaderTrack.WeightCurrent)
						end
					end
				end
			end
		end

		if syncedAnimations[follower.UserId] then
			for animId, followerTrack in pairs(syncedAnimations[follower.UserId]) do
				if not activeAnimIds[animId] and followerTrack.IsPlaying then
					followerTrack:Stop(SyncModule.CONFIG.FadeOutTime)
				end
			end
		end
	end)

	playerConnections[follower.UserId].syncLoop = renderConn

	local leaderDied = humanoid2.Died:Connect(function()
		ServerSyncModule.stopSyncing(follower, emotesFolder)
	end)

	local followerDied = humanoid1.Died:Connect(function()
		ServerSyncModule.stopSyncing(follower, emotesFolder)
	end)

	playerConnections[follower.UserId].leaderDied = leaderDied
	playerConnections[follower.UserId].followerDied = followerDied

	SyncModule.notify("Synced: " .. follower.Name .. " → " .. rootLeader.Name)
	return true
end

-- ============================================
-- CLEANUP
-- ============================================

function ServerSyncModule.cleanupPlayer(player, emotesFolder)
	local userId = player.UserId

	SyncModule.debugPrint("CLEANUP", player.Name)

	ServerSyncModule.disconnectPlayerConnections(userId)

	if syncingPlayers[userId] then
		ServerSyncModule.stopSyncing(player, emotesFolder)
	end

	if syncFollowers[userId] then
		for _, follower in ipairs(syncFollowers[userId]) do
			if follower and follower.Parent then
				ServerSyncModule.stopSyncing(follower, emotesFolder)
			end
		end
	end

	syncingPlayers[userId] = nil
	syncFollowers[userId] = nil
	isLeader[userId] = nil
	syncedAnimations[userId] = nil
	rootLeaders[userId] = nil
	rateLimitCache[userId] = nil
	preloadedTracks[userId] = nil
	playerPings[userId] = nil
end

function ServerSyncModule.cleanupOnRespawn(player, emotesFolder)
	task.wait(0.5)
	if syncingPlayers[player.UserId] then
		ServerSyncModule.stopSyncing(player, emotesFolder)
	end
end

return ServerSyncModule]]></ProtectedString>
