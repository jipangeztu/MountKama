					<Item class="LocalScript" referent="RBX7558B4DAD2DE48FBBE1F2316E5922E3C">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local imageLabel = script.Parent -- ImageButton atau ImageLabel

local targetId = 8815015003  -- ID temanmu

local thumbType = Enum.ThumbnailType.HeadShot
local thumbSize = Enum.ThumbnailSize.Size420x420

local content, isReady = Players:GetUserThumbnailAsync(targetId, thumbType, thumbSize)

imageLabel.Image = content
]]></ProtectedString>
