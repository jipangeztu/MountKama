					<Item class="LocalScript" referent="RBXA633F8D1553B490C919DDD3E09212721">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local button = script.Parent
local Lighting = game:GetService("Lighting")


--------------------------------------------------
-- UPDATE UI
--------------------------------------------------
local function updateVisual()
	if Lighting.GlobalShadows then
		button.Text = "ON"
		button.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
	else
		button.Text = "OFF"
		button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
	end
end

--------------------------------------------------
-- CLICK
--------------------------------------------------
button.MouseButton1Click:Connect(function()
	Lighting.GlobalShadows = not Lighting.GlobalShadows
	updateVisual()
end)

--------------------------------------------------
-- AUTO SYNC (kalau berubah dari script lain)
--------------------------------------------------
Lighting:GetPropertyChangedSignal("GlobalShadows"):Connect(updateVisual)

--------------------------------------------------
-- INIT
--------------------------------------------------
updateVisual()
]]></ProtectedString>
