					<ProtectedString name="Source"><![CDATA[--!strict

local AvatarEditorService = game:GetService("AvatarEditorService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ItemDetailsCache = require(ReplicatedStorage.Libraries.ItemDetailsCache)
local removeSimilarAccessories = require(script.Parent.removeSimilarAccessories)

local DIRECT_MAPPINGS = {
	"Head",
	"Torso",
	"RightArm",
	"LeftArm",
	"RightLeg",
	"LeftLeg",

	-- animations (HARUS replace)
	"MoodAnimation",
	"ClimbAnimation",
	"FallAnimation",
	"IdleAnimation",
	"JumpAnimation",
	"RunAnimation",
	"SwimAnimation",
	"WalkAnimation",

	"Shirt",
	"Pants",
	"Face",
}

local INDIRECT_MAPPINGS = {
	DynamicHead = "Head",
	TShirt = "GraphicTShirt",
}

local ACCESSORY_ORDER = {
	[Enum.AccessoryType.RightShoe] = 1,
	[Enum.AccessoryType.LeftShoe] = 1,
	[Enum.AccessoryType.Pants] = 2,
	[Enum.AccessoryType.Shorts] = 2,
	[Enum.AccessoryType.DressSkirt] = 2,
	[Enum.AccessoryType.TShirt] = 3,
	[Enum.AccessoryType.Shirt] = 4,
	[Enum.AccessoryType.Sweater] = 5,
	[Enum.AccessoryType.Jacket] = 6,
}

local ANIMATION_PROPERTIES = {
	MoodAnimation = true,
	ClimbAnimation = true,
	FallAnimation = true,
	IdleAnimation = true,
	JumpAnimation = true,
	RunAnimation = true,
	SwimAnimation = true,
	WalkAnimation = true,
}

local function applyAssetAsync(
	description: HumanoidDescription,
	assetId: number,
	_replace: boolean?
): HumanoidDescription

	local assetDetails = ItemDetailsCache.getAssetDetailsAsync(assetId)
	if not assetDetails then
		warn(`Could not apply asset id {assetId}`)
		return description
	end

	-- =========================
	-- DIRECT MAPPING
	-- =========================
	if table.find(DIRECT_MAPPINGS, assetDetails.AssetType) then
		(description :: any)[assetDetails.AssetType] = assetDetails.Id
		return description
	end

	-- =========================
	-- INDIRECT MAPPING
	-- =========================
	if INDIRECT_MAPPINGS[assetDetails.AssetType] then
		(description :: any)[INDIRECT_MAPPINGS[assetDetails.AssetType]] = assetDetails.Id
		return description
	end

	-- =========================
	-- ACCESSORIES (DEFAULT ROBLOX BEHAVIOR)
	-- =========================
	if string.find(assetDetails.AssetType, "Accessory") or assetDetails.AssetType == "Hat" then
		local accessories = description:GetAccessories(true)

		local assetType = Enum.AvatarAssetType[assetDetails.AssetType]
		local accessoryType = AvatarEditorService:GetAccessoryType(assetType)
		local order = ACCESSORY_ORDER[accessoryType] or 1

		-- ✅ INI YANG DIKEMBALIKAN
		accessories = removeSimilarAccessories(accessoryType, accessories)

		local accessory = {
			AssetId = assetId,
			AccessoryType = accessoryType,
			Order = order,
		}

		table.insert(accessories, accessory)
		description:SetAccessories(accessories, true)
		return description
	end

	warn(`No mapping for asset type {assetDetails.AssetType}`)
	return description
end

return applyAssetAsync
]]></ProtectedString>
					<string name="ScriptGuid">{D15EA006-1EBC-4161-8026-93D7B0F8EBA2}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">applyAssetAsync</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX79168118026F48A98C41839DDBDBE467">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[--!strict

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ItemDetailsCache = require(ReplicatedStorage.Libraries.ItemDetailsCache)
local applyAssetAsync = require(script.Parent.applyAssetAsync)

local function applyBundleAsync(
	description: HumanoidDescription,
	bundleId: number,
	_replace: boolean?
): HumanoidDescription

	local bundleDetails = ItemDetailsCache.getBundleDetailsAsync(bundleId)
	if not bundleDetails then
		warn(`Could not apply bundle id {bundleId}`)
		return description
	end

	for _, bundledItem in bundleDetails.BundledItems do
		if bundledItem.Type ~= "Asset" then
			continue
		end

		-- ✅ BIARKAN applyAssetAsync yang mengatur replace / stacking
		applyAssetAsync(description, bundledItem.Id)
	end

	return description
end

return applyBundleAsync
]]></ProtectedString>
