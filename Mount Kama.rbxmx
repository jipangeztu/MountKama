	<Item class="Script" referent="RBX2B9E150C70E34B8997FA485D30F0B37D">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local DonationStore = DataStoreService:GetDataStore("DonationData_v1")

MarketplaceService.ProcessReceipt = function(receiptInfo)
	print("RECEIPT MASUK", receiptInfo.PurchaseId)

	local player = Players:GetPlayerByUserId(receiptInfo.PlayerId)
	if not player then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local donated = leaderstats and leaderstats:FindFirstChild("Donated")
	if not donated then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	-- update local
	donated.Value += receiptInfo.CurrencySpent

	-- 🔐 SAFE UPDATE DATASTORE
	pcall(function()
		DonationStore:UpdateAsync(player.UserId, function(old)
			return (old or 0) + receiptInfo.CurrencySpent
		end)
	end)

	print("DONASI OK:", donated.Value)

	return Enum.ProductPurchaseDecision.PurchaseGranted
end
]]></ProtectedString>
