						<Properties>
							<ProtectedString name="Source"><![CDATA[local button = script.Parent
local Lighting = game:GetService("Lighting")

local cc1 = Lighting:WaitForChild("ColorCorrection")
local cc2 = Lighting:WaitForChild("ColorCorrection1")
local cc3 = Lighting:WaitForChild("ColorCorrection2")
local cc4 = Lighting:WaitForChild("ColorCorrection3")

local LoadGraphic = game.ReplicatedStorage:WaitForChild("LoadGraphic")


-- ukuran (opsional)


--------------------------------------------------
-- UPDATE BUTTON VISUAL
--------------------------------------------------
local function updateButton()
	if cc1.Enabled then
		button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
		button.Text = "1"
	elseif cc2.Enabled then
		button.BackgroundColor3 = Color3.fromRGB(170, 0, 255)
		button.Text = "2"
	elseif cc3.Enabled then
		button.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
		button.Text = "3"
	elseif cc4.Enabled then
		button.BackgroundColor3 = Color3.fromRGB(141, 137, 255)
		button.Text = "4"
	else
		button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
		button.Text = "OFF"
	end
end

local function hook(cc)
	cc:GetPropertyChangedSignal("Enabled"):Connect(updateButton)
end

hook(cc1)


--------------------------------------------------
-- TOGGLE LOGIC (OFF → 1 → 2 → OFF)
--------------------------------------------------
button.MouseButton1Click:Connect(function()
	if not cc1.Enabled and not cc2.Enabled and not cc3.Enabled and not cc4.Enabled then
		-- OFF → 1
		cc1.Enabled = true

	elseif cc1.Enabled then
		-- 1 → 2
		cc1.Enabled = false
		cc2.Enabled = true

	elseif cc2.Enabled then
		-- 2 → 3
		cc2.Enabled = false
		cc3.Enabled = true

	elseif cc3.Enabled then
		-- 3 → 4
		cc3.Enabled = false
		cc4.Enabled = true

	elseif cc4.Enabled then
		-- 4 → OFF
		cc4.Enabled = false
	end

	updateButton()
end)


--------------------------------------------------
-- INIT (sinkron dari awal)
--------------------------------------------------
updateButton()
]]></ProtectedString>
