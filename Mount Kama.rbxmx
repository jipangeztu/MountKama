			</Properties>
		</Item>
		<Item class="LocalScript" referent="RBXDBF63712B1CF400CBFA61DD95142121A">
			<Properties>
				<ProtectedString name="Source"><![CDATA[-- 🎵 Music Player Client Script
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local SoundService = game:GetService("SoundService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- GUI
local gui = playerGui:WaitForChild("ScreenGui"):WaitForChild("MainFrame")
local titleLabel = gui:WaitForChild("SongTitle")
local playBtn = gui:WaitForChild("PlayPauseBtn")
local prevBtn = gui:WaitForChild("PrevBtn")
local nextBtn = gui:WaitForChild("NextBtn")
local progressBar = gui:WaitForChild("ProgressBar")
local progressFill = progressBar:WaitForChild("ProgressFill")
local timeLabel = gui:WaitForChild("TimeLabel")

-- Folder musik
local MUSIC_FOLDER = "MusicList"

-- State
local songs = {}
local currentIndex = 1
local currentSound = nil
local isPlaying = false
local userSeeking = false
local holding = false


-- Format waktu
local function formatTime(t)
	if not t or t ~= t or t < 0 then return "0:00" end
	local m = math.floor(t / 60)
	local s = math.floor(t % 60)
	return string.format("%d:%02d", m, s)
end


-- Load semua musik
local function loadSongs()
	local folder = SoundService:FindFirstChild(MUSIC_FOLDER)
	if not folder then
		warn("⚠ MusicList tidak ditemukan di SoundService.")
		return
	end
	songs = folder:GetChildren()
	table.sort(songs, function(a, b) return a.Name < b.Name end)
end

loadSongs()


-- Main function
local function playSong(index)
	if currentSound then
		currentSound:Stop()
		currentSound:Destroy()
	end

	if #songs == 0 then
		titleLabel.Text = "No songs"
		return
	end

	currentIndex = math.clamp(index, 1, #songs)
	local song = songs[currentIndex]

	-- clone sound
	local sound = song:Clone()
	sound.Parent = SoundService
	sound.Looped = false
	

	currentSound = sound
	titleLabel.Text = sound.Name

	-- mulai play otomatis
	isPlaying = true
	playBtn.Text = "⏸"

	-- event saat lagu selesai
	sound.Ended:Connect(function()
		local nextIndex = currentIndex + 1
		if nextIndex > #songs then
			nextIndex = 1
		end

		playSong(nextIndex)
	end)


	-- auto play
	wait(5) -- tunggu 0.1 detik
	sound:Play()
end

playSong(1)


-- =======================
-- 🎛 Play / Pause button
-- =======================
playBtn.MouseButton1Click:Connect(function()
	if not currentSound then return end

	if isPlaying then
		currentSound:Pause()
		isPlaying = false
	else
		currentSound:Play()
		isPlaying = true
	end

	-- Update text 100% bersih
	playBtn.Text = isPlaying and "⏸" or "▶"
end)


-- =======================
-- ➡ Next
-- =======================
nextBtn.MouseButton1Click:Connect(function()
	local wasPlaying = isPlaying

	local nextIndex = currentIndex + 1
	if nextIndex > #songs then nextIndex = 1 end

	playSong(nextIndex)

	if wasPlaying then
		currentSound:Play()
		isPlaying = true
		playBtn.Text = "⏸"
	end
end)


-- =======================
-- ⬅ Previous
-- =======================
prevBtn.MouseButton1Click:Connect(function()
	local wasPlaying = isPlaying

	local prevIndex = currentIndex - 1
	if prevIndex < 1 then prevIndex = #songs end

	playSong(prevIndex)

	if wasPlaying then
		currentSound:Play()
		isPlaying = true
		playBtn.Text = "⏸"
	end
end)


-- =======================
-- 🎚 Seek Bar
-- =======================
local function seekTo(ratio)
	if not currentSound or currentSound.TimeLength <= 0 then return end
	local newTime = math.clamp(ratio, 0, 1) * currentSound.TimeLength
	currentSound.TimePosition = newTime
	progressFill.Size = UDim2.new(ratio, 0, 1, 0)
end

progressBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		holding = true
		userSeeking = true
		local rel = (input.Position.X - progressBar.AbsolutePosition.X) / progressBar.AbsoluteSize.X
		seekTo(rel)
	end
end)

progressBar.InputChanged:Connect(function(input)
	if holding and input.UserInputType == Enum.UserInputType.MouseMovement then
		local rel = (input.Position.X - progressBar.AbsolutePosition.X) / progressBar.AbsoluteSize.X
		seekTo(rel)
	end
end)

progressBar.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		holding = false
		userSeeking = false
	end
end)


-- =======================
-- ⏱ Update Time + Progress
-- =======================
RunService.Heartbeat:Connect(function()
	if not currentSound then return end

	if currentSound.TimeLength > 0 then
		local pos = currentSound.TimePosition
		local len = currentSound.TimeLength
		local ratio = pos / len

		if not userSeeking then
			progressFill.Size = UDim2.new(ratio, 0, 1, 0)
		end

		timeLabel.Text = string.format("%s / %s", formatTime(pos), formatTime(len))
	else
		timeLabel.Text = "0:00 / 0:00"
	end
end)


-- SPACE = play/pause
UIS.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.Space then
		playBtn:Activate()
	end
end)
]]></ProtectedString>
